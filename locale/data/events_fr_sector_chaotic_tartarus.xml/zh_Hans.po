msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CHAOS_REVENANT_DEATHBLOOM_DEFEAT\"]/text"
msgstr "但愿没了四处散播毒药与死亡的人，你就能对这里多些了解了。"

#: src-en/data/events_fr_sector_chaotic_tartarus.xml:133
msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CHAOS_REVENANT_DEATHBLOOM_DEFEAT\"]/choice/text"
