msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//ship[@name=\"SHIP_FR_CHAOS_REVENANT_FROSTWALL\"]/deadCrew/text"
msgstr "霜晶壁垒终于溃散了，他的水晶开裂破碎，灵魂也随之消散。"

#: src-en/data/events_fr_sector_chaotic_tartarus.xml:55
msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//ship[@name=\"SHIP_FR_CHAOS_REVENANT_FROSTWALL\"]/deadCrew/choice/text"
