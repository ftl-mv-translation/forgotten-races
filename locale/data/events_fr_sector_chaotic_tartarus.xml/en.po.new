msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CREW_CHAOS_SELECT_TARTARUS\"]/choice[3]/text"
msgstr "Pick Pok."

#: src-en/data/events_fr_sector_chaotic_tartarus.xml:696
msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CREW_CHAOS_SELECT_TARTARUS\"]/choice[3]/event/text"
msgstr ""
"You and your crew hold a brief ritual, and Pok manifests before your eyes, "
"wobbling with joy. \"Pok!\" The little Morph shapeshifts into a form just "
"like yours and gives you a great, big hug."

#: src-en/data/events_fr_sector_chaotic_tartarus.xml:697
msgid ""
