#: src-en/data/events_fr_sector_chaotic_tartarus.xml:707
msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CREW_CHAOS_SELECT_TARTARUS\"]/choice[4]/event/text"
msgstr ""
"You and your crew hold a brief ritual, and Charror manifests before your "
"eyes, their body fully composed for a single moment. \"Mercy...? This unit "
"izZzZzZz... thankful\"."

#: src-en/data/events_fr_sector_chaotic_tartarus.xml:708
msgid ""
"data/events_fr_sector_chaotic_tartarus.xml$//event[@name=\"FR_CREW_CHAOS_SELECT_TARTARUS\"]/choice[4]/event/crewMember"
