"data/events_fr_special_finalfight.xml$//event[@name=\"FR_BEGIN_THE_FIGHT_JERRY\"]/choice/event/choice/event/choice[@req=\"fr_bonus_prince\"]/event/text"
msgstr ""
"Before you begin your fight with the Exterminator, Jerry pauses, and walks "
"out of the room."

#: src-en/data/events_fr_special_finalfight.xml:371
msgid ""
"data/events_fr_special_finalfight.xml$//event[@name=\"FR_BEGIN_THE_FIGHT_JERRY\"]/choice/event/choice/event/choice[@req=\"fr_bonus_prince\"]/event/removeCrew/text"
