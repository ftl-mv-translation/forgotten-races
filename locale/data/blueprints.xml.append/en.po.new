#: src-en/data/blueprints.xml.append:2195
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_COMMONWEALTH_FOCUS\"]/descriptionOverride"
msgstr ""
"This bizarre variation of high-level Pinpoint technology stitches hull together and electrifies systems. This process is extremely harmful to organic beings.\n"
"\n"
"\t\tStats:\n"
"\t\tRequired Power: 3\n"
"\t\tCharge Time: 20 seconds\n"
"\n"
"\t\tBeam Length: Pinpoint\n"
"\t\tBeam Speed: 1\n"
"\t\t\n"
"\t\tHull Repair: 5\n"
"\t\tTotal Crew Damage: 75\n"
"\t\tIon Damage: 5\n"
"\n"
"\t\tFire Chance 50%\n"
"\t\tBreach Chance: 50% (Adjusted: 25%)\n"
"\t\tStun Chance: 100% (25 seconds long)\n"
"\n"
"\t\tDefault Price: 125~   -   Selling Price: 62~"

#: src-en/data/blueprints.xml.append:2214
