#: src-en/data/blueprints.xml.append:3631
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_WITHER_PROTOTYPE_HAVOC\"]/descriptionOverride"
msgstr ""
"This beam annihilates all semblance of order within its target, spreading ionization whilst slaughtering its crew. As a trade-off, it also stitches the hull together and can't deal system damage.\n"
"\n"
"\t\tStats:\n"
"\t\tRequired Power: 3\n"
"\t\tCharge Time: 15 seconds\n"
"\n"
"\t\tBeam Length: 200\n"
"\t\tBeam Speed: 5\n"
"\t\t\n"
"\t\tHull Repair: 4\n"
"\t\tTotal Crew Damage: 75\n"
"\t\tIon Damage: 4\n"
"\n"
"\t\tStun Chance: 100% (15 seconds long)\n"
"\n"
"\t\tDefault Price: 100~   -   Selling Price: 50~"

#: src-en/data/blueprints.xml.append:3648
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_WITHER_PROTOTYPE_HAVOC\"]/tooltipOverride"
msgstr ""
"Required Power: 3\n"
"\t\tCharge Time: 15 seconds\n"
"\n"
"\t\tBeam Length: 200\n"
"\t\tBeam Speed: 5\n"
"\t\t\n"
"\t\tHull Repair: 4\n"
"\t\tTotal Crew Damage: 75\n"
"\t\tIon Damage: 4\n"
"\n"
"\t\tStun Chance: 100% (15 seconds long)"

