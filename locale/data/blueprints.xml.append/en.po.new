#
msgid ""
msgstr ""
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

#: src-en/data/blueprints.xml.append:11
msgid "data/blueprints.xml.append$//systemBlueprint[@name=\"fr_clicker\"]/title"
msgstr "Her Will"

#: src-en/data/blueprints.xml.append:12
msgid "data/blueprints.xml.append$//systemBlueprint[@name=\"fr_clicker\"]/desc"
msgstr ""
"You were gifted with a small fraction of my power. Click on system rooms to ionize them, the number of clicks you can do and how much ion damage they deal raises with each level. Use this well, renegade.\n"
"\\\n"
":)"

#: src-en/data/blueprints.xml.append:33
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/title"
msgstr "Genius Scientist"

#: src-en/data/blueprints.xml.append:34
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/short"
msgstr "Genius"

#: src-en/data/blueprints.xml.append:35
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/desc"
msgstr ""
"The REAL Doctor Eggman, genius scientist and master of robotics! Do not believe the words of drunken rebel captains, they could never match even 1% of his genius.\n"
"\t\n"
"\tInherited Human Engineer stats: takes 0.6x damage from fires, minor suffocation resistance"

#: src-en/data/blueprints.xml.append:42
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/powerList/power[1]"
msgstr "Repairs and sabotages at 2x speed."

#: src-en/data/blueprints.xml.append:43
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/powerList/power[2]"
msgstr "Takes 1.5x damage in crew combat."

#: src-en/data/blueprints.xml.append:44
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/powerList/power[3]"
msgstr "Trained in lvl 2 skills"

#: src-en/data/blueprints.xml.append:45
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/powerList/power[4]"
msgstr ""
"Doubles the damage as well as the repair and movement speed of all friendly "
"crew drones while this crew is repairing a damaged system."

#: src-en/data/blueprints.xml.append:46
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_eggman\"]/powerList/power[5]"
msgstr ""
"Rapidly drains the health of all enemy crew drones on screen while "
"sabotaging systems."

#: src-en/data/blueprints.xml.append:51
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_prophet\"]/title"
msgstr "Cultist Prophet"

#: src-en/data/blueprints.xml.append:52
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_prophet\"]/short"
msgstr "Prophet"

#: src-en/data/blueprints.xml.append:53
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_prophet\"]/desc"
msgstr ""
"The so-called \"True Prophet\" cultist leader. You aren't sure if you should trust him, but he seems to be on your side for now.\n"
"\t\n"
"\tInherited Rock Cultist stats: 175 HP, 0.5x speed and stun duration, fire immunity, Active Ability: Sacrifices a portion of their health for temporarily boosted stats"

#: src-en/data/blueprints.xml.append:60
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_prophet\"]/powerList/power[1]"
msgstr "Provides 1 power when inside an ally drone control room."

#: src-en/data/blueprints.xml.append:61
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_prophet\"]/powerList/power[2]"
msgstr ""
"Grants friendly crew in the same room as him +5% crew damage and max health."

#: src-en/data/blueprints.xml.append:66
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/title"
msgstr "Totality Commander"

#: src-en/data/blueprints.xml.append:67
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/short"
msgstr "Commander"

#: src-en/data/blueprints.xml.append:68
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/desc"
msgstr ""
"The Federation's most capable soldiers. Equipped with state of the art technology with a heavy focus on speed and defense.\n"
"\t\n"
"\tInherited Human Soldier stat: Takes 0.7x damage from crew combat"

#: src-en/data/blueprints.xml.append:75
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/powerList/power[1]"
msgstr ""
"Reconstructive Stimulant: Will automatically heal themselves back to full "
"life when at 40 or less health once per jump. Charge is regained after "
"dying."

#: src-en/data/blueprints.xml.append:76
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/powerList/power[2]"
msgstr "1.5x movement speed, attacks twice as quickly"

#: src-en/data/blueprints.xml.append:77
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/powerList/power[3]"
msgstr "Takes half damage from hazards and is stunned for half as long"

#: src-en/data/blueprints.xml.append:78
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_human_totality\"]/powerList/power[4]"
msgstr "Trained in lvl 2 skills"

#: src-en/data/blueprints.xml.append:83
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/title"
msgstr "Gate's Messenger"

#: src-en/data/blueprints.xml.append:84
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/short"
msgstr "Messenger"

#: src-en/data/blueprints.xml.append:85
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/desc"
msgstr ""
"A being from a race that's almost completely unknown to the Federation and "
"its allies. The only known fact about them is whenever they appear, a leader"
" of a powerful or influential faction will be dead or vanish with no trace "
"of them left behind."

#: src-en/data/blueprints.xml.append:90
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/powerList/power[1]"
msgstr "175 Health, regenerates for 5 health per second even while in combat."

#: src-en/data/blueprints.xml.append:91
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/powerList/power[2]"
msgstr "1.5x repair speed, 0.5x combat damage. Takes 2x weapon damage."

#: src-en/data/blueprints.xml.append:92
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_messenger\"]/powerList/power[3]"
msgstr "Enemy crew directly targed by them deal no ranged damage."

#: src-en/data/blueprints.xml.append:97
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/title"
msgstr "Obelisk Commoner"

#: src-en/data/blueprints.xml.append:98
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/short"
msgstr "Commoner"

#: src-en/data/blueprints.xml.append:99
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/desc"
msgstr ""
"A member of the Obelisk Commonwealth, a caste that was thought to have been completely wiped out by the Royals.\n"
"\n"
"\tInherited Obelisk stats: is immune to fires and suffocation."

#: src-en/data/blueprints.xml.append:106
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/powerList/power[1]"
msgstr ""
"100 Health, regenerates for 1.5 health per second even while in combat."

#: src-en/data/blueprints.xml.append:107
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/powerList/power[2]"
msgstr "3x repair speed, 0.5x sabotage speed."

#: src-en/data/blueprints.xml.append:108
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_commonwealth\"]/powerList/power[3]"
msgstr "Cannot fight, 0.90x movement speed."

#: src-en/data/blueprints.xml.append:113
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/desc"
msgstr ""
"The most famous unaffiliated pirate that the multiverse has ever known. Stuck between making a living and running from his past, this powerful corsair just wants to leave this life behind and retire.\n"
"\t\n"
"\tInherited Legionnaire Operative stats: Repair and movement speed is doubled, greatly resistant to O2 and fire hazards, trained in lvl 2 skills."

#: src-en/data/blueprints.xml.append:116
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/title"
msgstr "Dread Corsair"

#: src-en/data/blueprints.xml.append:117
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/short"
msgstr "Corsair"

#: src-en/data/blueprints.xml.append:122
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/powerList/power[1]"
msgstr ""
"Active Ability: Deploys a Stim Bomb in the room, buffing the movement speed,"
" combat damage, sabotage damage, and repair speed by 20% for 10 seconds of "
"himself and all friedly crew in the same room as him."

#: src-en/data/blueprints.xml.append:123
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/powerList/power[2]"
msgstr ""
"Deals 1.5x combat damage, gains a flat 0.5x combat damage for each friendly "
"crew in the room."

#: src-en/data/blueprints.xml.append:124
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_purple_beard\"]/powerList/power[3]"
msgstr "Max Health is 150. Takes 0.8x combat damage."

#: src-en/data/blueprints.xml.append:129
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/desc"
msgstr ""
"The powerful rock leader in charge of research and exploration. While less fanatical than the other elders, his faith in the Coalition is unbreakable.\n"
"\t\n"
"\tInherited Rock stats: 0.5x speed, fire immunity"

#: src-en/data/blueprints.xml.append:132
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/title"
msgstr "Rockman Research Elder"

#: src-en/data/blueprints.xml.append:133
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/short"
msgstr "R&D Elder"

#: src-en/data/blueprints.xml.append:138
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/powerList/power[1]"
msgstr ""
"Provides an additional +50% repair and sabotage speed to allied crew on any "
"ship."

#: src-en/data/blueprints.xml.append:139
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/powerList/power[2]"
msgstr "Max Health is 300, heals at 150% speed."

#: src-en/data/blueprints.xml.append:140
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/powerList/power[3]"
msgstr "Takes 0.5x suffocation damage. Repairs at 1.25x speed."

#: src-en/data/blueprints.xml.append:141
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_rockmore\"]/powerList/power[4]"
msgstr "Can't be stunned. Trained in level 2 skills."

#: src-en/data/blueprints.xml.append:146
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_victor\"]/title"
msgstr "Rebel Sharpshooter"

#: src-en/data/blueprints.xml.append:147
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_victor\"]/short"
msgstr "Sharpshooter"

#: src-en/data/blueprints.xml.append:148
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_victor\"]/desc"
msgstr ""
"The captain of the Rebel's strike force on the Warfront. They are deadly with their ranged combat, but can't do much hand to hand.\n"
"\n"
"\tInherited Human stat: minor hazardous damage resistance"

#: src-en/data/blueprints.xml.append:155
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_victor\"]/powerList/power[1]"
msgstr "Trained in lvl 1 skills. Learns skills twice as fast."

#: src-en/data/blueprints.xml.append:156
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_victor\"]/powerList/power[2]"
msgstr ""
"Shoots at twice the normal speed. 4x ranged damage multiplier, but only "
"deals 0.25x damage in melee range."

#: src-en/data/blueprints.xml.append:161
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/title"
msgstr "Lead Technician"

#: src-en/data/blueprints.xml.append:162
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/short"
msgstr "L. Tech."

#: src-en/data/blueprints.xml.append:163
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/desc"
msgstr ""
"The leader of the technicians, sent by Universe 1 to teach and guide the new generation of technicians.\n"
"\n"
"\tInherited Technician stats: cannot fight crew or sabotage systems, minor hazardous damage resistance"

#: src-en/data/blueprints.xml.append:170
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/powerList/power[1]"
msgstr "Active Ability: Summons a temporary Battle drone."

#: src-en/data/blueprints.xml.append:171
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/powerList/power[2]"
msgstr "Active Ability: Summons a temporary Repair drone."

#: src-en/data/blueprints.xml.append:172
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/powerList/power[3]"
msgstr "Trained in lvl 2 skills."

#: src-en/data/blueprints.xml.append:173
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_jon\"]/powerList/power[4]"
msgstr ""
"2x repair speed. His summoned drones gain an additional +50% boost to combat"
" or repair while in Engines, Piloting, Shields, Weapons, or Drone Control."

#: src-en/data/blueprints.xml.append:178
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/title"
msgstr "Obelisk Explorer"

#: src-en/data/blueprints.xml.append:179
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/short"
msgstr "Explorer"

#: src-en/data/blueprints.xml.append:180
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/desc"
msgstr ""
"The best of the best in terms of weapon and technology development that the Commonwealth has to offer. Now back from the grave, she's eager to prove all those that doubted her wrong.\n"
"\n"
"\tInherited Commonwealth stats: Cannot fight, is immune to fires and suffocation"

#: src-en/data/blueprints.xml.append:187
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/powerList/power[1]"
msgstr ""
"80 Health, regenerates for 2.5 hp/s to herself and 5 hp/s allied drones in "
"the same room as her."

#: src-en/data/blueprints.xml.append:188
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/powerList/power[2]"
msgstr "10x repair speed, can't sabotage. 1.3x movement speed."

#: src-en/data/blueprints.xml.append:189
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_daisy\"]/powerList/power[3]"
msgstr ""
"Provides a stacking Drone Booster buff to all allied drones on the same "
"ship."

#: src-en/data/blueprints.xml.append:194
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/title"
msgstr "Obelisk Deviser"

#: src-en/data/blueprints.xml.append:195
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/short"
msgstr "Deviser"

#: src-en/data/blueprints.xml.append:196
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/desc"
msgstr ""
"A member of the Obelisk's Deviser Division, a caste focused on building and experimenting with Aether, with the goal of creating the most cutting-edge technology in existence.\n"
"\n"
"\tInherited Obelisk stats: is immune to fires and suffocation."

#: src-en/data/blueprints.xml.append:203
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/powerList/power[1]"
msgstr "150 Health, can teleport anywhere on the current ship."

#: src-en/data/blueprints.xml.append:204
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/powerList/power[2]"
msgstr ""
"0.75x repair speed, 2x sabotage speed. Takes 0.8x damage in melee combat."

#: src-en/data/blueprints.xml.append:205
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_deviser\"]/powerList/power[3]"
msgstr "Deals 0.8x melee damage and 1.5x ranged damage. Can't be stunned."

#: src-en/data/blueprints.xml.append:210
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/title"
msgstr "Obelisk Queen"

#: src-en/data/blueprints.xml.append:211
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/short"
msgstr "Queen"

#: src-en/data/blueprints.xml.append:212
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/desc"
msgstr ""
"The absolute queen of the Obelisk society who rules her subjects with aether-infused iron fists.\n"
"\t\n"
"\tInherited Obelisk Royal stats: is immune to fires and suffocation."

#: src-en/data/blueprints.xml.append:219
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/powerList/power[1]"
msgstr "400 health, immune to mind control."

#: src-en/data/blueprints.xml.append:220
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/powerList/power[2]"
msgstr "Deals 4x combat damage. Can't repair. Starts at level 2 skills"

#: src-en/data/blueprints.xml.append:221
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_y\"]/powerList/power[3]"
msgstr ""
"Moves at 0.5x speed. Sabotages at 0.75x speed. Breaks doors at half speed."

#: src-en/data/blueprints.xml.append:226
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/title"
msgstr "Absolute Cognitive (Defensive)"

#: src-en/data/blueprints.xml.append:227
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/short"
msgstr "Abs. Cognitive [D]"

#: src-en/data/blueprints.xml.append:228
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/desc"
msgstr ""
"This extremely sophisticated AI made for Queen Y herself can swap between multiple modes depending on the situation.\n"
"\t\n"
"\tInherited Advanced Cognitive stats: is immune to fires and suffocation, immune to mind control and sees adjacent rooms, starts at level 2 skills."

#: src-en/data/blueprints.xml.append:235
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/powerList/power[1]"
msgstr "Active Ability: Can swap between its different modes."

#: src-en/data/blueprints.xml.append:236
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/powerList/power[2]"
msgstr "250 Max Health"

#: src-en/data/blueprints.xml.append:237
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/powerList/power[3]"
msgstr "CURRENT STANCE STATS:"

#: src-en/data/blueprints.xml.append:238
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/powerList/power[4]"
msgstr ""
"3x repair speed, provides 2 power from the current allied room, slowly "
"repairs itself, can teleport anywhere on the current ship."

#: src-en/data/blueprints.xml.append:239
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive\"]/powerList/power[5]"
msgstr "Can't fight or sabotage."

#: src-en/data/blueprints.xml.append:244
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/title"
msgstr "Absolute Cognitive (Boarding)"

#: src-en/data/blueprints.xml.append:245
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/short"
msgstr "Abs. Cognitive [B]"

#: src-en/data/blueprints.xml.append:246
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/desc"
msgstr ""
"This extremely sophisticated AI made for Queen Y herself can swap between multiple modes depending on the situation.\n"
"\n"
"\tInherited Advanced Cognitive stats: is immune to fires and suffocation, immune to mind control and sees adjacent rooms, starts at level 2 skills."

#: src-en/data/blueprints.xml.append:253
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/powerList/power[1]"
msgstr "Active Ability: Can swap between its different modes."

#: src-en/data/blueprints.xml.append:254
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/powerList/power[2]"
msgstr "250 Max Health"

#: src-en/data/blueprints.xml.append:255
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/powerList/power[3]"
msgstr "CURRENT STANCE STATS:"

#: src-en/data/blueprints.xml.append:256
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/powerList/power[4]"
msgstr ""
"3x combat and sabotage damage/speed, drains 2 power from the current enemy "
"room, can teleport directly into the enemy ship."

#: src-en/data/blueprints.xml.append:257
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_boarding\"]/powerList/power[5]"
msgstr "Can't repair or heal itself."

#: src-en/data/blueprints.xml.append:262
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/title"
msgstr "Absolute Cognitive (Automated)"

#: src-en/data/blueprints.xml.append:263
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/short"
msgstr "Abs. Cognitive [A]"

#: src-en/data/blueprints.xml.append:264
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/desc"
msgstr ""
"This extremely sophisticated AI made for Queen Y herself can swap between multiple modes depending on the situation.\n"
"\t\t\t\n"
"\tInherited Advanced Cognitive stats: is immune to fires and suffocation, immune to mind control and sees adjacent rooms, starts at level 2 skills."

#: src-en/data/blueprints.xml.append:271
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[1]"
msgstr "Active Ability: Can swap between its different modes."

#: src-en/data/blueprints.xml.append:272
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[2]"
msgstr "250 Max Health"

#: src-en/data/blueprints.xml.append:273
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[3]"
msgstr "CURRENT STANCE STATS:"

#: src-en/data/blueprints.xml.append:274
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[4]"
msgstr ""
"3x combat and sabotage damage/speed, 3x repair speed, can teleport anywhere."

#: src-en/data/blueprints.xml.append:275
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[5]"
msgstr ""
"Slowly repairs itself out of combat. Drains 2 power of the current enemy "
"system and gives 2 power to the current allied system."

#: src-en/data/blueprints.xml.append:276
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_absolute_cognitive_auto\"]/powerList/power[6]"
msgstr "Can't be controlled."

#: src-en/data/blueprints.xml.append:281
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/title"
msgstr "Necromantic Cognitive"

#: src-en/data/blueprints.xml.append:282
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/short"
msgstr "Necro. Cognitive"

#: src-en/data/blueprints.xml.append:283
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/desc"
msgstr ""
"An AI construct that has been twisted and corrupted by the Necro-Lich's powers. Any sentience it had before has been stripped away, leaving it only as a tool for her schemes.\n"
"\n"
"\tInherited Advanced Cognitive stats: is immune to fires and suffocation, immune to mind control and sees adjacent rooms, starts at level 2 skills."

#: src-en/data/blueprints.xml.append:290
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/powerList/power[1]"
msgstr "200 Max Health, quickly repairs itself out of combat."

#: src-en/data/blueprints.xml.append:291
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/powerList/power[2]"
msgstr "1.6x combat damage, moves at 1.6x speed. 1.6x repair speed"

#: src-en/data/blueprints.xml.append:292
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/powerList/power[3]"
msgstr ""
"Can be switched to its Beacon mode, being unable to move or act but also "
"granting powerful bonuses to allied crew in the same ship as them."

#: src-en/data/blueprints.xml.append:293
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive\"]/powerList/power[4]"
msgstr "The crew is considered automated when in beacon mode."

#: src-en/data/blueprints.xml.append:299
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/title"
msgstr "Necromantic Cognitive (Beacon)"

#: src-en/data/blueprints.xml.append:300
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/short"
msgstr "Necro. Cognitive [B]"

#: src-en/data/blueprints.xml.append:301
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/desc"
msgstr ""
"An AI construct that has been twisted and corrupted by the Necro-Lich's powers. Any sentience it had before has been stripped away, leaving it only as a tool for her schemes.\n"
"\n"
"\tInherited Advanced Cognitive stats: is immune to fires and suffocation, immune to mind control and sees adjacent rooms, starts at level 2 skills."

#: src-en/data/blueprints.xml.append:308
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/powerList/power[1]"
msgstr "200 Max Health, quickly repairs itself out of combat."

#: src-en/data/blueprints.xml.append:309
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/powerList/power[2]"
msgstr "1.6x combat damage, moves at 1.6x speed. 1.6x repair speed"

#: src-en/data/blueprints.xml.append:310
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/powerList/power[3]"
msgstr ""
"Can be switched to its Beacon mode, being unable to move or act but also "
"granting powerful bonuses to allied crew in the same ship as them."

#: src-en/data/blueprints.xml.append:311
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_necromantic_cognitive_beacon\"]/powerList/power[4]"
msgstr "The crew is considered automated when in beacon mode."

#: src-en/data/blueprints.xml.append:316
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/title"
msgstr "Nexus Collector"

#: src-en/data/blueprints.xml.append:317
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/short"
msgstr "Collector"

#: src-en/data/blueprints.xml.append:318
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/desc"
msgstr ""
"A Sylvan who was responsible for the sudden appearance of strange new weapons to the multiverse.\n"
"\t\n"
"\tInherited Sylvan stats: 250 HP, 1.5x combat damage, massive hazardous damage resistance, telepathic powers, mind control immunity"

#: src-en/data/blueprints.xml.append:325
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/powerList/power[1]"
msgstr ""
"Active Ability: Deploys a Spider Bomb that unleashes 3 friendly "
"uncontrollable hatchling spiders that live for 10 seconds."

#: src-en/data/blueprints.xml.append:326
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/powerList/power[2]"
msgstr ""
"Portable shield generator makes allies in the same room as him take 20% less"
" damage and deal 5% more damage."

#: src-en/data/blueprints.xml.append:327
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_collector\"]/powerList/power[3]"
msgstr ""
"Portable battery provides 2 power to occupied systems. 2.5x extinguishing "
"speed."

#: src-en/data/blueprints.xml.append:332
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/title"
msgstr "Nexus Deserter"

#: src-en/data/blueprints.xml.append:333
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/short"
msgstr "Deserter"

#: src-en/data/blueprints.xml.append:334
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/desc"
msgstr ""
"A Sylvan who abandoned his job and past life to live with the supposedly extinct Commonwealths.\n"
"\t\n"
"\tInherited Sylvan stats: 250 HP, massive hazardous damage resistance, telepathic powers, mind control immunity\n"
"\tInherited Commonwealth stats: Cannot fight, 3x repair speed"

#: src-en/data/blueprints.xml.append:342
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/powerList/power[1]"
msgstr ""
"Active Ability: (1 charge) Deploys a stun Bomb that can stun crew for 999 "
"seconds and deals 10 ion damage."

#: src-en/data/blueprints.xml.append:343
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/powerList/power[2]"
msgstr "Moves at 1.5x speed. Sabotages at 2x speed."

#: src-en/data/blueprints.xml.append:344
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_cylvan\"]/powerList/power[3]"
msgstr "Immune to stuns."

#: src-en/data/blueprints.xml.append:349
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/title"
msgstr "Spherax"

#: src-en/data/blueprints.xml.append:350
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/short"
msgstr "Spherax"

#: src-en/data/blueprints.xml.append:351
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/desc"
msgstr ""
"One of the last remaining members of the race known as the \"Spherax\", "
"timeless beings solely focused on bettering themselves and pursuing their "
"goals doggedly."

#: src-en/data/blueprints.xml.append:356
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/powerList/power[1]"
msgstr ""
"Active Ability: Can speed up or slow down the room they are currently in for"
" 5 seconds."

#: src-en/data/blueprints.xml.append:357
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/powerList/power[2]"
msgstr "200 health, immune to hazards."

#: src-en/data/blueprints.xml.append:358
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/powerList/power[3]"
msgstr "Can teleport between rooms and ships. Sabotages at 3x speed."

#: src-en/data/blueprints.xml.append:359
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/powerList/power[4]"
msgstr ""
"Instantly regenerates health after being outside of combat for 10 seconds."

#: src-en/data/blueprints.xml.append:360
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_spherax\"]/powerList/power[5]"
msgstr "Can only shoot. Shoots very slowly but deals 5x damage."

#: src-en/data/blueprints.xml.append:365
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/title"
msgstr "Hektar Exile"

#: src-en/data/blueprints.xml.append:366
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/short"
msgstr "Exile"

#: src-en/data/blueprints.xml.append:367
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/desc"
msgstr ""
"After witnessing the death of his brother at the hands of the Rebels, this Billy decided to take up his brother's mantle, even discovering the Nexus and convincing Sylvan Prime to accept him.\n"
"\t\n"
"\tInherited Sylvan stats: 1.5x combat damage, telepathic powers, mind control immunity, starts with level 2 on all skills, doesn't lose skills when cloned"

#: src-en/data/blueprints.xml.append:374
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/powerList/power[1]"
msgstr ""
"Active Ability: Can enter and exit his box at any time. While inside the box"
" he will be fully immune to hazards."

#: src-en/data/blueprints.xml.append:375
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/powerList/power[2]"
msgstr ""
"Active Ability: Deploys a Breach, Lockdown, and Fire Bomb at the same time."

#: src-en/data/blueprints.xml.append:376
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/powerList/power[3]"
msgstr ""
"Heals at half speed from passive sources, but regenerates 20 hp/s while in "
"the box."

#: src-en/data/blueprints.xml.append:377
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan\"]/powerList/power[4]"
msgstr "Max Health is increased to 150."

#: src-en/data/blueprints.xml.append:382
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/title"
msgstr "Hektar Exile"

#: src-en/data/blueprints.xml.append:383
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/short"
msgstr "Exile"

#: src-en/data/blueprints.xml.append:384
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/desc"
msgstr ""
"After witnessing the death of his brother at the hands of the Rebels, this Billy decided to take up his brother's mantle, even discovering the Nexus and convincing Sylvan Prime to accept him.\n"
"\t\n"
"\tInherited Sylvan stats: 1.5x combat damage, massive hazard damage resistance, telepathic powers, mind control immunity, starts with level 2 on all skills, doesn't lose skills when cloned"

#: src-en/data/blueprints.xml.append:391
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/powerList/power[1]"
msgstr ""
"Active Ability: Can enter and exit the box at any time. While inside the box"
" he will be fully immune to hazards."

#: src-en/data/blueprints.xml.append:392
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/powerList/power[2]"
msgstr ""
"Active Ability: Deploys a Breach, Lockdown, and Fire Bomb at the same time."

#: src-en/data/blueprints.xml.append:393
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/powerList/power[3]"
msgstr ""
"Heals at half speed from passive sources, but regenerates 20 hp/s while in "
"the box."

#: src-en/data/blueprints.xml.append:394
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_billvan_box\"]/powerList/power[4]"
msgstr "Max Health is increased to 150."

#: src-en/data/blueprints.xml.append:399
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/title"
msgstr "Head Mascot"

#: src-en/data/blueprints.xml.append:400
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/short"
msgstr "Mascot"

#: src-en/data/blueprints.xml.append:401
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/desc"
msgstr ""
"The actor who plays the popular main character of the Sammy The Spider show. Prefers to be called Michael when the cameras are off.\n"
"\t\n"
"\tInherited Human stats: minor suffocation resistance"

#: src-en/data/blueprints.xml.append:408
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/powerList/power[1]"
msgstr ""
"Active Ability: Swaps between Buff and Debuff mode. CURRENT MODE: DEBUFF"

#: src-en/data/blueprints.xml.append:409
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/powerList/power[2]"
msgstr "Deals 0.5x combat damage and takes 1.2x combat damage."

#: src-en/data/blueprints.xml.append:410
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/powerList/power[3]"
msgstr "Learns skills twice as fast."

#: src-en/data/blueprints.xml.append:411
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy\"]/powerList/power[4]"
msgstr ""
"Constantly plays loud music through his speaker-phones, distracting enemies "
"in the same room as him, lowering their damage, repair and sabotage speed by"
" 50%."

#: src-en/data/blueprints.xml.append:416
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/title"
msgstr "Head Mascot"

#: src-en/data/blueprints.xml.append:417
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/short"
msgstr "Mascot"

#: src-en/data/blueprints.xml.append:418
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/desc"
msgstr ""
"The actor who plays the popular main character of the Sammy The Spider show. Prefers to be called Michael when the cameras are off.\n"
"\t\n"
"\tInherited Human stats: minor suffocation resistance"

#: src-en/data/blueprints.xml.append:425
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/powerList/power[1]"
msgstr ""
"Active Ability: Swaps between Buff and Debuff mode. CURRENT MODE: BUFF"

#: src-en/data/blueprints.xml.append:426
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/powerList/power[2]"
msgstr "Deals 0.5x combat damage and takes 1.2x combat damage."

#: src-en/data/blueprints.xml.append:427
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/powerList/power[3]"
msgstr "Learns skills twice as fast."

#: src-en/data/blueprints.xml.append:428
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_sammy_buff\"]/powerList/power[4]"
msgstr ""
"Constantly plays funky music through his speaker-phones, buffing allies in "
"the same room as him, raising their sabotage, damage and repair speed by "
"50%."

#: src-en/data/blueprints.xml.append:433
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/title"
msgstr "Legion Admiral"

#: src-en/data/blueprints.xml.append:434
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/short"
msgstr "Admiral"

#: src-en/data/blueprints.xml.append:435
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/desc"
msgstr ""
"The Vance of Universe 1, leader of the Legionnaires and the usurper of the Rebel leadership. Very much not a good guy.\n"
"\t\n"
"\tInherited Legionnaire Operative stats: movement speed is doubled, trained in lvl 2 skills, greatly resistant to O2 and fire hazards."

#: src-en/data/blueprints.xml.append:442
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/powerList/power[1]"
msgstr "200 health. Attacks 20% slower at range."

#: src-en/data/blueprints.xml.append:443
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/powerList/power[2]"
msgstr ""
"Deals 3x combat damage as well as repairs and sabotages at 3x speed while "
"inside a room with a friendly human."

#: src-en/data/blueprints.xml.append:444
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/powerList/power[3]"
msgstr "Can't man systems as he doesn't believe in running the ship alone."

#: src-en/data/blueprints.xml.append:445
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_vance_one\"]/powerList/power[4]"
msgstr ""
"Friendly humans in the same room as him get 1.5x of the bonuses that he gets"
" while inside a room with a friendly human."

#: src-en/data/blueprints.xml.append:450
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/desc"
msgstr ""
"The boss of the Haunts, a group of some of the most wanted criminals in the galaxy.\n"
"\t\n"
"\tInherited Vagabond stats: takes no damage from hazards, has door phasing properties"

#: src-en/data/blueprints.xml.append:453
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/title"
msgstr "Boss of the Haunts"

#: src-en/data/blueprints.xml.append:454
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/short"
msgstr "Boss"

#: src-en/data/blueprints.xml.append:459
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/powerList/power[1]"
msgstr ""
"Periodically becomes unable to fight but gains 3x sabotage and repair speed "
"and becomes uncontrollable."

#: src-en/data/blueprints.xml.append:460
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/powerList/power[2]"
msgstr "Max Health is increased to 200"

#: src-en/data/blueprints.xml.append:461
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/powerList/power[3]"
msgstr "Can't sabotage but deals 3x combat damage."

#: src-en/data/blueprints.xml.append:462
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_gozer\"]/powerList/power[4]"
msgstr ""
"Doubles the repair speed of allied Haunts that are in the same room as him."

#: src-en/data/blueprints.xml.append:467
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/desc"
msgstr ""
"This fully sentient hologram is controlled by an advanced AI, housed inside "
"a biological data-substrate."

#: src-en/data/blueprints.xml.append:470
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/title"
msgstr "AI Avatar"

#: src-en/data/blueprints.xml.append:471
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/short"
msgstr "AI Avatar"

#: src-en/data/blueprints.xml.append:474
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/powerList/power[1]"
msgstr "Immune to hazards, phases through doors."

#: src-en/data/blueprints.xml.append:475
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/powerList/power[2]"
msgstr "Max Health is reduced to 50."

#: src-en/data/blueprints.xml.append:476
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_CE_avatar\"]/powerList/power[3]"
msgstr "Starts with level 2 on all skills."

#: src-en/data/blueprints.xml.append:506
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/desc"
msgstr "[DESC MISSING]"

#: src-en/data/blueprints.xml.append:508
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/title"
msgstr "[TITLE]"

#: src-en/data/blueprints.xml.append:509
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/short"
msgstr "Error"

#: src-en/data/blueprints.xml.append:512
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/powerList/power[1]"
msgstr "[SKILLS_INSTANT = TRUE]"

#: src-en/data/blueprints.xml.append:513
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/powerList/power[2]"
msgstr "[HAZARD_AND_STUN_EFFECTS = DISABLED]"

#: src-en/data/blueprints.xml.append:514
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_errorman\"]/powerList/power[3]"
msgstr "[REPAIR = DISABLED] [GLOBAL_TELEPORT = ENABLED]."

#: src-en/data/blueprints.xml.append:554
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/title"
msgstr "Proto-Cognitive"

#: src-en/data/blueprints.xml.append:555
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/short"
msgstr "Pro. Cognitive"

#: src-en/data/blueprints.xml.append:556
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/desc"
msgstr ""
"A semi-sentient AI construct built by the Obelisk Commonwealth for combating"
" boarders; it lacks the capability for even basic repairs. It can be "
"switched between manual control and an automated mode."

#: src-en/data/blueprints.xml.append:561
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/powerList/power[1]"
msgstr "150 Max Health, Slowly repairs itself out of combat."

#: src-en/data/blueprints.xml.append:562
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/powerList/power[2]"
msgstr "1.75x combat damage, moves at 2x speed."

#: src-en/data/blueprints.xml.append:563
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/powerList/power[3]"
msgstr "Immune to mind control and sees adjacent rooms. Can't repair."

#: src-en/data/blueprints.xml.append:564
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/powerList/power[4]"
msgstr "Immune to suffocation and fire damage."

#: src-en/data/blueprints.xml.append:565
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive\"]/powerList/power[5]"
msgstr ""
"Can be switched to Liberated mode, losing direct control but granting large "
"boosts to their stats."

#: src-en/data/blueprints.xml.append:569
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/title"
msgstr "Proto-Cognitive (Automated)"

#: src-en/data/blueprints.xml.append:570
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/short"
msgstr "Pro. Cognitive [A]"

#: src-en/data/blueprints.xml.append:571
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/desc"
msgstr ""
"A semi-sentient AI construct built by the Obelisk Commonwealth for combating"
" boarders; it lacks the capability for even basic repairs. It can be "
"switched between manual control and an automated mode."

#: src-en/data/blueprints.xml.append:576
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[1]"
msgstr "Automated state."

#: src-en/data/blueprints.xml.append:577
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[2]"
msgstr "175 Max Health, Slowly repairs itself out of combat."

#: src-en/data/blueprints.xml.append:578
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[3]"
msgstr "3x combat damage, moves at 2.5x speed."

#: src-en/data/blueprints.xml.append:579
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[4]"
msgstr "Immune to mind control and sees adjacent rooms. Can't repair."

#: src-en/data/blueprints.xml.append:580
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[5]"
msgstr "Immune to suffocation and fire damage."

#: src-en/data/blueprints.xml.append:581
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_proto_cognitive_automated\"]/powerList/power[6]"
msgstr ""
"Can be switched back to Control mode, gaining direct control but losing the "
"large boosts to its stats."

#: src-en/data/blueprints.xml.append:585
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/title"
msgstr "Experimental Cognitive"

#: src-en/data/blueprints.xml.append:586
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/short"
msgstr "Exp. Cognitive"

#: src-en/data/blueprints.xml.append:587
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/desc"
msgstr ""
"A highly advanced AI construct built by Aenwithe, a former engineer in the "
"Obelisk Empire's Cognitive division. This model has to alternate between "
"automated and manual control for safety reasons."

#: src-en/data/blueprints.xml.append:592
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/powerList/power[1]"
msgstr ""
"200 Max Health, takes 10% less damage from combat. Learns skills very "
"quickly."

#: src-en/data/blueprints.xml.append:593
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/powerList/power[2]"
msgstr ""
"1.5x combat damage, moves and repairs at 1.5x speed. Can teleport anywhere."

#: src-en/data/blueprints.xml.append:594
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/powerList/power[3]"
msgstr ""
"Immune to suffocation and fire damage as well as mind control. Gives 1 power"
" when inside a mannable, main system."

#: src-en/data/blueprints.xml.append:595
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive\"]/powerList/power[4]"
msgstr ""
"At every jump it will switch between Automated and Manual mode, becoming "
"uncontrollable and controllable respectively."

#: src-en/data/blueprints.xml.append:599
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/title"
msgstr "Experimental Cognitive (Automated)"

#: src-en/data/blueprints.xml.append:600
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/short"
msgstr "Exp. Cognitive [A]"

#: src-en/data/blueprints.xml.append:601
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/desc"
msgstr ""
"A highly advanced AI construct built by Aenwithe, a former engineer in the "
"Obelisk Empire's Cognitive division. This model has to alternate between "
"automated and manual control for safety reasons."

#: src-en/data/blueprints.xml.append:606
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/powerList/power[1]"
msgstr "Automated."

#: src-en/data/blueprints.xml.append:607
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/powerList/power[2]"
msgstr ""
"200 Max Health, takes 10% less damage from combat. Learns skills very "
"quickly."

#: src-en/data/blueprints.xml.append:608
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/powerList/power[3]"
msgstr ""
"1.5x combat damage, moves and repairs at 1.5x speed. Can teleport anywhere."

#: src-en/data/blueprints.xml.append:609
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/powerList/power[4]"
msgstr ""
"Immune to suffocation and fire damage as well as mind control. Gives 2 power"
" when inside a mannable, main system."

#: src-en/data/blueprints.xml.append:610
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_experimental_cognitive_automated\"]/powerList/power[5]"
msgstr ""
"At every jump it will switch between Automated and Manual mode, becoming "
"uncontrollable and controllable respectively. Can be controlled while in the"
" enemy ship."

#: src-en/data/blueprints.xml.append:617
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/desc"
msgstr ""
"An Augmented who has further varied their biology by consuming a specific "
"piece of ancient wreckage. They can only repair by using their unique "
"abilities."

#: src-en/data/blueprints.xml.append:618
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/title"
msgstr "The Enhanced"

#: src-en/data/blueprints.xml.append:619
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/short"
msgstr "Enhanced"

#: src-en/data/blueprints.xml.append:624
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/powerList/power[1]"
msgstr ""
"Primary Active Ability: Releases stored nano-metals, repairing the hull for "
"1 point. 1 charge per jump."

#: src-en/data/blueprints.xml.append:625
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/powerList/power[2]"
msgstr ""
"Secondary Active Ability: Melds with the system, dealing 40 damage to itself"
" but fully healing the system."

#: src-en/data/blueprints.xml.append:626
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/powerList/power[3]"
msgstr ""
"Max Health is reduced to 80, slowly regenerates health. Immune to hazards, "
"slowly drains air from the room."

#: src-en/data/blueprints.xml.append:627
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_enhanced\"]/powerList/power[4]"
msgstr "Provides power to current room, deals 1.5x damage. Can't repair."

#: src-en/data/blueprints.xml.append:631
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/desc"
msgstr ""
"Bizarrely mutated Lanius who have feasted upon an unusual piece of ancient "
"scrap metal. Although their arms have been rendered harmless noodles, they "
"boast unparalleled sabotage capability."

#: src-en/data/blueprints.xml.append:632
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/title"
msgstr "The Withered"

#: src-en/data/blueprints.xml.append:633
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/short"
msgstr "Withered"

#: src-en/data/blueprints.xml.append:638
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/powerList/power[1]"
msgstr ""
"Active Ability: Assimilates part of the ship hull, doing minor hull damage "
"but dealing x5 boosted sabotage damage (doesn't stack with the normal bonus)"
" and regenerating 5 hp/s for 12 seconds. They will be uncontrollable and "
"unable to be teleported back while this effect is active."

#: src-en/data/blueprints.xml.append:639
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/powerList/power[2]"
msgstr "120 Health. Deals 3x the sabotage damage."

#: src-en/data/blueprints.xml.append:640
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_withered\"]/powerList/power[3]"
msgstr "Can't fight, immune to mind control."

#: src-en/data/blueprints.xml.append:647
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/desc"
msgstr ""
"The Mantis Queen, Leikonpliiinakra, might appear harmless to an outsider, "
"but she is, in fact, the strongest Mantis within the Hive. Her true strength"
" lies in the efficiency boost her mere presence enforces."

#: src-en/data/blueprints.xml.append:648
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/title"
msgstr "Mantis Queen"

#: src-en/data/blueprints.xml.append:649
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/short"
msgstr "Queen"

#: src-en/data/blueprints.xml.append:654
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/powerList/power[1]"
msgstr ""
"Her presence makes friendly crew in the same room deal 1.5x damage and take "
"0.8x damage (Mantis have these buffs raised to 2x and 0.6x respectively)."

#: src-en/data/blueprints.xml.append:655
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/powerList/power[2]"
msgstr "250 Health. Repairs at normal speed. Deals 0.35x damage."

#: src-en/data/blueprints.xml.append:656
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/powerList/power[3]"
msgstr "Attacks in melee range at 3.5x speed. Moves at 0.5x speed."

#: src-en/data/blueprints.xml.append:657
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_mantis_queen\"]/powerList/power[4]"
msgstr ""
"Enemy Hive Mantis are unable to fight when inside the same room as the "
"Queen."

#: src-en/data/blueprints.xml.append:662
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/title"
msgstr "Salt Soldier"

#: src-en/data/blueprints.xml.append:663
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/short"
msgstr "Salt"

#: src-en/data/blueprints.xml.append:664
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/desc"
msgstr ""
"A member of the legendary Salt Empire's armada, thought to have been driven "
"to extinction many years ago. Thanks to the efforts of a determined bounty "
"hunter, they have returned to the fray."

#: src-en/data/blueprints.xml.append:669
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/powerList/power[1]"
msgstr ""
"200 Health, constantly saps the health of nearby enemies at 3.5 damage per "
"second. Slugs take 5 damage per second instead. Nearby enemies heal 30% "
"slower."

#: src-en/data/blueprints.xml.append:670
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/powerList/power[2]"
msgstr ""
"0.80x movement speed, only takes 30% suffocation damage, takes 1.5 times "
"fire damage. 0.25x combat damage and 0.5x sabotage damage."

#: src-en/data/blueprints.xml.append:671
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/powerList/power[3]"
msgstr "Crew's highly corrosive salt makes them deal 5x more damage to doors."

#: src-en/data/blueprints.xml.append:672
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_salt\"]/powerList/power[4]"
msgstr ""
"Salted gases makes Slugs and drones take 30% more damage while in the same "
"room as the crew."

#: src-en/data/blueprints.xml.append:679
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_zoltan_osmian_hologram_weak\"]/desc"
msgstr ""
"A hologram projected by a miniature mobile hardlight emitter. Although not "
"sapient and only temporary, it can perform any task a regular crew member "
"can."

#: src-en/data/blueprints.xml.append:680
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_zoltan_osmian_hologram_weak\"]/title"
msgstr "Hologram"

#: src-en/data/blueprints.xml.append:681
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_zoltan_osmian_hologram_weak\"]/short"
msgstr "Hologram"

#: src-en/data/blueprints.xml.append:686
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_zoltan_osmian_hologram_weak\"]/powerList/power[1]"
msgstr "25 Max Health, immune to hazards. Cannot be cloned."

#: src-en/data/blueprints.xml.append:687
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_zoltan_osmian_hologram_weak\"]/powerList/power[2]"
msgstr "Can man systems at lvl 2 skill level."

#: src-en/data/blueprints.xml.append:692
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_wither_hologram\"]/desc"
msgstr "A hologram projected by a highly advanced prototype Aether weapon."

#: src-en/data/blueprints.xml.append:693
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_wither_hologram\"]/title"
msgstr "Wither Hologram"

#: src-en/data/blueprints.xml.append:694
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_wither_hologram\"]/short"
msgstr "W. Hologram"

#: src-en/data/blueprints.xml.append:699
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_wither_hologram\"]/powerList/power[1]"
msgstr "300 Max Health, 2x crew damage, immune to hazards."

#: src-en/data/blueprints.xml.append:700
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_wither_hologram\"]/powerList/power[2]"
msgstr ""
"Has a built in short range teleporter that allows them to teleport anywhere "
"on the current ship."

#: src-en/data/blueprints.xml.append:705
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/desc"
msgstr ""
"A nightmare machine made by the Legion. Built out of a secret aether alloy "
"and fuled by pure liquid aether, this machine can spew flames that are hot "
"enough to melt solid aether chunks in seconds."

#: src-en/data/blueprints.xml.append:706
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/title"
msgstr "Legionnaire Pyrotechnic Battledrone"

#: src-en/data/blueprints.xml.append:707
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/short"
msgstr "Legion Battle."

#: src-en/data/blueprints.xml.append:712
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/powerList/power[1]"
msgstr "175 Max Health, 0.45x movement speed, immune to hazards."

#: src-en/data/blueprints.xml.append:713
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/powerList/power[2]"
msgstr "Attacks extremely fast in combat, but only deals 0.5x damage."

#: src-en/data/blueprints.xml.append:714
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/powerList/power[3]"
msgstr "Starts fires in the room after attacking for 5 seconds."

#: src-en/data/blueprints.xml.append:715
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/powerList/power[4]"
msgstr "Deals double damage to crew with exposed flesh."

#: src-en/data/blueprints.xml.append:716
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_legion_drone_battle\"]/powerList/power[5]"
msgstr ""
"Explodes on death, damaging any system and crew in the room and starting "
"fires."

#: src-en/data/blueprints.xml.append:721
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone\"]/desc"
msgstr ""
"A machination composed of pure souls and energy. It is very agile, but "
"equally fragile."

#: src-en/data/blueprints.xml.append:722
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone\"]/title"
msgstr "Ghostly Battledrone"

#: src-en/data/blueprints.xml.append:723
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone\"]/short"
msgstr "G. Battle."

#: src-en/data/blueprints.xml.append:728
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone\"]/powerList/power"
msgstr "50 Max Health, 3x movement speed, immune to hazards."

#: src-en/data/blueprints.xml.append:733
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone_2\"]/desc"
msgstr ""
"A machination composed of pure souls and energy. It is slow, but highly "
"durable and capable of delivering powerful strikes."

#: src-en/data/blueprints.xml.append:734
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone_2\"]/title"
msgstr "Ghostly Battledrone MK II"

#: src-en/data/blueprints.xml.append:735
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone_2\"]/short"
msgstr "G. Battle. II"

#: src-en/data/blueprints.xml.append:740
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone_2\"]/powerList/power[1]"
msgstr ""
"250 Max Health, 0.5x movement speed, immune to hazards. Deals 2x combat "
"damage."

#: src-en/data/blueprints.xml.append:741
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghostly_battledrone_2\"]/powerList/power[2]"
msgstr "Sabotages at half speed."

#: src-en/data/blueprints.xml.append:746
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_specter\"]/desc"
msgstr ""
"The wisp of a deceased soul brought back to existence through foul "
"necromancy. It is incapable of feeling anything."

#: src-en/data/blueprints.xml.append:747
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_specter\"]/title"
msgstr "Undead Specter"

#: src-en/data/blueprints.xml.append:748
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_specter\"]/short"
msgstr "Specter"

#: src-en/data/blueprints.xml.append:753
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_specter\"]/powerList/power[1]"
msgstr ""
"Immune to hazards and stuns. Cannot be cloned, healed or resurrected by any "
"means."

#: src-en/data/blueprints.xml.append:754
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_specter\"]/powerList/power[2]"
msgstr "Can phase through doors and moves at 1.5x speed."

#: src-en/data/blueprints.xml.append:759
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/desc"
msgstr "Brrr. Now with brains."

#: src-en/data/blueprints.xml.append:760
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/title"
msgstr "Smart Snowman"

#: src-en/data/blueprints.xml.append:761
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/short"
msgstr "S. Snowman"

#: src-en/data/blueprints.xml.append:766
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/powerList/power[1]"
msgstr "Heals at 1.5x speed. Clones at 0.7x speed."

#: src-en/data/blueprints.xml.append:767
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/powerList/power[2]"
msgstr "Takes 10x damage from fires."

#: src-en/data/blueprints.xml.append:768
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/powerList/power[3]"
msgstr "0.5x ranged and 1.5x melee damage. Attacks quickly in melee."

#: src-en/data/blueprints.xml.append:769
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/powerList/power[4]"
msgstr "Takes 0.7x damage from any crew weak to suffocation."

#: src-en/data/blueprints.xml.append:770
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_snowman_smart\"]/powerList/power[5]"
msgstr "Can't suffocate. Moves at 0.7x speed. Repairs at 1.3x speed."

#: src-en/data/blueprints.xml.append:775
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/desc"
msgstr ""
"The lesser-known cousins of Snowmen, Lavamen are actually quite friendly. "
"Unfortunately, the high temperature of their bodies renders their mere "
"existence hazardous."

#: src-en/data/blueprints.xml.append:776
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/title"
msgstr "Lavaman"

#: src-en/data/blueprints.xml.append:777
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/short"
msgstr "Lavaman"

#: src-en/data/blueprints.xml.append:782
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/powerList/power[1]"
msgstr "Heals at 0.7x speed. Clones at 1.5x speed."

#: src-en/data/blueprints.xml.append:783
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/powerList/power[2]"
msgstr "Takes 10x damage from suffocation."

#: src-en/data/blueprints.xml.append:784
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/powerList/power[3]"
msgstr "0.5x melee and 1.5x ranged damage. Attacks quickly in ranged."

#: src-en/data/blueprints.xml.append:785
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/powerList/power[4]"
msgstr "Deal 1.5x damage against any crew weak to fire."

#: src-en/data/blueprints.xml.append:786
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_lavaman\"]/powerList/power[5]"
msgstr "Immune to fire. Moves at 1.3x speed. Repairs at 0.7x speed."

#: src-en/data/blueprints.xml.append:791
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/desc"
msgstr ""
"The infamous Beam Master, and your long time nemesis. Now, with new-gen equipment!\n"
"\t\t\n"
"\tInherited Legionnaire stats: greatly resistant to suffocation and fire hazards, trained in lvl 2 skills"

#: src-en/data/blueprints.xml.append:795
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/title"
msgstr "Beam Legionnaire"

#: src-en/data/blueprints.xml.append:796
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/short"
msgstr "Beam Legion"

#: src-en/data/blueprints.xml.append:799
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/powerList/power[1]"
msgstr "Might be an actual threat now."

#: src-en/data/blueprints.xml.append:800
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/powerList/power[2]"
msgstr "Moves by teleporting and can teleport to the enemy ship directly."

#: src-en/data/blueprints.xml.append:801
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/powerList/power[3]"
msgstr "Advanced blasters gives her 2x ranged damage."

#: src-en/data/blueprints.xml.append:802
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_unique_leah_legion\"]/powerList/power[4]"
msgstr "Lack of very protective armor makes her take 1.2x damage."

#: src-en/data/blueprints.xml.append:807
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/desc"
msgstr ""
"Minions of the One Who Rhymes. A weaker thing and with fading eldritch "
"power, the presence of multiple of these beings cannot be sustained without "
"heavy tolls."

#: src-en/data/blueprints.xml.append:808
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/title"
msgstr "Lesser Thing"

#: src-en/data/blueprints.xml.append:809
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/short"
msgstr "Thing"

#: src-en/data/blueprints.xml.append:813
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/powerList/power[1]"
msgstr "125 Health, halved movement speed, deals 1.25x damage"

#: src-en/data/blueprints.xml.append:814
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/powerList/power[2]"
msgstr ""
"If a Thing dies while not burning, stunned, or mind controlled, it will "
"split into two new Things"

#: src-en/data/blueprints.xml.append:815
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"eldritch_thing_weak_noclone\"]/powerList/power[3]"
msgstr ""
"For each Lesser Thing on screen, they will all lose 10% repair speed and "
"combat damage"

#: src-en/data/blueprints.xml.append:823
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/desc"
msgstr ""
"A brilliant Obelisk Royal who lost her sanity trying to reanimate her deceased friend.\n"
"\t\n"
"\tInherited Specter stats: has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Obelisk Royal stats: 0.75x speed, Max Health is increased to 300, 2x combat damage, repairs and puts out fires at 0.05x speed, is affected by Obelisk lab upgrades."

#: src-en/data/blueprints.xml.append:828
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/title"
msgstr "Necrolich Royal"

#: src-en/data/blueprints.xml.append:829
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/short"
msgstr "Necrolich"

#: src-en/data/blueprints.xml.append:834
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/powerList/power[1]"
msgstr ""
"Active Ability: Becomes completely damage resistant but loses 80% of crew "
"damage."

#: src-en/data/blueprints.xml.append:835
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/powerList/power[2]"
msgstr "Heals slightly instead of taking damage from hazards."

#: src-en/data/blueprints.xml.append:836
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/powerList/power[3]"
msgstr ""
"Prevents all enemy revenants from fighting while in the same room as her. "
"Friendly revenants will repair at twice the speed while in the same room as "
"her."

#: src-en/data/blueprints.xml.append:837
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_g\"]/powerList/power[4]"
msgstr "Can't sabotage."

#: src-en/data/blueprints.xml.append:842
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/desc"
msgstr ""
"One of the most loyal Bishops ever appointed, this fearsome warrior died while protecting the eggs under her care from a fire. Surprisingly reasonable, considering the reputation Mantis have.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from suffocation, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Mantis Bishop stats: 2.2x combat damage, 0.07x repair speed, is affected by Mantis lab upgrades."

#: src-en/data/blueprints.xml.append:847
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/title"
msgstr "Revenant Bishop"

#: src-en/data/blueprints.xml.append:848
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/short"
msgstr "Rev. Bishop"

#: src-en/data/blueprints.xml.append:853
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/powerList/power[1]"
msgstr ""
"Active Ability: Enters a berserk mode that damages all enemy crew and the "
"current system."

#: src-en/data/blueprints.xml.append:854
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/powerList/power[2]"
msgstr ""
"125 Health, takes 10x more damage from fire. Can't phase through doors "
"without help from her pheromones."

#: src-en/data/blueprints.xml.append:855
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_aleenor\"]/powerList/power[3]"
msgstr ""
"Enemy crew in the same room as her lose their suffocation immunity, take "
"double suffocation damage, and experience a heavy reduction to key stats."

#: src-en/data/blueprints.xml.append:860
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/desc"
msgstr ""
"A Shell born from a disastrous genetic experiment that infused her with massive amounts of ion energy. Her existence is nothing but suffering.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Shell Guardian stat: 0.7x damage taken in crew combat, is affected by Shell lab upgrades."

#: src-en/data/blueprints.xml.append:865
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/title"
msgstr "Revenant Guardian"

#: src-en/data/blueprints.xml.append:866
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/short"
msgstr "Rev. Guardian"

#: src-en/data/blueprints.xml.append:871
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/powerList/power[1]"
msgstr ""
"Active Ability: deals 5 ion damage to systems in the room she stands in and "
"fully repairs them. This will also stun everyone else in the room."

#: src-en/data/blueprints.xml.append:872
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/powerList/power[2]"
msgstr "150 Health, moves at 2x speed. Can't be stunned."

#: src-en/data/blueprints.xml.append:873
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/powerList/power[3]"
msgstr "Can't repair systems normally."

#: src-en/data/blueprints.xml.append:874
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_phys\"]/powerList/power[4]"
msgstr "Provides 3 power to the current system."

#: src-en/data/blueprints.xml.append:879
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/desc"
msgstr ""
"An ex-MFK Ace who was tortured to death by his own ally. This event left him incredibly bitter towards all living things; he now solely relies on and trusts drones.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Human MFK stats: deals 2x damage in combat, starts at level 2 skills, is affected by Human lab upgrades."

#: src-en/data/blueprints.xml.append:884
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/title"
msgstr "Revenant MFK"

#: src-en/data/blueprints.xml.append:885
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/short"
msgstr "Rev. MFK"

#: src-en/data/blueprints.xml.append:890
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/powerList/power[1]"
msgstr ""
"Active Ability: Repairs all drones in the same room as him, healing them for"
" 10 hp/s for 10 seconds."

#: src-en/data/blueprints.xml.append:891
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/powerList/power[2]"
msgstr ""
"150 Health, 2x sabotage speed, takes 0.5x damage in combat. Moves at 1.5x "
"speed."

#: src-en/data/blueprints.xml.append:892
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/powerList/power[3]"
msgstr "Doesn't lose skills when cloned. Immune to Mind control."

#: src-en/data/blueprints.xml.append:893
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_cleo\"]/powerList/power[4]"
msgstr "Takes 2.2x damage from drones and deals 0.25x damage to them."

#: src-en/data/blueprints.xml.append:898
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/desc"
msgstr ""
"An ancient Slug king whose insatiable appetite eventually led to a fatal case of food poisoning caused by a nasty batch of hallucinogenic melons.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Slug Saboteur stats: telepathic powers, mind control immunity, is affected by Slug lab upgrades."

#: src-en/data/blueprints.xml.append:903
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/title"
msgstr "Revenant Saboteur"

#: src-en/data/blueprints.xml.append:904
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/short"
msgstr "Rev. Saboteur"

#: src-en/data/blueprints.xml.append:909
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/powerList/power[1]"
msgstr ""
"Active Ability: Eats a piece of enemy crew in the room, healing himself in "
"the process."

#: src-en/data/blueprints.xml.append:910
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/powerList/power[2]"
msgstr ""
"Active Ability: Eats part of the ship to fully heal himself, dealing 1 hull "
"damage, breaching the ship and fully destroying the system. Can't be used "
"inside the enemy ship."

#: src-en/data/blueprints.xml.append:911
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/powerList/power[3]"
msgstr "200 Health, can't heal through normal means."

#: src-en/data/blueprints.xml.append:912
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_slimer\"]/powerList/power[4]"
msgstr ""
"Moves at 0.25x speed while in the enemy ship. Deals 0.5x combat damage."

#: src-en/data/blueprints.xml.append:917
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/desc"
msgstr ""
"A brutish Rockman Paladin from the distant past who met an ironic demise, melting alive as his ship plummeted into a star. He now serves as G's chief enforcer.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Rock Paladin stats: heals at double speed, movement speed is massively reduced, immune to stun, is affected by Rock lab upgrades."

#: src-en/data/blueprints.xml.append:922
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/title"
msgstr "Revenant Paladin"

#: src-en/data/blueprints.xml.append:923
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/short"
msgstr "Rev. Paladin"

#: src-en/data/blueprints.xml.append:928
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/powerList/power[1]"
msgstr "Active Ability: Lights a fire in the current room."

#: src-en/data/blueprints.xml.append:929
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/powerList/power[2]"
msgstr "350 Health, can't sabotage."

#: src-en/data/blueprints.xml.append:930
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/powerList/power[3]"
msgstr "Cannot put out fires, but repairs at 1.5x speed."

#: src-en/data/blueprints.xml.append:931
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_vin\"]/powerList/power[4]"
msgstr ""
"Enemies in the same room as Vin will lose their fire resistance and take 2x "
"fire damage."

#: src-en/data/blueprints.xml.append:936
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/desc"
msgstr ""
"The fanatical right-hand man of the Necrolich G, and technically the cause of everything Tartarus-related.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Lanius Welder stats: is affected by Lanius lab upgrades."

#: src-en/data/blueprints.xml.append:941
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/title"
msgstr "Revenant Welder"

#: src-en/data/blueprints.xml.append:942
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/short"
msgstr "Rev. Welder"

#: src-en/data/blueprints.xml.append:947
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/powerList/power[1]"
msgstr ""
"Active Ability: Temporarily moves extremely slowly and has lower crew and "
"sabotage damage, but instantly drains oxygen and regenerates the health of "
"nearby friendly crew."

#: src-en/data/blueprints.xml.append:948
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/powerList/power[2]"
msgstr "150 Health, 4x sabotage speed"

#: src-en/data/blueprints.xml.append:949
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/powerList/power[3]"
msgstr ""
"Enemy metalloid crew and drones in the same room excluding other Lanius will"
" have their movement speed slowed down by 50% and are unable to repair or "
"heal."

#: src-en/data/blueprints.xml.append:950
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reborn_zulu\"]/powerList/power[4]"
msgstr ""
"Attacks extremely fast in ranged combat, but only deals 0.3x ranged damage."

#: src-en/data/blueprints.xml.append:957
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/desc"
msgstr ""
"A once-famed Sentinel, this poor Crystal experienced first-hand how maddening whispers in the back of his head can be.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Crystal Sentinel stats: Max Health is increased to 135, movement speed reduced to 0.65x, is affected by Crystal lab upgrades."

#: src-en/data/blueprints.xml.append:962
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/title"
msgstr "Revenant Sentinel"

#: src-en/data/blueprints.xml.append:963
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/short"
msgstr "Rev. Sentinel"

#: src-en/data/blueprints.xml.append:968
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/powerList/power[1]"
msgstr ""
"Active Ability: Locks down the room, taking 35 damage and freezing all non-"
"ice crew in the room for 5 seconds, preventing them from acting but making "
"them take 50% less damage for the duration. Lockdown lasts for twice as long"
" as the normal amount and the shards have twice the hp."

#: src-en/data/blueprints.xml.append:969
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/powerList/power[2]"
msgstr "Deals 2x ranged damage."

#: src-en/data/blueprints.xml.append:970
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_frostwall\"]/powerList/power[3]"
msgstr ""
"Enemies in the same room as Frostwall lose their door phasing properties and"
" their movement speed is slowed by 25%."

#: src-en/data/blueprints.xml.append:975
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/desc"
msgstr ""
"A treasure hunter renowned through the universe, whose last discovery caused her downfall.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Vampweed Cultivator stats: enemies heal 25% slower in the same room, produces oxygen very slowly, is affected by Orchid lab upgrades."

#: src-en/data/blueprints.xml.append:980
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/title"
msgstr "Revenant Cultivator"

#: src-en/data/blueprints.xml.append:981
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/short"
msgstr "Rev. Cultivator"

#: src-en/data/blueprints.xml.append:986
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/powerList/power[1]"
msgstr ""
"Active Ability: Infests the current room with deadly spores, draining "
"enemy's health for 10hp/s."

#: src-en/data/blueprints.xml.append:987
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/powerList/power[2]"
msgstr "Max Health is increased to 125."

#: src-en/data/blueprints.xml.append:988
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_deathbloom\"]/powerList/power[3]"
msgstr ""
"Each enemy crew that dies in the same room as deathbloom will give her a 20 "
"extra max health and 20% extra flat damage for the current beacon."

#: src-en/data/blueprints.xml.append:993
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_pok\"]/desc"
msgstr ""
"An amalgamation of chaos energy and pure determination, this little Morph can perfectly copy the appearance of anyone just by looking at a photo of them.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Morph stats: is affected by Morph lab upgrades."

#: src-en/data/blueprints.xml.append:998
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_pok\"]/title"
msgstr "Revenant Morph"

#: src-en/data/blueprints.xml.append:999
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_pok\"]/short"
msgstr "Rev. Morph"

#: src-en/data/blueprints.xml.append:1004
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_pok\"]/powerList/power[1]"
msgstr ""
"Active Ability: Transforms into a version of a unique crew with all of their"
" abilities plus hazard immunity and door phasing properties."

#: src-en/data/blueprints.xml.append:1005
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_pok\"]/powerList/power[2]"
msgstr ""
"You can see which unique will be next by hovering over the \"MORPH\" power."

#: src-en/data/blueprints.xml.append:1010
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/desc"
msgstr ""
"An Engi, corrupted by a virus of unknown origin and an attempt to fuse with an actual soul. They now wander the Multiverse, seeking purpose for their existence.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Engi Defender stats: 0.35x combat damage, 2.7x repair speed, is affected by Engi lab upgrades."

#: src-en/data/blueprints.xml.append:1015
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/title"
msgstr "Revenant Defender"

#: src-en/data/blueprints.xml.append:1016
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/short"
msgstr "Rev. Defender"

#: src-en/data/blueprints.xml.append:1021
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/powerList/power[1]"
msgstr ""
"Active Ability: Corrupts nearby robotic crew and drones, disabling their AI,"
" making them uncontrollable, and preventing them from fighting, repairing or"
" sabotaging. Also halves Charror's damage taken for the duration."

#: src-en/data/blueprints.xml.append:1022
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/powerList/power[2]"
msgstr ""
"Sabotages mannable systems at 5x speed. Sabotages other systems at 0.2x "
"speed."

#: src-en/data/blueprints.xml.append:1023
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_charror\"]/powerList/power[3]"
msgstr "Is stunned for 3x longer."

#: src-en/data/blueprints.xml.append:1028
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/desc"
msgstr ""
"One of the most well-disciplined Amperes that the Eargen Republic had to offer. After being puppeteered by a much greater force, he now only wishes to have a peaceful afterlife.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Leech Ampere stats: Stunned for 1.75x the usual duration, is affected by Leech lab upgrades."

#: src-en/data/blueprints.xml.append:1033
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/title"
msgstr "Revenant Ampere"

#: src-en/data/blueprints.xml.append:1034
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/short"
msgstr "Rev. Ampere"

#: src-en/data/blueprints.xml.append:1039
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/powerList/power[1]"
msgstr ""
"Active Ability: Hacks the doors of the enemy system room they are in for 10 "
"seconds. During that time, Leo gains 5x sabotage damage, damages enemies in "
"the same room for 1.5 hp/s and becomes invisible at the cost of taking "
"triple damage from all sources and being unable to fight or move."

#: src-en/data/blueprints.xml.append:1040
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/powerList/power[2]"
msgstr ""
"Fully drains power while in the same room as non-essential enemy systems. "
"Drains 2 power out of essential systems."

#: src-en/data/blueprints.xml.append:1041
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_leo\"]/powerList/power[3]"
msgstr "Constantly regenerates 5 hp/s. Deals 0.4x damage in combat."

#: src-en/data/blueprints.xml.append:1046
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_searak\"]/desc"
msgstr ""
"One of the oldest Duskbringers, driven mad by a sabotaged clone bay. Now, he searches only for redemption and peace.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Duskbringer Martyr stats: 15 crew damage on death, short-range teleportation, is affected by Zoltan lab upgrades."

#: src-en/data/blueprints.xml.append:1051
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_searak\"]/title"
msgstr "Revenant Martyr"

#: src-en/data/blueprints.xml.append:1052
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_searak\"]/short"
msgstr "Rev. Martyr"

#: src-en/data/blueprints.xml.append:1057
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_searak\"]/powerList/power[1]"
msgstr ""
"Active Ability: Detonation ability that deals 25 self damage, 150 enemy crew"
" damage, starts a fire, and deals 2 system damage to the current room. After"
" the explosion triggers, Searak will be unable to act for 15 seconds."

#: src-en/data/blueprints.xml.append:1058
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_reformed_searak\"]/powerList/power[2]"
msgstr ""
"Fully powers non essential systems. Provides 2 power to essential systems."

#: src-en/data/blueprints.xml.append:1059
msgid ""
