#: src-en/data/blueprints.xml.append:1607
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/desc"
msgstr ""
"The richest Phantom to ever live. Blessed by an unnatural power that makes them stronger as their pockets fill.\n"
"\t\n"
"\tInherited Specter stats: is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Phantom stats: takes no damage from hazards, 0.8x speed, has door phasing properties, is affected by Vagabond lab upgrades"

#: src-en/data/blueprints.xml.append:1612
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/title"
msgstr "Umbral Alpha Phantom"

#: src-en/data/blueprints.xml.append:1613
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/short"
msgstr "U. A. Phantom"

#: src-en/data/blueprints.xml.append:1618
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[1]"
msgstr ""
"Active Ability: Spend 10 scrap to fully heal the crew. This ability will "
"always trigger when the crew reaches 10 health."

#: src-en/data/blueprints.xml.append:1619
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[2]"
msgstr "Max Health is reduced to 50."

#: src-en/data/blueprints.xml.append:1620
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[3]"
msgstr "Inflicts 0.5x damage in crew combat and sabotages at 0.5x speed."

#: src-en/data/blueprints.xml.append:1621
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[4]"
msgstr "Gains +0.1x crew damage per 10 scrap you have on your cargo."

#: src-en/data/blueprints.xml.append:1622
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[5]"
msgstr "Gains +0.1x sabotage speed per 10 scrap you have on your cargo."

#: src-en/data/blueprints.xml.append:1623
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus\"]/powerList/power[6]"
msgstr "Gains +1 Max Health per 2 scrap you have on your cargo."

#: src-en/data/blueprints.xml.append:1628
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/desc"
msgstr ""
"A pale imitation of the richest Phantom to ever live. Blessed by an unnatural power that makes them stronger as their pockets fill.\n"
"\t\n"
"\tInherited Specter stats: is affected by Specter lab upgrades.\n"
"\t\n"
"\tInherited Phantom stats: takes no damage from hazards, 0.8x speed, has door phasing properties, is affected by Vagabond lab upgrades"

#: src-en/data/blueprints.xml.append:1633
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/title"
msgstr "Umbral Alpha Phantom"

#: src-en/data/blueprints.xml.append:1634
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/short"
msgstr "U. A. Phantom"

#: src-en/data/blueprints.xml.append:1639
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[1]"
msgstr ""
"Active Ability: Kills all allies in the same room to fully heal themselves. "
"This ability will always trigger when the crew reaches 10 health."

#: src-en/data/blueprints.xml.append:1640
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[2]"
msgstr "Max Health is reduced to 50."

#: src-en/data/blueprints.xml.append:1641
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[3]"
msgstr "Inflicts 0.5x damage in crew combat and sabotages at 0.5x speed."

#: src-en/data/blueprints.xml.append:1642
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[4]"
msgstr "Gains +0.1x crew damage per 10 scrap you have at the moment."

#: src-en/data/blueprints.xml.append:1643
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[5]"
msgstr "Gains +0.1x sabotage speed per 10 scrap you have at the moment."

#: src-en/data/blueprints.xml.append:1644
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_augustus_enemy\"]/powerList/power[6]"
msgstr "Gains +1 Max Health per 2 scrap you have at the moment."

#: src-en/data/blueprints.xml.append:1649
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/desc"
msgstr ""
"The outcome of a desperate experiment, this fusion of an unknown lifeform and a spider is surprisingly self-aware.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\n"
"\tInherited Hatchling Spider stats: 50 health, 0.10x repairs, is affected by Spider lab upgrades."

#: src-en/data/blueprints.xml.append:1654
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/title"
msgstr "Umbral Hatchling Spider"

#: src-en/data/blueprints.xml.append:1655
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/short"
msgstr "U. Hatchling"

#: src-en/data/blueprints.xml.append:1660
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/powerList/power[1]"
msgstr ""
"Active Ability: Fully heals this crew and reform to its previous form "
"(Adult)."

#: src-en/data/blueprints.xml.append:1661
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/powerList/power[2]"
msgstr "2.5x combat damage, 0.5x sabotage damage,  3x movement speed."

#: src-en/data/blueprints.xml.append:1662
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_hatchling\"]/powerList/power[3]"
msgstr "Cannot heal through normal means, clones at half speed."

#: src-en/data/blueprints.xml.append:1667
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/desc"
msgstr ""
"Apparently the outcome of a desperate experiment, this fusion of an unknown lifeform and a spider is surprisingly self-aware.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\n"
"\tInherited Adult Spider stats: 85 health, is affected by Spider lab upgrades."

#: src-en/data/blueprints.xml.append:1672
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/title"
msgstr "Umbral Adult Spider"

#: src-en/data/blueprints.xml.append:1673
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/short"
msgstr "U. Adult"

#: src-en/data/blueprints.xml.append:1678
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/powerList/power[1]"
msgstr ""
"Active Ability: Fully heals this crew and reform to its previous form "
"(Weaver)."

#: src-en/data/blueprints.xml.append:1679
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/powerList/power[2]"
msgstr ""
"2x combat damage, 1x sabotage damage, 1x repair speed, 1.5 movement speed."

#: src-en/data/blueprints.xml.append:1680
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/powerList/power[3]"
msgstr "Cannot heal through normal means, knows all skills at level 1."

#: src-en/data/blueprints.xml.append:1681
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_adult\"]/powerList/power[4]"
msgstr ""
"Cannot be cloned, instead on death this crew will spawn a smaller version of"
" this crew (Hatchling)."

#: src-en/data/blueprints.xml.append:1686
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/desc"
msgstr ""
"The outcome of a desperate experiment, this fusion of an unknown lifeform and a spider is surprisingly self-aware.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\n"
"\tInherited Weaver Spider stats: 95 health, 0.8x movement speed, is affected by Spider lab upgrades."

#: src-en/data/blueprints.xml.append:1691
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/title"
msgstr "Umbral Weaver Spider"

#: src-en/data/blueprints.xml.append:1692
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/short"
msgstr "U. Weaver"

#: src-en/data/blueprints.xml.append:1697
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/powerList/power[1]"
msgstr ""
"Active Ability: Fully heals this crew and empowers all other friendly "
"spiders by giving them a 2x damage boost for 10 seconds."

#: src-en/data/blueprints.xml.append:1698
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/powerList/power[2]"
msgstr "1.5x combat damage, 1.5x sabotage damage, 2.5x repair speed."

#: src-en/data/blueprints.xml.append:1699
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/powerList/power[3]"
msgstr "Cannot heal through normal means, knows all skills at level 2."

#: src-en/data/blueprints.xml.append:1700
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_sally_weaver\"]/powerList/power[4]"
msgstr ""
"Cannot be cloned, instead on death this crew will spawn a smaller version of"
" this crew (Adult)."

#: src-en/data/blueprints.xml.append:1705
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/desc"
msgstr ""
"A enigmatic demonic Equinoid, summoned from the depths of Tartarus. This creature might appear to be mindless, but they know much more about the universe than they let on.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\n"
"\tInherited Tamed Equinoid stats: Can be controlled, 0.3x repair speed."

#: src-en/data/blueprints.xml.append:1710
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/title"
msgstr "Umbral Shadow Equinoid"

#: src-en/data/blueprints.xml.append:1711
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/short"
msgstr "U. Equinoid"

#: src-en/data/blueprints.xml.append:1716
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/powerList/power[1]"
msgstr ""
"Active Ability: Cloaks the room in darkness, nullifying all enemy crew "
"ranged damage and setting their repair and sabotage speed to 0.25x."

#: src-en/data/blueprints.xml.append:1717
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/powerList/power[2]"
msgstr "0.4x combat damage, 0.4x sabotage damage, 8x movement speed."

#: src-en/data/blueprints.xml.append:1718
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince\"]/powerList/power[3]"
msgstr ""
"Puts out fires instantly, Can't be detected in rooms without enemy drones."

#: src-en/data/blueprints.xml.append:1723
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/desc"
msgstr ""
"A enigmatic demonic Equinoid, summoned from the depths of Tartarus. This creature might appear to be mindless, but they know much more about the universe than they let on.\n"
"\t\n"
"\tInherited Specter stats: takes no damage from hazards, has door phasing properties, is affected by Specter lab upgrades.\n"
"\n"
"\tInherited Tamed Equinoid stats: Can be controlled, 0.3x repair speed."

#: src-en/data/blueprints.xml.append:1728
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/title"
msgstr "Unnatural Shadow Equinoid"

#: src-en/data/blueprints.xml.append:1729
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/short"
msgstr "Unn. Equinoid"

#: src-en/data/blueprints.xml.append:1734
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/powerList/power[1]"
msgstr ""
"Active Ability: Cloaks the room in darkness, nullifying all enemy crew "
"ranged damage and setting their repair and sabotage speed to 0.25x. Becomes "
"untargetable while in the room."

#: src-en/data/blueprints.xml.append:1735
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/powerList/power[2]"
msgstr "0.4x combat damage, 0.4x sabotage damage, 8x movement speed."

#: src-en/data/blueprints.xml.append:1736
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_enemy\"]/powerList/power[3]"
msgstr "Puts out fires instantly."

#: src-en/data/blueprints.xml.append:1741
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/desc"
msgstr ""
"A demon spawned from the depts of literal hell. Fragile but highly "
"destructive."

#: src-en/data/blueprints.xml.append:1742
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/title"
msgstr "Demonic Spawn"

#: src-en/data/blueprints.xml.append:1743
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/short"
msgstr "Spawn"

#: src-en/data/blueprints.xml.append:1748
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/powerList/power[1]"
msgstr "50 Max Health, immune to hazards. Can't be mind controlled."

#: src-en/data/blueprints.xml.append:1749
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/powerList/power[2]"
msgstr ""
"2x ranged damage. Can't fight in melee combat, man systems, repair or "
"extinguish."

#: src-en/data/blueprints.xml.append:1750
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_demon_skull\"]/powerList/power[3]"
msgstr "Uses 1/4 of a crew slot. Moves at 2x speed."

#: src-en/data/blueprints.xml.append:1755
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_jerry\"]/desc"
msgstr ""
"Jerry has been consumed by grief. Now he has a really large gun AND a DEMONIC HORSE.\n"
"\t\n"
"\tInherited Umbral Shadow Equinoid stats: takes no damage from hazards, has door phasing properties, puts out fires instantly, can't be detected in rooms without enemy drones, 8x movement speed.\n"
"\n"
"\tInherited Pony Jerry stats: 300 Max Health, learns skills faster, 2x damage, 3x heal speed, 0.5x damage taken, shoots extremely quickly, sabotages at 5x speed, has his death effect."

#: src-en/data/blueprints.xml.append:1760
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_jerry\"]/title"
msgstr "Shadow Mounted Human"

#: src-en/data/blueprints.xml.append:1761
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_jerry\"]/short"
msgstr "Sh. Human"

#: src-en/data/blueprints.xml.append:1766
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_bonus_prince_jerry\"]/powerList/power"
msgstr ""
"Active Ability: Cloaks the room in darkness, setting all enemy crew repair "
