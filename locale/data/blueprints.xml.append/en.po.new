msgstr ""
"[Base cooldown: 50] Opens a rift that combines all the powers of the "
"alliance. Inflicts standard erosion, mind controls crew hit for 10 seconds, "
"breaches and locks down the room and spawns a specter."

#: src-en/data/blueprints.xml.append:14504
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL_B\"]/tooltip"
msgstr ""
"Bomb artillery, sends 1 bomb; Inflicts standard erosion, mind controls crew "
"hit for 10 seconds, breaches and locks down the room and spawns a specter."

#: src-en/data/blueprints.xml.append:14587
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL_C\"]/title"
msgstr "Royal Cursed Artillery"

#: src-en/data/blueprints.xml.append:14588
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL_C\"]/short"
msgstr "R. Cursed Art."

#: src-en/data/blueprints.xml.append:14589
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL_C\"]/desc"
msgstr ""
"[Base cooldown: 50] Opens a single, powerful rift from Liythkyk Yuk, the "
"Obelisk capital. it spawns an Obelisk noble that will fight for you for 20 "
"seconds. Can't miss."

#: src-en/data/blueprints.xml.append:14590
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL_C\"]/tooltip"
msgstr ""
"Bomb artillery, spawns an Obelisk noble that will fight for you for 20 "
"seconds. Can't miss."

#: src-en/data/blueprints.xml.append:14642
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX\"]/title"
msgstr "Vortex Radiation Laser Artillery"

#: src-en/data/blueprints.xml.append:14643
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX\"]/short"
msgstr "Vort. Rad. Art."

#: src-en/data/blueprints.xml.append:14644
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX\"]/desc"
msgstr ""
"[Base cooldown: 48] Fires a burst of 4 lasers. Each laser pierces all "
"shielding, inflicts massive system and crew damage, and inflicts crew with "
"radiation poisoning that blocks healing, cloning, and teleportation."

#: src-en/data/blueprints.xml.append:14645
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX\"]/tooltip"
msgstr ""
"4 shot laser weapon, 4 system damage, 45 crew damage with full shield "
"pierce, moderate breach but no hull damage. Crew hit by the laser can't be "
"cloned, healed or teleport."

#: src-en/data/blueprints.xml.append:14709
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HOLOGRAM\"]/title"
msgstr "Vortex Hologram Artillery"

#: src-en/data/blueprints.xml.append:14710
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HOLOGRAM\"]/short"
msgstr "Vort. Hol. Art."

#: src-en/data/blueprints.xml.append:14712
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HOLOGRAM\"]/desc"
msgstr ""
"[Base cooldown: 40] Opens 3 rifts in the enemy's ship, summoning "
"uncontrollable Osmian Holograms that fight for 10 seconds before vanishing."

#: src-en/data/blueprints.xml.append:14713
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HOLOGRAM\"]/tooltip"
msgstr ""
"Bomb artillery, sends 3 bombs that deal 2 ion damage and summons an Osmian "
"hologram that can't be controlled to fight for you."

#: src-en/data/blueprints.xml.append:14773
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HEAL\"]/title"
msgstr "Vortex Heal Beam Artillery"

#: src-en/data/blueprints.xml.append:14774
