#: src-en/data/blueprints.xml.append:14285
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_REVENANT_CLEO_B\"]/title"
msgstr "Cleo's Combat Drone Artillery"

#: src-en/data/blueprints.xml.append:14286
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_REVENANT_CLEO_B\"]/short"
msgstr "Cleo D. Art."

#: src-en/data/blueprints.xml.append:14287
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_REVENANT_CLEO_B\"]/desc"
msgstr ""
"[Base cooldown: 40] This one of a kind artillery can deploy 2 temporary Auto"
