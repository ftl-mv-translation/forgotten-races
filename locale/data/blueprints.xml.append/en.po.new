#: src-en/data/blueprints.xml.append:6403
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_DEATHBLOOM_SPORE_BOMBLAUNCHER\"]/title"
msgstr "Deathboom's Charge Spore Launcher"

#: src-en/data/blueprints.xml.append:6404
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_DEATHBLOOM_SPORE_BOMBLAUNCHER\"]/short"
msgstr "Charge Spore"

#: src-en/data/blueprints.xml.append:6405
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_DEATHBLOOM_SPORE_BOMBLAUNCHER\"]/desc"
msgstr ""
"A strange variant of the vampweed spore launchers, one which somehow charges"
" shots instead of releasing them all in one go. Being Deathbloom's signature"
" weapon also means carrying her deadly spores, which infect crew hit, "
"causing them to damage allies for a stacking 2.5 hp/s that lasts for 10 "
"seconds."

