"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VISION\"]/short"
msgstr "'Cthulhu'"

#: src-en/data/blueprints.xml.append:14839
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VISION\"]/desc"
msgstr ""
"[Base cooldown: 23] Fires a burst of 5 mines, each of which inflicts "
"Absolute Madness on the target, disabling all actions and powers of the "
