#: src-en/data/blueprints.xml.append:7445
msgid ""
"data/blueprints.xml.append$//droneBlueprint[@name=\"FR_COMBAT_SALLY_BOMB\"]/desc"
msgstr ""
"A specialized drone that can deals no actual damage and instead fires bombs "
"that spawns 2 spider hatchlings that live for 20 seconds. Avoids all anti "
"drone measures."

