"controlled or stunned, and are immune to hazards."

#: src-en/data/blueprints.xml.append:18700
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_ENGINES_DODGE\"]/title"
msgstr "Engine Efficacy"

#: src-en/data/blueprints.xml.append:18701
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_ENGINES_DODGE\"]/desc"
msgstr "Gives +5 evasion while your engines are powered."

#: src-en/data/blueprints.xml.append:18709
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_ENGINES_JUMP\"]/title"
