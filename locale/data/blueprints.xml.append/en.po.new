msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_PRIME_PINK\"]/desc"
msgstr ""
"[Base cooldown: 25] Fires a highly destructive Pinpoint beam. It starts at 1"
