#: src-en/data/blueprints.xml.append:19032
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_BATTERY_SHIELD\"]/title"
msgstr "Shield Energizer Upgrade"

#: src-en/data/blueprints.xml.append:19033
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_BATTERY_SHIELD\"]/desc"
