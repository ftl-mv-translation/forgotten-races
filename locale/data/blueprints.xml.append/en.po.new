#: src-en/data/blueprints.xml.append:19087
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_BEAM_OVERCLOCKER\"]/desc"
msgstr ""
"A powerful piece of technology that bolsters the power of your beam and pinpoint weapons and artilleries. \n"
"\t\t\n"
"\tThey deal 1 extra damage of all of the types they normally deal, with crew damage being raised by 15 instead. \n"
