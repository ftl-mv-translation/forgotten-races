#: src-en/data/blueprints.xml.append:1519
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghost_metyunt\"]/powerList/power[1]"
msgstr ""
"Active Ability: Transforms into a version of a unique crew with all of their"
" abilities plus hazard immunity and door phasing properties."

#: src-en/data/blueprints.xml.append:1520
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghost_metyunt\"]/powerList/power[2]"
msgstr ""
"Active Ability: Temporarily doubles their repair and sabotage speed, but "
"lowers Max Health. Nearby allies also gain the effects."

#: src-en/data/blueprints.xml.append:1521
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghost_metyunt\"]/powerList/power[3]"
msgstr "Max Health is increased to 135."

#: src-en/data/blueprints.xml.append:1522
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghost_metyunt\"]/powerList/power[4]"
msgstr ""
"Passively provides a 50% fire resistance to all other allied crew in the "
"same room."

#: src-en/data/blueprints.xml.append:1523
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"fr_ghost_metyunt\"]/powerList/power[5]"
msgstr "Moves at 1.5x speed."

