#: src-en/data/blueprints.xml.append:19014
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_TEMPORAL_GLOBAL\"]/title"
msgstr "Ship-Wide Temporal Distortion Upgrade"

#: src-en/data/blueprints.xml.append:19015
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_NEXUS_TEMPORAL_GLOBAL\"]/desc"
