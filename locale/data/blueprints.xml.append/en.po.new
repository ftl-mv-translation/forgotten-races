"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL\"]/short"
msgstr "T. Portal Art."

#: src-en/data/blueprints.xml.append:14428
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_NECROMANTIC_PORTAL\"]/desc"
msgstr ""
"[Base cooldown: 40] Opens 2 rifts between Tartarus and the target. Each rift"
" spawns a temporary specter crew."

