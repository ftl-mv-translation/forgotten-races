#: src-en/data/blueprints.xml.append:14967
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_PRIME_PINK\"]/title"
msgstr "Elite Arbiter Artillery"

#: src-en/data/blueprints.xml.append:14968
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_PRIME_PINK\"]/short"
