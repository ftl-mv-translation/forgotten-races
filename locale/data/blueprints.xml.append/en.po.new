#: src-en/data/blueprints.xml.append:14775
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HEAL\"]/desc"
msgstr ""
"[Base cooldown: 40] A strange beam which pierces all shields and inflicts 5 "
"ion damage, but repairs 2 hull per room passed and heals struck crew for 3 "
"hp/s for 15 seconds."

#: src-en/data/blueprints.xml.append:14776
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HEAL\"]/tooltip"
msgstr ""
"Beam weapon: repairs 2 hull, heals crew for 3 hp/s for 15 seconds, pierces "
"all shields, deals 5 ion damage"

#: src-en/data/blueprints.xml.append:14777
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VORTEX_HEAL\"]/descriptionOverride"
msgstr ""
"[Base cooldown: 40] A strange beam which pierces all shields and inflicts 5 ion damage, but repairs 2 hull per room passed and heals struck crew for 3 hp/s for 15 seconds.\n"
"\n"
"\t\tStats:\n"
"\t\tRequired Power: 1\n"
"\t\tCharge Time: 40 seconds\n"
"\n"
"\t\tBeam Length: 105\n"
"\t\tBeam Speed: 25\n"
"\t\t\n"
"\t\tHull Repair: 2\n"
"\t\tTotal Crew Healing: 30\n"
"\t\tIon Damage: 5\n"
"\t\tShield Piercing: 10\n"
"\n"
"\t\tHeals crew hit for: 3 hp/s for 15 seconds\n"
"\n"
"\t\tDefault Price: 70~   -   Selling Price: 35~"

#: src-en/data/blueprints.xml.append:14837
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_VISION\"]/title"
