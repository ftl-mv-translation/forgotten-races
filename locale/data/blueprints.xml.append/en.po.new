msgstr "Golden Onslaught Launcher"

#: src-en/data/blueprints.xml.append:8302
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_GOLDEN_ANCIENT_MINELAUNCHER\"]/short"
