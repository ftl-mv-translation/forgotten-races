#: src-en/data/blueprints.xml.append:8868
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_LOOT_ELITE_COALITION_1\"]/descriptionOverride"
msgstr ""
"Special loot weapon. See tooltip in the inventory to check the improvements over the base version\n"
"\n"
"\t\tStats:\n"
"\t\tRequired Power: 2\n"
"\t\tCharge Time: 13 seconds\n"
"\t\tMissile Consumption: 1\n"
"\t\tAccuracy Bonus: 30%\n"
"\n"
"\t\tShots Per Charge: 1\n"
"\t\t\n"
"\t\tBase Hull Damage: 3\n"
"\t\tTotal System Damage: 3\n"
"\t\tTotal Crew Damage: 60\n"
"\t\tShield Piercing: 10\n"
"\n"
"\t\tLocks down rooms on hit\n"
"\t\tFire Chance: 20%\n"
"\t\tBreach Chance: 20% (Adjusted: 16%)\n"
"\t\tStun Chance: 100% (5 seconds long)\n"
"\t\t\n"
"\t\tDefault Price: 65~   -   Selling Price: 32~"

