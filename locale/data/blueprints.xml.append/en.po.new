#: src-en/data/blueprints.xml.append:15005
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_JUDGES\"]/desc"
msgstr ""
"[Base cooldown: 60/ Final Cooldown: 3] This Pinpoint artillery takes a long "
