#: src-en/data/blueprints.xml.append:7365
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_AUGUSTUS_MISSILE\"]/title"
msgstr "'Midas' Burst Missiles"

#: src-en/data/blueprints.xml.append:7366
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_AUGUSTUS_MISSILE\"]/short"
msgstr "'Midas'"

#: src-en/data/blueprints.xml.append:7367
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_AUGUSTUS_MISSILE\"]/desc"
msgstr ""
"Burst Missiles fire multiple low damage warheads for the price of one "
"through patented replication technology."

#: src-en/data/blueprints.xml.append:7368
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_AUGUSTUS_MISSILE\"]/descriptionOverride"
msgstr ""
"A gun made out of pure gold and ectoplasm. Fires a set of 3 golden warheads which all have different properties at the cost of needing both scrap and a missile to fire.\n"
"\n"
"\t\tStats:\n"
"\t\tRequired Power: 2\n"
"\t\tCharge Time: 15 seconds\n"
"\t\tScrap Consumption: 3\n"
"\t\tMissile Consumption: 1\n"
"\n"
"\t\tShot Radius: 35\n"
"\t\tFires 3 Random Missiles Per Shot\n"
"\t\t\n"
"\t\tRed Missile: 1 hull and 3 system damage, 100% fire chance, fully ignites the room hit.\n"
"\t\tBlue Missile: 2 hull damage, hullbust, 100% breach chance, slowly erode the system in the targeted room.\n"
"\t\tGreen Missile: 1 hull and 2 Ion Damage, stuns crew hit for 10 seconds, destroys any crew drone hit instantly.\n"
"\t\tCyan Missile: 1 Damage, undetectable by certain Defense Drones, locks down room, inflicts Cryo-Sentry debuffs on all crew members in room for the lockdown duration.\n"
"\t\tPurple Missile: 1 system and 90 crew damage, inflicts radiation debuffs, inflicts 3 damage per second over 25 seconds, can't miss, deals 1 system damage to surrounding rooms.\n"
"\t\t\n"
"\t\tDefault Price: 250~   -   Selling Price: 125~"

#: src-en/data/blueprints.xml.append:7387
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_AUGUSTUS_MISSILE\"]/tooltipOverride"
msgstr ""
"Required Power: 2\n"
"\t\tCharge Time: 15 seconds\n"
"\t\tScrap Consumption: 3\n"
"\t\tMissile Consumption: 1\n"
"\n"
"\t\tShot Radius: 35\n"
"\t\tFires 3 Random Missiles Per Shot\n"
"\t\t\n"
"\t\tRed Missile: 1 hull and 3 system damage, 100% fire chance, fully ignites the room hit.\n"
"\t\tBlue Missile: 2 hull damage, hullbust, 100% breach chance, slowly erode the system in the targeted room.\n"
"\t\tGreen Missile: 1 hull and 2 Ion Damage, stuns crew hit for 10 seconds, destroys any crew drone hit instantly.\n"
"\t\tCyan Missile: 1 Damage, undetectable by certain Defense Drones, locks down room, inflicts Cryo-Sentry debuffs on all crew members in room for the lockdown duration.\n"
"\t\tPurple Missile: 1 system and 90 crew damage, inflicts radiation debuffs, inflicts 3 damage per second over 25 seconds, can't miss, deals 1 system damage to surrounding rooms."

#: src-en/data/blueprints.xml.append:7443
msgid ""
"data/blueprints.xml.append$//droneBlueprint[@name=\"FR_COMBAT_SALLY_BOMB\"]/title"
msgstr "Sally's Arachno-Bomb Drone"

#: src-en/data/blueprints.xml.append:7444
msgid ""
"data/blueprints.xml.append$//droneBlueprint[@name=\"FR_COMBAT_SALLY_BOMB\"]/short"
