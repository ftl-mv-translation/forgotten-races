"Can't miss. The drone won't benefit from drone related bonuses and will self"
" destruct on jump."

#: src-en/data/blueprints.xml.append:14327
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ARTILLERY_REVENANT_CLEO_C\"]/tooltip"
msgstr ""
