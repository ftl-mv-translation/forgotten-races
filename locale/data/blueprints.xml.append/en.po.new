"\n"
"\t\tBeam Length: Pinpoint\n"
"\t\tBeam Speed: 1\n"
"\t\t\n"
"\t\tHull Repair: 5\n"
"\t\tTotal Crew Damage: 75\n"
"\t\tIon Damage: 5\n"
"\n"
"\t\tFire Chance 50%\n"
"\t\tBreach Chance: 50% (Adjusted: 25%)\n"
"\t\tStun Chance: 100% (25 seconds long)"

