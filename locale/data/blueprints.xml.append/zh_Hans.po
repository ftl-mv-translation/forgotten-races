"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_SLIMER_BOMB\"]/desc"
msgstr "黏稠者的首席打造的自传送式炸药。造成轻微系统伤害，阻止修理，并使船员移动速度降低至0.1倍，持续10秒。无法对自己的飞船使用。"

#: src-en/data/blueprints.xml.append:5626
