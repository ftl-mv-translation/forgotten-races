#: src-en/data/hyperspace.xml.append:3135
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"fr_unique_prophet\"]/powerEffect/tooltip"
msgstr ""
"[ПЕРЕЗАРЯДКА:30с  ДЛИТЕЛЬНОСТЬ: 12с  -75 ОЗ]\n"
"\t\t\tПредоставляет следующие усиления:\n"
"\t\t\t-1.5х скорость передвижения\n"
"\t\t\t-2.5х скорость ремонта, нанесения боевого урона и скорости саботажа\n"
"\t\t\t-0.75х уменьшение урона, получаемого от ЛЮБОГО источника\n"
"\t\t\t-Иммунитет к контролю разума\n"
"\t\t\t-Дает 2 энергии при нахождении в блоке Контроля дронов дружественными "
"дронами."

#: src-en/data/hyperspace.xml.append:3206
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"fr_human_totality\"]/powerEffect/buttonText"
msgstr "ЛЕЧЕНИЕ"

#: src-en/data/hyperspace.xml.append:3207
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"fr_human_totality\"]/powerEffect/tooltip"
msgstr ""
"[ПЕРЕЗАРЯДКА:1с]\n"
"\t\t\tПолностью исцеляет этого члена экипажа."

#: src-en/data/hyperspace.xml.append:3305
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"fr_unique_purple_beard\"]/powerEffect/buttonText"
msgstr "СТИМ-БОМБА"

#: src-en/data/hyperspace.xml.append:3306
