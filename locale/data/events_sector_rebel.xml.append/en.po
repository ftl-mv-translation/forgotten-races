#: src-en/data/events_sector_rebel.xml.append:9
msgid ""
"data/events_sector_rebel.xml.append$//mod:findName[@name=\"ENCOUNTER_REBEL\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halt, soldier! The Rebel movement is under the spell of a "
"treacherous rat! This is your official order to disband!\""

#: src-en/data/events_sector_rebel.xml.append:11
msgid ""
"data/events_sector_rebel.xml.append$//mod:findName[@name=\"ENCOUNTER_REBEL\"]/mod-"
"append:choice[1]/event[1]/text"
msgstr ""
"\"It's an honor to meet you, sir! Yes, we will stand down at your order!\""

#: src-en/data/events_sector_rebel.xml.append:16
msgid ""
"data/events_sector_rebel.xml.append$//mod:findName[@name=\"ENCOUNTER_REBEL\"]/mod-"
"append:choice[1]/event[2]/text"
msgstr ""
"\"Vance Prime! Sir, it's an honor to meet you! We are short on supplies, but"
" we do have one too many bodies onboard!\" A Rebel offers to join your crew."

#: src-en/data/events_sector_rebel.xml.append:21
msgid ""
"data/events_sector_rebel.xml.append$//mod:findName[@name=\"ENCOUNTER_REBEL\"]/mod-"
"append:choice[1]/event[3]/text"
msgstr ""
"The Rebel captain can't believe their eyes when they see that your ship "
"carries the one and only Vance Prime! They quickly apologize and promise to "
"delay the fleet as much as they can before jumping away."

