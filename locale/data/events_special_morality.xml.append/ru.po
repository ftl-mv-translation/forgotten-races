#: src-en/data/events_special_morality.xml.append:115
msgid ""
"data/events_special_morality.xml.append$//event[@name=\"FR_MORALITY_UPDATE_ZOLTAN_MASSIVE\"]/text"
msgstr ""
"[ДУРНАЯ СЛАВА ПОВЫШЕНА X4 - МИНИСТЕРСТВО]\n"
"\tВаши действия против Министерства сделали вас врагом государства. Сторожевые корабли Министерства теперь будут нападать на вас при первой же возможности."

#: src-en/data/events_special_morality.xml.append:121
msgid ""
"data/events_special_morality.xml.append$//event[@name=\"FR_MORALITY_CRYSTAL_VAMPWEED\"]/text"
msgstr ""
"[ДУРНАЯ СЛАВА ПОВЫШЕНА - ИМПЕРИЯ КРИСТАЛЛИНОВ]\n"
"\tВаши действия здесь, оправданные или нет, не лучшим образом отразятся в глазах Империи и ее граждан. Продолжая совершать подобные действия, вы можете начать замечать негативную реакцию со стороны Империи и ее союзников.\n"
"\t\n"
"\t[ДУРНАЯ СЛАВА ПОВЫШЕНА - ИМПЕРИЯ КОНФЕДЕРАЦИЯ]\n"
"\tВаши действия здесь, оправданные или нет, не лучшим образом отразятся в глазах Конфедерации и ее граждан. Продолжая совершать подобные действия, вы можете начать замечать негативную реакцию со стороны Конфедерации и ее союзников."

#: src-en/data/events_special_morality.xml.append:131
msgid ""
"data/events_special_morality.xml.append$//event[@name=\"FR_MORALITY_REMOVE_GENERAL_DOUBLE\"]/text"
msgstr ""
"[ДУРНАЯ СЛАВА ПОНИЖЕНА 2Х - ОБЩЕЕ]\n"
"\tВы совершили доброе дело в глазах Федерации. Если вы обрели дурную славу за проступки до этого, вас, скорее всего, простят за них.\n"
"\tЗа ваши особо героические поступки ваша дурная слава была понижена дважды."

#: src-en/data/events_special_morality.xml.append:138
msgid ""
"data/events_special_morality.xml.append$//event[@name=\"FR_REPUTATION_UPDATE_SLAVER_MEMBERSHIP\"]/text"
msgstr ""
"[РЕПУТАЦИЯ ПОВЫШЕНА 10Х - РАБОТОРГОВЦЫ]\n"
"\tЗарегистрировав членскую карточку, вы значительно укрепили свой авторитет в кругах работорговцев. Некоторые работорговцы могут охотнее предлагать вам скидки или особые сделки и будут чувствовать себя комфортнее рядом с вами."
