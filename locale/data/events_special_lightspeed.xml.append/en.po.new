#: src-en/data/events_special_lightspeed.xml.append:229
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_ENTER_WARZONE\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_lightspeed.xml.append:235
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_WARZONE_WARP\"]/text"
msgstr ""
"Name: Contested Warzone Sector\n"
"\tType: Hostile\n"
"\tUnique: True\n"
"\tDominant Faction: The Rebellion, The Coalition and The Federation\n"
"\tRebel Threat Level: !CRITICALLY HIGH!\n"
"\tLocations of Interest: Federation R&D Headquarters\n"
"\n"
"\tThis sector used to be the R&D sector for the Federation until the Rebels launched a surprise attack on it, greatly weakening the Federation's presence in the sector and taking over their secret project, a Federation Flagship. After that the Coalition invaded the sector with a flagship of their own, hoping to pick off the two weakened factions and seize any remaining technology from either faction.\n"
"\n"
"\tWhile still present, the Federation's forces won't be able to offer you much help; you are on your own here.\n"
"\n"
"\tWARNING: SECTOR IS FILLED WITH POWERFUL AND DANGEROUS ENEMIES ALONGSIDE CONSTANT ASB BARRAGES. YOU MAY REDIRECT YOUR SHIP TO THE FEDERATION EMBASSY BEFORE YOU LAND IF THE RISK IS TOO HIGH."

#: src-en/data/events_special_lightspeed.xml.append:248
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_WARZONE_WARP\"]/choice[1]/text"
msgstr "Exit hyperspeed."

#: src-en/data/events_special_lightspeed.xml.append:252
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_WARZONE_WARP\"]/choice[@req=\"COORDS\"]/text"
msgstr "Reroute."

#: src-en/data/events_special_lightspeed.xml.append:256
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_WARZONE_WARP\"]/choice[3]/text"
msgstr "Redirect the jump to the Federation Embassy!"

