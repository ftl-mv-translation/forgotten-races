#: src-en/data/events_special_lightspeed.xml.append:96
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/text"
msgstr ""
"You are about to reroute. Below is the Atlas entry for this sector.\n"
"\tName: Tartarus\n"
"\tType: Hostile\n"
"\tUnique: True\n"
"\tDominant Faction: The Revenants\n"
"\tRebel Threat Level: None\n"
"\t\n"
"\tMost of the information on this distant sector is completely blank. All you can make out is a list of bizarre names from the bounty, and a foreboding title offered to the sector: Tartarus. The Spook Chasers told you this stretch of space was home to actual undead, but that can't possibly be true... right?"

#: src-en/data/events_special_lightspeed.xml.append:105
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/choice[1]/text"
msgstr "Continue with the jump."

#: src-en/data/events_special_lightspeed.xml.append:107
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/choice[1]/event/text"
msgstr ""
"You prepare to jump to the new coordinates, and change your flight path "
"accordingly."

#: src-en/data/events_special_lightspeed.xml.append:111
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/choice[1]/event/choice[@req=\"chaos_mode\""
" and @lvl=\"1\"]/text"
msgstr "Continue..."

#: src-en/data/events_special_lightspeed.xml.append:115
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/choice[1]/event/choice[@req=\"chaos_mode\""
" and @lvl=\"0\"]/text"
msgstr "Continue..."

#: src-en/data/events_special_lightspeed.xml.append:121
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_LIGHTSPEED_SECTOR_WARP_TARTARUS\"]/choice[2]/text"
msgstr "Nevermind."

