"data/events_special_lightspeed.xml.append$//event[@name=\"FR_COMMONWEALTH_WARP\"]/choice[@req=\"loc_task_accepted\"]/text"
msgstr "Your connection with C.U.R.A. is currently unavailable."

#: src-en/data/events_special_lightspeed.xml.append:207
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_COMMONWEALTH_WARP\"]/choice[@req=\"COORDS\"]/text"
