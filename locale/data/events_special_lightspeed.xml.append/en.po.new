#: src-en/data/events_special_lightspeed.xml.append:191
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_COMMONWEALTH_WARP\"]/text"
msgstr ""
"Name: ???\n"
"\tType: ???\n"
"\tDominant Faction: ???\n"
"\tRebel Threat Level: ???\n"
"\n"
"\tThere is no data about the next sector in your Atlas."

#: src-en/data/events_special_lightspeed.xml.append:199
msgid ""
"data/events_special_lightspeed.xml.append$//event[@name=\"FR_COMMONWEALTH_WARP\"]/choice[1]/text"
