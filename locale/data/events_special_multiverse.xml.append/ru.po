#: src-en/data/events_special_multiverse.xml.append:1807
msgid ""
"data/events_special_multiverse.xml.append$//mod:findName[@name=\"THE_JUDGES_ENGI_REAL\"]/mod-"
"append:choice/text"
msgstr "Представить Ее волю."

#: src-en/data/events_special_multiverse.xml.append:1809
msgid ""
"data/events_special_multiverse.xml.append$//mod:findName[@name=\"THE_JUDGES_ENGI_REAL\"]/mod-"
"append:choice/event/text"
msgstr ""
"\"[ОШИБКА]... К-к-к-как вы... Э-э-это же н-н-н-невозможно! Н-н-н-нет... Я-я "
"должна п-предупредить остальных! Н-но... Корби н-никогда не н-н-н-нарушает "
"кредо! Поэтому я все же обязана вас -наградить-... Я дарую вас дар Касания! "
"Дар Касания! Приберегите его - на будущее, и н-н-никогда больше не о-"
"обращайся к нам!\""

