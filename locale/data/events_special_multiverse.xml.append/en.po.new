msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"FR_SYLVAN_COMMONWEALTH_CONVERT_MENU\"]/text"
msgstr ""
"\"Low on sssscrap, sstranger? High on resssourcesss? Well lucky for you "
"ssstranger, I can take care of that!\""

#: src-en/data/events_special_multiverse.xml.append:333
