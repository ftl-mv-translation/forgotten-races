msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_COGNITIVE\"]/choice[2]/text"
msgstr "Leave them to drift."

#: src-en/data/events_fr_sector_commonwealth.xml:1093
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_COGNITIVE\"]/choice[2]/event/text"
msgstr ""
"The Cognitive never once stirs to life. You doubt that you could have helped"
" it anyways."

#: src-en/data/events_fr_sector_commonwealth.xml:1095
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_COGNITIVE\"]/choice[2]/event/choice[1]/text"
msgstr "Do something onboard the ship."

