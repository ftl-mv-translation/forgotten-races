"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[@req=\"fr_rep_commonwealth\""
" and @lvl=\"3\"]/event/text"
msgstr ""
"The Commonwealths work on your ship for hours, but eventually they finish. "
"When you ask what they did, they simply smile and point to your internal "
"augment list, where it shows a brand new augment has been installed - a... "
"panic button?!"

#: src-en/data/events_fr_sector_commonwealth.xml:1170
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[4]/text"
msgstr "Reject their offer."

#: src-en/data/events_fr_sector_commonwealth.xml:1172
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[4]/event/text"
msgstr "The Commonwealths are disappointed, but they understand."

#: src-en/data/events_fr_sector_commonwealth.xml:1174
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[4]/event/choice[1]/text"
