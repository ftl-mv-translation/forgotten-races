msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_AUTO_CRUISER_SUCCESS\"]/choice/event/choice[2]/event/choice/event/text"
msgstr "The guard nods before bidding you farewell."

