msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_REPAIR_CENTER_NOMARKER\"]/text"
msgstr ""
"As you land from the jump, you realize you are in the airspace of a repair "
"center - this should be useful."

#: src-en/data/events_fr_sector_commonwealth.xml:199
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_REPAIR_CENTER_NOMARKER\"]/choice/text"
