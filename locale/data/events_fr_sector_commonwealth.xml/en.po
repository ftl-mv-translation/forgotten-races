"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[@req=\"fr_rep_commonwealth\""
" and @lvl=\"-1\"]/event/text"
msgstr ""
"The Commonwealths work on your ship for hours, but eventually they finish. "
"When you ask what they did, they simply smile and point to your internal "
"augment list, where it shows a brand new augment has been installed - an "
"Ancient Recycler!"

#: src-en/data/events_fr_sector_commonwealth.xml:1163
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_ITEM_COMMONWEALTH_AUGMENT\"]/choice[@req=\"fr_rep_commonwealth\""
" and @lvl=\"3\"]/text"
msgstr "Accept."

#: src-en/data/events_fr_sector_commonwealth.xml:1165
