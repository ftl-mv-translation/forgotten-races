#: src-en/data/events_sector_showdown.xml.append:287
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_SHOWDOWN_Y\"]/text"
msgstr ""
"Vance pauses, and appears on the vidscreen. He stares at the queen, visible confusion plastered on his face.\n"
"\t\n"
"\t\"You...You were supposed to be dead. I shot you an hour ago!\""

#: src-en/data/events_sector_showdown.xml.append:291
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_SHOWDOWN_Y\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_sector_showdown.xml.append:293
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_SHOWDOWN_Y\"]/choice/event/text"
msgstr ""
"Y just laughs in his face. \"You mortals are so predictable. Whoever you "
"think you shot clearly wasn't me. No queen worthy of her rank would ever die"
" to the likes of you!\""

#: src-en/data/events_sector_showdown.xml.append:295
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_SHOWDOWN_Y\"]/choice/event/choice/text"
