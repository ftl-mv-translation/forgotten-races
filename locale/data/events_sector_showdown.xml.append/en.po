#: src-en/data/events_sector_showdown.xml.append:157
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_TRUE_VICTORY_CREW_LEIKONPLIIINAKRA\"]/text"
msgstr ""
"\"The mantis have been in dire need of a victory to raise our spirits. May "
"this one herald a new era for our people. We have stopped the Rebellion, "
"hopefully for good this time, and one-upped the Obelisks themselves, ancient"
" enemies of the Crystalline people! Oh, I can't wait to see Elder "
"Stonewall's face after this. Thank you, Renegade... if we get out of this "
"alive, I promise the negotiations will start the instant we get home.\""

#: src-en/data/events_sector_showdown.xml.append:160
msgid ""
"data/events_sector_showdown.xml.append$//event[@name=\"FR_TRUE_VICTORY_CREW_LEIKONPLIIINAKRA\"]/choice/text"
