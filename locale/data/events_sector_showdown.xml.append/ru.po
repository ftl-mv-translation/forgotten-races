"data/events_sector_showdown.xml.append$//event[@name=\"FR_SHOWDOWN_TWIST\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"ponyc\"]/event/choice/event/removeCrew/text"
