msgid ""
"data/events_sector_obelisk.xml.append$//event[@name=\"FR_COMMONWEALTH_FORGE_CRUISER\"]/beaconType/undiscoveredTooltip[1]"
msgstr "这个信标似乎正在传送一段奇特的广播信号。"

#: src-en/data/events_sector_obelisk.xml.append:10
msgid ""
"data/events_sector_obelisk.xml.append$//event[@name=\"FR_COMMONWEALTH_FORGE_CRUISER\"]/beaconType/undiscoveredTooltip[2]"
