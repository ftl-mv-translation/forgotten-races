msgstr ""
"(Рунический переводчик) У нас уже есть переводчик; расшифровать, что говорит "
"корабль!"

#: src-en/data/events_sector_obelisk.xml.append:50
msgid ""
"data/events_sector_obelisk.xml.append$//event[@name=\"FR_COMMONWEALTH_FORGE_CRUISER\"]/choice[1]/event/choice[@req=\"UPG_AETHER_TRANSLATOR\""
" and @lvl=\"1\"]/event/text"
