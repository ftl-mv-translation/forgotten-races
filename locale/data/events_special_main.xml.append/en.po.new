#: src-en/data/events_special_main.xml.append:14
msgid ""
"data/events_special_main.xml.append$//mod:findName[@name=\"GIVE_DATABASE\"]/mod-"
"append:choice/text"
msgstr "Screw this ship! Let's take the good old Tester for a spin!"

#: src-en/data/events_special_main.xml.append:16
msgid ""
"data/events_special_main.xml.append$//mod:findName[@name=\"GIVE_DATABASE\"]/mod-"
"append:choice/event/text"
msgstr ""
"You and your crew quickly ditch your current ship and board the newly "
"refurbished Tester!"

#: src-en/data/events_special_main.xml.append:20
msgid ""
"data/events_special_main.xml.append$//mod:findName[@name=\"GIVE_DATABASE\"]/mod-"
"append:choice/event/choice/text"
msgstr "Continue..."

