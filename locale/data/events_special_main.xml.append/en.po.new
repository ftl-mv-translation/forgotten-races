#: src-en/data/events_special_main.xml.append:355
msgid ""
"data/events_special_main.xml.append$//event[@name=\"FR_EXTRA_LIFE_HER\"]/text"
msgstr ""
"\"Not so fast! You aren't going to take me down that easily!\"\n"
"\t\t  /\n"
"\t\t:)\n"
"\tSuddenly, your hull is as good as new, as if it was never damaged."
