#: src-en/data/events_sector_dynasty.xml.append:106
#, fuzzy
msgid ""
"data/events_sector_dynasty.xml.append$//event[@name=\"FR_WITHER_RUINS_DYNASTY_CREWKILL\"]/choice[@req=\"FR_LIST_MEDICAL_NONBALLISTIC\"]/event/text"
msgstr ""
"“谢谢你，谢谢你！”那个食铁族手舞足蹈着，跟着你回到了你的船上。灵朝飞船过了一"
"会就向你呼叫了。\n"
"\t\t\t\n"
"\t\t\t“哎哟，你真的会让那些害虫留在你的船上吗？真该死！幸好我是个实诚的魂灵。"
"你将会收到你的蓝图，但别指望能得到我的额外奖励。现在快走，在我改变主意之前！”"

#: src-en/data/events_sector_dynasty.xml.append:115
msgid ""
"data/events_sector_dynasty.xml.append$//event[@name=\"FR_WITHER_RUINS_DYNASTY_CREWKILL\"]/choice[@req=\"RECON_AND_TELEPORT\"]/text"
msgstr "（传送重构器）把他传送回你的船上。"

#: src-en/data/events_sector_dynasty.xml.append:117
#, fuzzy
msgid ""
"data/events_sector_dynasty.xml.append$//event[@name=\"FR_WITHER_RUINS_DYNASTY_CREWKILL\"]/choice[@req=\"RECON_AND_TELEPORT\"]/event/text"
msgstr ""
"“谢谢你，谢谢你！”那个食铁族手舞足蹈着，已经完全恢复了。灵朝飞船过了一会就向"
"你呼叫了。\n"
"\t\t\t\n"
"\t\t\t“哎哟，你真的会让那些害虫留在你的船上吗？真该死！幸好我是个实诚的魂灵。"
