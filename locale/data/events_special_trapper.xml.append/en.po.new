#: src-en/data/events_special_trapper.xml.append:235
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_PIRATE\"]/text"
msgstr ""
"Elite pirates all seem to share one defining feature, a love for highly "
"dangerous and forbidden weapons. Their favorite type is the ever frightful "
"minelauncher line. How they got their hands on these weapons is one of "
"life's great mysteries."

#: src-en/data/events_special_trapper.xml.append:239
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_PIRATE\"]/choice[1]/text"
