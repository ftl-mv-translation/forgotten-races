#: src-en/data/events_special_trapper.xml.append:183
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_FEDERATION\"]/text"
msgstr ""
"Few factions are as stringent about border protection as the Zoltan, and "
"their Peacekeeper ships are even stricter, especially in such a wartorn "
"sector. They hail you. \"Federation ship, we demand you leave immediately. "
"It is of great importance that we reinforce the minefields in this sector, "
"and your presence disturbs our work. We will not warn you a second time.\""

#: src-en/data/events_special_trapper.xml.append:187
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_FEDERATION\"]/choice[1]/text"
msgstr "Attack, we can steal their Mine Launcher tech!"

