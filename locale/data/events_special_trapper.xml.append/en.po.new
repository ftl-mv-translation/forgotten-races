"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_COALITION\"]/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_trapper.xml.append:141
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_COALITION\"]/choice[2]/text"
msgstr "Avoid the Trapper."

#: src-en/data/events_special_trapper.xml.append:143
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_TRAPPER_WARZONE_COALITION\"]/choice[2]/event/text"
