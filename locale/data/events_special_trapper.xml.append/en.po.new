#: src-en/data/events_special_trapper.xml.append:157
msgid ""
"data/events_special_trapper.xml.append$//event[@name=\"FR_DESTROYED_TRAPPER_WARZONE_COALITION\"]/text"
msgstr ""
"While scrapping the wreckage of the Trapper ship, you find a functional Mine"
