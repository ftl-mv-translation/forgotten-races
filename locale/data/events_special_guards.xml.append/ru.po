msgstr "Охранник кивает, прощаясь с вами."

#: src-en/data/events_special_guards.xml.append:362
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/event/choice/event/choice/text"
