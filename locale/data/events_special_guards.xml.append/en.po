#: src-en/data/events_special_guards.xml.append:1145
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_FEDERATION\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:1147
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_FEDERATION\"]/text"
msgstr ""
"You catch sight of a Federation ship, but they don't seem pleased to see you. \"Turncoats! You should be ashamed!\" The ship moves in to attack, and it doesn't take long for you to realize this is one of the ships sent by the guards to hunt you down for attacking.\n"
"\t\t\t\n"
"\tHowever, before the fight can truly start, you detect that the MFK and Coalition fleets in the distance has also turned its guns on the Federation ship. It's an all-out brawl now!"

#: src-en/data/events_special_guards.xml.append:1156
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_FEDERATION\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:1165
