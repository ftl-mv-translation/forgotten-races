#: src-en/data/events_special_guards.xml.append:5
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:7
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[1]/text"
msgstr ""
"\"O-Oh shit! Of course, sir!\" The Rebel guard stands down and allows your "
"ship to pass. One of their crew offers to jump ship, and Vance orders the "
"guard ship to send over supplies as well as send false data to the fleet."

#: src-en/data/events_special_guards.xml.append:14
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[2]/text"
msgstr ""
"\"Like hell we will! You don't deserve to be called Vance anymore, you "
"traitor!\" the Rebel captain bellows and calls for reinforcement, as well as"
" informing the fleet of your intrusion."

#: src-en/data/events_special_guards.xml.append:18
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[2]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:24
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:26
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/event[1]/text"
msgstr ""
"\"O-Oh shit! Of course, sir!\" The Rebel guard stands down and allows your "
"ship to pass. One of their crew offers to jump ship, and Vance orders the "
"guard ship to send over supplies as well as send false data to the fleet."

#: src-en/data/events_special_guards.xml.append:33
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/event[2]/text"
msgstr ""
"\"Like hell we will! You don't deserve to be called Vance anymore, you "
"traitor!\" the Rebel captain bellows and calls for reinforcement, as well as"
" informing the fleet of your intrusion."

#: src-en/data/events_special_guards.xml.append:37
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/event[2]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:43
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[3]/text"
msgstr "(Forged Identification) Try to pass your ship for a Rebel one."

#: src-en/data/events_special_guards.xml.append:45
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[3]/event[1]/text"
msgstr ""
"\"Hah! That's a good joke, we stopped using IDs with photos years ago!\" The"
" Rebel ship sends a distress signal, calling for backup!"

#: src-en/data/events_special_guards.xml.append:49
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[3]/event[1]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:54
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[3]/event[2]/text"
msgstr ""
"The rebel captain examines the ID, before shrugging. \"Ehhh...sure. Welcome "
"to the sector, kid\"."

#: src-en/data/events_special_guards.xml.append:63
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[1]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:65
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[1]/event/text"
msgstr ""
"\"Oh, shit! Vance Prime! I-I'm sorry for the misunderstanding, we ID'd you "
"as a Fed! We'll make sure the fleet isn't a problem for you here.\" As the "
"guard sends an all-clear signal, a couple of MFK Aces are dispatched to aid "
"your cause, alongside a few boxes of supplies."

#: src-en/data/events_special_guards.xml.append:72
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[2]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:74
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[2]/event/text"
msgstr ""
"\"Wow. Just...wow. And here I thought you Federation dogs couldn't get any "
"more stupid!\" The Rebel ship sends a distress signal, calling for backup!"

#: src-en/data/events_special_guards.xml.append:78
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[2]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:84
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[3]/text"
msgstr "(Forged Identification) Try to pass your ship for a Rebel one."

#: src-en/data/events_special_guards.xml.append:86
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[3]/event/text"
msgstr ""
"\"Wow. Just...wow. And here I thought you Federation dogs couldn't get any "
"more stupid!\" The Rebel ship sends a distress signal, calling for backup!"

#: src-en/data/events_special_guards.xml.append:90
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[3]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:99
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_JERRY\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass! I need to "
"see my nephew!\""

#: src-en/data/events_special_guards.xml.append:101
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_JERRY\"]/mod-"
"append:choice[1]/event/text"
msgstr ""
"\"Wait a second...Vance Prime? How...w-why, when did you join the "
"Federation!? This makes...no sense...\" The guard staggers. They eventually "
"agree to let you pass, though they only have the heart to push the fleet "
"back a small amount."

#: src-en/data/events_special_guards.xml.append:106
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_JERRY\"]/mod-"
"append:choice[2]/text"
msgstr "(Forged Identification) Try to pass your ship for a Rebel one."

#: src-en/data/events_special_guards.xml.append:108
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_JERRY\"]/mod-"
"append:choice[2]/event/text"
msgstr "\"Duke Bangledotom...? Jerry's been expecting you! Right this way!\""

#: src-en/data/events_special_guards.xml.append:117
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_COALITIONHOLD\"]/mod-"
"append:choice/text"
msgstr ""
"(Leikonpliiinakra) \"Let's ask another question. What appendages do YOU "
"value the most?\""

#: src-en/data/events_special_guards.xml.append:119
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_COALITIONHOLD\"]/mod-"
"append:choice/event/text"
msgstr ""
"\"Oh my god! Queen Leikonpliiinakra?! I-I'm so sorry! P-please, don't cut "
"off my arms, I'll let you right through!\" The guard dumps a few crates of "
"valuable scrap metal, and one containing a weapon from the Coalition's "
"finest arsenal, right into your cargo hold."

#: src-en/data/events_special_guards.xml.append:128
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_UNION_COREWORLDS\"]/mod-"
"append:choice/text"
msgstr "Undergo the inspection."

#: src-en/data/events_special_guards.xml.append:130
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_UNION_COREWORLDS\"]/mod-"
"append:choice/event/text"
msgstr ""
"At long last you make your way to the checkpoint entrance. Your crew are taken one by one into a full-room scanning machine that examines everything from their chemical makeup to the contents of their stomach. The guard leader stops dead in their track as they realize who's right in front of them \"Vance... Prime...?\" They mutter quietly, taking a step back.\n"
"\n"
"\t\t\t\t\tVance bares a fanged smile and slowly shakes his head. \"I'm afraid you aren't correct, our most loyal citizen. I'm simply a veteran of this terrible war, and I would kindly ask you to allow this old man to pass.\" The guard blinks a few times before shyly nodding and allowing him and the rest of your crew to pass without any other issues."

#: src-en/data/events_special_guards.xml.append:139
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_COALITION\"]/mod-"
"append:choice/text"
msgstr ""
"(Leikonpliiinakra) \"Intruders?! Listen here, you weakling, you will allow "
"us passage through the sector. Otherwise, I will publicly execute all of "
"you! Do you understand?\""

#: src-en/data/events_special_guards.xml.append:141
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_COALITION\"]/mod-"
"append:choice/event/text"
msgstr ""
"The guards scramble to attention at the sight of the Queen. \"O-Of course, "
"your highness! Right this way!\" The guard allows you to pass while also "
"sending some supplies your way."

#: src-en/data/events_special_guards.xml.append:149
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_LEECH_COALITION\"]/mod-"
"append:choice/text"
msgstr "(Leikonpliiinakra) \"Guards! I demand entry into this sector at once!\""

#: src-en/data/events_special_guards.xml.append:151
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_LEECH_COALITION\"]/mod-"
"append:choice/event/text"
msgstr ""
"You hear heavy chatter on the other side of the radio before the captain "
"finally contacts you. \"O-of course, your highness!\" They also send you "
"some supplies as tribute."

#: src-en/data/events_special_guards.xml.append:159
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_MANTIS\"]/mod-"
"append:choice/text"
msgstr "(Leikonpliiinakra) \"Guards! I demand entry into this sector at once!\""

#: src-en/data/events_special_guards.xml.append:161
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_MANTIS\"]/mod-"
"append:choice/event/text"
msgstr ""
"The guards all collectively bow to their queen. \"O-of course Highness! Have"
" gifts!\""

#: src-en/data/events_special_guards.xml.append:169
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_HIVE\"]/mod-"
"append:choice/text"
msgstr "(Leikonpliiinakra) \"Loyal warriors, your queen demands entry at once!\""

#: src-en/data/events_special_guards.xml.append:171
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_HIVE\"]/mod-"
"append:choice/event/text"
msgstr ""
"The guards all collectively bow to their queen. \"Queen Leikonpliiinakra "
"bless loyal warriors with beautiful vision! I request to join Queen's "
"mission!\" The Queen blesses a Bishop with permission to join your crew, and"
" they step in bearing gifts!"

#: src-en/data/events_special_guards.xml.append:194
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/text"
msgstr ""
"You reach the other side of the portal at last, and there you find a guard "
"that looks identical to the Obelisk designs you've seen, though this one "
"flies colors that you don't recognise. The ship doesn't make any hostile "
"moves yet, as it appears to be analyzing you and your intentions first."

#: src-en/data/events_special_guards.xml.append:202
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/text"
msgstr "Hail them."

#: src-en/data/events_special_guards.xml.append:204
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/text"
msgstr ""
"The ship responds, though the crew's speech seems to be too old for the "
"translator to keep up, only managing to translate a few words that likely "
"still exist in the modern Obelisk language \"Beware - Exterminators - "
"Unwelcome - Surrender\""

#: src-en/data/events_special_guards.xml.append:206
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[1]/text"
msgstr "We don't want to hurt you! We came in peace!"

#: src-en/data/events_special_guards.xml.append:208
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[1]/event/text"
msgstr ""
"Despite your peaceful declarations, the enemy ship turns its weapons online!"
" It seems they either didn't understand you or didn't believe you. Either "
"way, a fight is unavoidable."

#: src-en/data/events_special_guards.xml.append:211
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:217
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/text"
msgstr ""
"(Commonwealth's Body) Show them the broken body, maybe they can help us "
"repair it."

#: src-en/data/events_special_guards.xml.append:219
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/text"
msgstr ""
"A loud shriek can be heard from the other side, and soon after the other "
"ship cuts the transmission and refuses all further hails. Well then..."

#: src-en/data/events_special_guards.xml.append:222
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:228
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_BLUELIST_ANCIENT_NO_COMMONWEALTH\"]/text"
msgstr ""
"(Non-Commonwealth Obelisk Crew) Let your obelisk crew de-escalate the "
"situation."

#: src-en/data/events_special_guards.xml.append:230
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_BLUELIST_ANCIENT_NO_COMMONWEALTH\"]/event/text"
msgstr ""
"Your crew hails the ship but to no avail. It seems that your Obelisk crew "
"member speaks a language that is not intelligible to the Obelisks on the "
"other ship. In an effort to de-escalate the situation, your crew member only"
" ends up making the other Obelisks angrier."

#: src-en/data/events_special_guards.xml.append:233
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"FR_BLUELIST_ANCIENT_NO_COMMONWEALTH\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:239
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/text"
msgstr "(Commonwealth Crew) Your Commonwealth crew wants to talk to them."

#: src-en/data/events_special_guards.xml.append:241
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/text"
msgstr ""
"The mere sight of your Commonwealth crew seems to put them at ease, enough for them to turn their weapons offline immediately. After a long chat, your Commonwealth manages to convince them to install a translator that can translate the old Commonwealth language into something understandable.\n"
"\n"
"\t\t\t\t\t\"Apologies for the hostile introduction, we're always on high alert whenever outsiders appear. I'm afraid our past trauma with the Exterminators still haunts us to this day. We are the Commonwealth and we bid you welcome to our humble refuge.\""

#: src-en/data/events_special_guards.xml.append:246
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/text"
msgstr "Exterminators?"

#: src-en/data/events_special_guards.xml.append:248
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/text"
msgstr ""
"The being nods its main cube. \"The ones adorned in white and pink, those that ordered our demise, and those whose might we simply couldn't match. They are out there still, and if they found us... Well, I'm afraid the last of our kind would vanish, for good this time.\"\n"
"\n"
"\t\t\t\t\t\t\tThe being sits in silence for a moment before speaking again \"We weren't expecting you to harbor one of our kind. I'm surprised we didn't detect them sooner, though I suppose our equipment aren't what they used to be. Entropy certainly is a cruel mistress.\""

#: src-en/data/events_special_guards.xml.append:253
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/text"
msgstr "How do we leave this sector?"

#: src-en/data/events_special_guards.xml.append:255
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/text"
msgstr ""
"The Commonwealth shakes its head. \"I'm afraid it won't be that easy. Others of my kind might not welcome outsiders, even those who harbor our kind. Still, if you wish to leave, then simply look for the rift deep within our sector. It's the only way out, and it's also guarded by our most fearsome vessel. Be prepared for a fight, as no one is ever allowed to leave.\"\n"
"\n"
"\t\t\t\t\t\t\t\t\t\"Still, I will do what I can to aid you by repairing your hull and gifting you one of our weapons. Peace be with you, outsiders.\""

#: src-en/data/events_special_guards.xml.append:261
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[1]/text"
msgstr "Thank you."

#: src-en/data/events_special_guards.xml.append:263
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[1]/event/text"
msgstr "The guard nods before bidding you farewell."

#: src-en/data/events_special_guards.xml.append:267
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:273
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/text"
msgstr ""
"(Commonwealth's Body) What about this body? Is there a way to revive them?"

#: src-en/data/events_special_guards.xml.append:275
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/text"
msgstr ""
"The guard examines the body for a few minutes before speaking \"There might "
"be a way indeed. There is a repair center that might have the tools needed "
"to revive them. Here, let me mark it for you in your map.\""

#: src-en/data/events_special_guards.xml.append:278
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/text"
msgstr "Thank you."

#: src-en/data/events_special_guards.xml.append:280
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/event/text"
msgstr "The guard nods before bidding you farewell."

#: src-en/data/events_special_guards.xml.append:282
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:296
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/text"
msgstr "(Daisy) Daisy wants to talk to them."

#: src-en/data/events_special_guards.xml.append:298
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/text"
msgstr ""
"The guard's eyes widen as they quickly shut down their weapons, immediately realizing who they are talking to. After a quick chat, Daisy convinces them to install a module that can translate the old Commonwealth language into something understandable.\n"
"\n"
"\t\t\t\t\t\"Apologies for the hostile introduction Ms. Daisy! We didn't expect you to ever return, much less with the backup you promised. The refuge missed you dearly.\" The guard bows to Daisy and she huffs, crossing her nubs.\n"
"\n"
"\t\t\t\t\t\"You really haven't changed, have you, Dianthus? I'm guessing the refuge got even jumpier after I left. Did you even think about how absurd the idea of the Exterminators returning in a mortal cruiser would sound like?\" Her voice is stern, yet there's a fondness to it, a side of an Obelisk you haven't seen yet."

#: src-en/data/events_special_guards.xml.append:304
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/text"
msgstr "Exterminators?"

#: src-en/data/events_special_guards.xml.append:306
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/text"
msgstr ""
"Dianthus nods his main cube. \"The ones adorned in white and pink, those that ordered our demise, and those whose might we simply couldn't match. They are out there still, and if they found us... Well, I'm afraid the last of our kind would vanish, for good this time.\"\n"
"\n"
"\t\t\t\t\t\t\tDaisy sighs \"I hate to admit your fears are valid. The Exterminators were what got me; I managed to flee far enough to leave their capital sector but those cursed noblemen got to me before I could fully leave Obelisk space. The little fleshling alien here was the one who saved me; they repaired me... somehow.\"\n"
"\n"
"\t\t\t\t\t\t\tDianthus reels from the revelantion \"You... you perished?! Then the warnings, they were all true! Daisy, you must stay in the Refuge for you own safety; we cannot allow you to risk yourself again!\""

#: src-en/data/events_special_guards.xml.append:312
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/text"
msgstr "Wait, we need to leave the sector, we need to find the Paragon!"

#: src-en/data/events_special_guards.xml.append:314
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/event/text"
msgstr ""
"The Commonwealths turn to you in horror. Daisy is the first to speak \"The Paragon? You mean that blasted bomb? IT STILL EXISTS!?\" She turns to Dianthus in a flash. \"Dianthus, I hate to be a contrarian, but we must leave, as soon as physically possible! If Y wants to use the Paragon again then we can't just sit and watch!\"\n"
"\n"
"\t\t\t\t\t\t\t\t\tDianthus stays silent for a moment, thinking about the repercussions of of his possible actions. \"I hate to say it, but you are right. The exit is at the edge of the sector, guarded by our strongest vessel. I wish you two good luck; you will need it.\" \t\n"
"\n"
"\t\t\t\t\t\t\t\t\t\"I will also do what I can to aid you by repairing your hull and gifting you one of our weapons. Peace be with you, outsiders.\" Dianthus bows, his stare staying on Daisy for a moment longer before he cuts the call."

#: src-en/data/events_special_guards.xml.append:323
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/event/choice/text"
msgstr "Thank you."

#: src-en/data/events_special_guards.xml.append:325
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/event/choice/event/text"
msgstr "The guard nods before bidding you farewell."

#: src-en/data/events_special_guards.xml.append:329
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_unique_daisy\"]/event/choice/event/choice/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:345
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/text"
msgstr ""
"The enemy ship won't hold out much longer like this. Perhaps you can get "
"them to surrender?"

#: src-en/data/events_special_guards.xml.append:347
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/text"
msgstr "Power down your weapons."

#: src-en/data/events_special_guards.xml.append:349
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/text"
msgstr ""
"It takes a bit before the enemy ship realizes what you just did, but once they do they also power off their weapons and drones. They hail you, sending you files that seem to be a rudimentary translator. Even with the translator files, you can barely make out a request asking that you allow their drone to install a proper translator in your ship, which you quickly agree to.\n"
"\n"
"\t\t\tOnce the drone is done, you are able to properly communicate with the strange vessel. \"Greetings, Outsider. We are the Commonwealth and we bid you welcome to our humble refuge. We apologise for our hasty actions, we thought you were one of the Exterminators. We offer some scrap as an apology for any damaged we might have caused.\""

#: src-en/data/events_special_guards.xml.append:357
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/text"
msgstr "Thank you, but who are these \"Exterminators\"?"

#: src-en/data/events_special_guards.xml.append:359
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/text"
msgstr ""
"The being nods its main cube \"The ones adorned in white and pink, those that ordered our demise, and those whose might we simply couldn't match. They are out there still, and if they found us... Well, I'm afraid the last of our kind would vanish, for good this time.\"\n"
"\n"
"\t\t\t\t\tThe being sits in silence for a moment before speaking again \"We weren't expecting you to harbor one of our kind. I'm surprised we didn't detect them sooner, though I suppose our equipment aren't what they used to be. Entropy certainly is a cruel mistress.\""

#: src-en/data/events_special_guards.xml.append:364
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/text"
msgstr "How do we leave this sector?"

#: src-en/data/events_special_guards.xml.append:366
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/text"
msgstr ""
"The Commonwealth shakes its head. \"I'm afraid it won't be that easy. Others of my kind might not welcome outsiders, even those who harbor our kind. Still, if you wish to leave, then simply look for the rift deep within our sector. It's the only way out, and it's also guarded by our most fearsome vessel. Be prepared for a fight, as no one is ever allowed to leave.\"\n"
"\n"
"\t\t\t\t\t\t\t\"Still, I will do what I can to aid you by repairing your hull and gifting you one of our weapons. Peace be with you, outsiders.\""

#: src-en/data/events_special_guards.xml.append:372
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[1]/text"
msgstr "Thank you."

#: src-en/data/events_special_guards.xml.append:374
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[1]/event/text"
msgstr "The guard nods before bidding you farewell."

#: src-en/data/events_special_guards.xml.append:378
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:384
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/text"
msgstr ""
"(Commonwealth's Body) What about this body? Is there a way to revive them?"

#: src-en/data/events_special_guards.xml.append:386
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/text"
msgstr ""
"The guard examines the body for a few minutes before speaking \"There might "
"be a way indeed. There is a repair center that might have the tools needed "
"to revive them. Here, let me mark it for you in your map.\""

#: src-en/data/events_special_guards.xml.append:389
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/text"
msgstr "Thank you."

#: src-en/data/events_special_guards.xml.append:391
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/event/text"
msgstr "The guard nods before bidding you farewell."

#: src-en/data/events_special_guards.xml.append:393
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:407
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[2]/text"
msgstr "No, keep fighting."

#: src-en/data/events_special_guards.xml.append:413
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_DESTROY\"]/text"
msgstr ""
"You have defeated the strange Obelisk guard. Whatever might have been in their cargo has certainly been destroyed. Just as you are about to leave, you notice a strange device that survived the fight - a strange translator that seems to be tuned to the extremely old language that the guard spoke. It appears you are in the sector controlled by a group named the Commonwealth. If only we had that before the fight...\n"
"\n"
"\tYou also decide to scan the sector for any points of interest and you notice another huge power spike at the heart of the sector, identical to the portal you came from. If there's a way to leave this place, this will likely be your way out."

#: src-en/data/events_special_guards.xml.append:419
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_DESTROY\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:424
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_DEADCREW\"]/text"
msgstr ""
"You have defeated the strange Obelisk guard. Without crew on board to stop you, you can investigate their cargo. You find a strange blue weapon as well as a strange translator that seems to be tuned to the extremely old language that the guard spoke. It appears you are in the sector controlled by a group named the Commonwealth. If only we had that before the fight...\n"
"\n"
"\tIn the cargo you find a map pointing to a specific location in the sector, some kind of rift that was marked as the \"exit\". Seems like that's your destination if you want to leave this place."

#: src-en/data/events_special_guards.xml.append:431
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_DEADCREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:440
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_FOLLOWUP\"]/text"
msgstr ""
"By killing the Commonwealth guard, you have no doubt caused them to dispatch"
" reinforcements to track you down. Watch your step as you explore the "
"sector."

#: src-en/data/events_special_guards.xml.append:443
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_FOLLOWUP\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:447
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_FOLLOWUP\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:456
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_COMMONWEALTH\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:457
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_COMMONWEALTH\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:458
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_COMMONWEALTH\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:460
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_COMMONWEALTH\"]/text"
msgstr ""
"You catch sight of a heavily powered Commonwealth ship, but they don't seem "
"pleased to see you. \"Outsider! How dare you destroy our guard! Prepare to "
"feel our wrath!\" The ship moves in to attack, and it doesn't take long for "
"you to realize this is one of the ships sent by the guards to hunt you down "
"for attacking."

#: src-en/data/events_special_guards.xml.append:464
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_COMMONWEALTH\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:496
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/text"
msgstr ""
"This sector would have once been a safe haven for you and your crew, but "
"ever since the Rebel attack and the sequential Coalition invasion, this "
"sector has become a no man's land. If that wasn't bad enough, pirates have "
"also been drawn into this place hoping to score easy scrap. Watch your step "
"and always be on guard."

#: src-en/data/events_special_guards.xml.append:504
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:506
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/text"
msgstr ""
"It appears the Coalition has managed to spare a elite guard ship to keep the"
" sector from getting reinforcements, be they Rebel or Federation. \"So you "
"are the reinforcements they sent to try and fight us? That's adorable. Tell "
"me, oh Federation ship that could, how do you expect to stop an endless tide"
" with only a single barricade?\" With this, the guard ship's weapons power "
"on."

#: src-en/data/events_special_guards.xml.append:508
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[1]/text"
msgstr "Prepare for combat!"

#: src-en/data/events_special_guards.xml.append:510
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[1]/event/text"
msgstr "You lock your weapons onto the guard and move in to attack."

#: src-en/data/events_special_guards.xml.append:513
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:519
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"fr_unique_mantis_queen\"]/text"
msgstr "(Leikonpliiinakra) Leikonpliiinakra demands free passage!"

#: src-en/data/events_special_guards.xml.append:521
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"fr_unique_mantis_queen\"]/event/text"
msgstr ""
"\"How dare you address your Queen in such a way? You will let us pass this instant or be publically excuted at my hands. Am I clear?\"\n"
"\t\t\t\t\t\t\n"
"\t\t\t\t\tThe guard scrambles to attention at the sight of the Queen. \"O-Of course, your highness! Right this way!\" The guard allows you to pass while also sending some supplies your way and alerting the Coalition fleet to allow you to pass."

#: src-en/data/events_special_guards.xml.append:528
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"unique_nights\"]/text"
msgstr "(Nights) Nights demands free passage!"

#: src-en/data/events_special_guards.xml.append:530
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"unique_nights\"]/event/text"
msgstr ""
"\"Lissssten here you poor excusssse for a ssssoldier, you will let ussss passsss or I will make you the Coalition'ssss number 1 enemy!\"\n"
"\n"
"\t\t\t\t\tThe guard freezes for a moment before powering down their weapons. \"Very well, Captain. I will let the fleet know at once.\" The guard also sends some supplies your way."

#: src-en/data/events_special_guards.xml.append:537
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"unique_tyrdeo\"]/text"
msgstr "(Tyrdeo) Ask for free passage."

#: src-en/data/events_special_guards.xml.append:539
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"unique_tyrdeo\"]/event/text"
msgstr ""
"\"Excuse me, but I'm Tyrdeo, the President of the Republic. As such, I'm one of the leaders of the Coalition and so I'm politely asking for safe passage.\"\n"
"\n"
"\t\t\t\t\tThe guards tilts their head for a moment before shrugging. \"Very well, President. I will let the fleet know at once.\" The guard also sends some supplies your way."

#: src-en/data/events_special_guards.xml.append:546
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"FR_LIST_CREW_RUES\"]/text"
msgstr "(R.U.E.S. Elite Crew) Try to persuade them to let you go."

#: src-en/data/events_special_guards.xml.append:548
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"FR_LIST_CREW_RUES\"]/event/text"
msgstr ""
"\"I see I have been terribly confused. You can't be a Federation ship, not "
"with one of our elite soldiers with you. You may pass.\" The guard turns "
"their focus back to the rebel forces, but not before sending some supplies "
"to aid you."

#: src-en/data/events_special_guards.xml.append:553
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION\"]/choice/event/choice[@req=\"unique_vance\"]/text"
msgstr "(Vance Prime) Ask for help from the fleet."

#: src-en/data/events_special_guards.xml.append:562
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION_VANCE\"]/text"
msgstr ""
"Vance enters the specific frequency that the local MFK fleet uses to communicate before clearing his throat \n"
"\t\t\n"
"\t\"Soldiers! This is Vance Prime speaking! Any troops avaliable for battle must report immediately and attack the Coalition guard that stands in our way!\"\n"
"\n"
"\tThe Coalition guard bursts out laughting \"Oh please! Your troops are being pushed back further by the second, you think they have the manpower to aid you? It's no wonder the Rebellion is dyin-\" The Coalition captain stops mid sentence as intruder alarms start blaring down on the enemy ship, it seems the fleet had a few MFK soldiers to spare! That didn't stop the guard from attacking you however."

#: src-en/data/events_special_guards.xml.append:569
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_COALITION_VANCE\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:581
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_SIGNAL\"]/text"
msgstr ""
"It appears the guard ship is sending out a distress signal to a nearby ASB "
"platform! Brace for impact!"

#: src-en/data/events_special_guards.xml.append:583
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/text"
msgstr "(Signal Diluter) Jam their signal."

#: src-en/data/events_special_guards.xml.append:585
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/event/text"
msgstr ""
"When no ASB activates, you assume that is a good sign that your augment has "
"functioned properly, and you continue to fight."

#: src-en/data/events_special_guards.xml.append:589
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_SIGNAL\"]/choice[2]/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:591
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_SIGNAL\"]/choice[2]/event/text"
msgstr ""
"Suddenly you detect a shift in the rebel fleet in the distance, its guns now"
" pointing at the Coalition guard!"

#: src-en/data/events_special_guards.xml.append:599
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_DESTROY\"]/text"
msgstr ""
"You have defeated the Coalition guard. Whatever might have been in their "
"cargo has for certain been destroyed, but you can at least salvage some "
"supplies from the ship."

#: src-en/data/events_special_guards.xml.append:602
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_DESTROY\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:607
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_DEADCREW\"]/text"
msgstr ""
"You have defeated the Coalition guard. Without crew on board to stop you, "
"you can investigate their cargo. You find a weapon to bring back to the "
"ship, and move on to scrap their hull."

#: src-en/data/events_special_guards.xml.append:611
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_DEADCREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:619
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_FOLLOWUP\"]/text"
msgstr ""
"By killing the Coalition guard, you have no doubt caused them to dispatch "
"reinforcements to track you down. Watch your step as you explore the sector."
" Though with how chaotic this sector is, there's a chance the forces here "
"will be too busy to deal with you."

#: src-en/data/events_special_guards.xml.append:628
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_FOLLOWUP\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:632
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_COALITION_FOLLOWUP\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:640
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:641
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:642
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:644
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_COALITION\"]/text"
msgstr ""
"\"We will destroy you Federation scum! You will regret ever coming here!\" A hostile Elite Coalition ship approaches, and you suspect they're angry for a lot more than just the dead guard.\n"
"\n"
"\tHowever, before the fight can truly start, you detect that the Federation fleet in the distance has also turned its guns on the Coalition ship. It's an all-out brawl now!"

#: src-en/data/events_special_guards.xml.append:653
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_COALITION\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:662
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:663
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:664
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_COALITION\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:666
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_COALITION\"]/text"
msgstr ""
"\"We will destroy you Federation scum! You will regret ever coming here!\" A hostile Elite Coalition ship approaches, and you suspect they're angry for a lot more than just the dead guard.\n"
"\n"
"\tHowever, before the fight can truly start, you detect that the Federation fleet in the distance has also turned its guns on the Coalition ship. It's an all-out brawl now!"

#: src-en/data/events_special_guards.xml.append:677
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_COALITION\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:690
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/text"
msgstr ""
"This sector would have once been a safe haven for you and your crew, but "
"ever since the Rebel attack and the sequential Coalition invasion, this "
"sector has become a no man's land. If that wasn't bad enough, pirates have "
"also been drawn into this place hoping to score easy scrap. Watch your step "
"and always be on guard."

#: src-en/data/events_special_guards.xml.append:698
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:700
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/text"
msgstr ""
"It seems the Rebels have managed to hold on to the sector's entrance enough "
"to have an MFK Ace Guard still standing. They notice you right away and "
"power on their weapons and artillery. \"Oh, of course a goddamn renegade "
"would stick their nose where it doesn't belong, we are already dealing with "
"enough shit at the moment, the last thing we need is a Federation dog "
"causing us trouble!\""

#: src-en/data/events_special_guards.xml.append:702
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[1]/text"
msgstr "Prepare for combat!"

#: src-en/data/events_special_guards.xml.append:704
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[1]/event/text"
msgstr "You lock your weapons onto the guard and move in to attack."

#: src-en/data/events_special_guards.xml.append:707
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:713
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_vance\"]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:715
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_vance\"]/event/text"
msgstr ""
"\"Oh, shit! Vance Prime! I-I'm sorry for the misunderstanding, we ID'd you "
"as a Fed! We will tell the fleet to help you whenever they can but I'm "
"afraid we have our hands full at the moment, so we can't spare much. If you "
"have the time, please send a few Coalition ships to hell for us!\" The MFK "
"Ace guard powers down their weapons before sending an all-clear signal and "
"barely dodging an ASB shot. They then beam aboard an MFK soldier to aid in "
"your journey."

#: src-en/data/events_special_guards.xml.append:720
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"fr_unique_vance_one\"]/text"
msgstr "(Vance Prime) \"Halt, soldier! Stand down, and allow us to pass!\""

#: src-en/data/events_special_guards.xml.append:722
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"fr_unique_vance_one\"]/event/text"
msgstr ""
"The MFK Ace guard blnks before shouting \"ONE?! What the hell are you doing "
"here?! I don't care if this will get me court-martialialed; we won't let you"
" pass after everything you have done!\""

#: src-en/data/events_special_guards.xml.append:725
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"fr_unique_vance_one\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:731
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_cyra\"]/text"
msgstr ""
"(Cyra) \"Halt, brave soldier! This ship is under the command of an MFK Ace! "
"Unpower your weapons immediately!\""

#: src-en/data/events_special_guards.xml.append:733
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_cyra\"]/event/text"
msgstr ""
"The MFK Ace guard is shocked to see Cyra and hastely powers down their "
"weapons and artillery \"My mistake ma'am! We are sending all the supplies we"
" can spare as an apology for our brash behaviour!\" The guard dispatches a "
"few crates of supplies before turning their attention back to the Coalition "
"fleet."

#: src-en/data/events_special_guards.xml.append:738
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"human_mfk\"]/text"
msgstr "(MFK Ace Crew) Have the MFK convince them to let you through."

#: src-en/data/events_special_guards.xml.append:740
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"human_mfk\"]/event/text"
msgstr ""
"\"Ah, working undercover are you? Smart, I'm sure whatever mission you were "
"given will be a glorious victory for the Rebellion!\" The MFK Ace guard "
"laughs and sends some supplies to aid you before turning their atention back"
" to the invading Coalition."

#: src-en/data/events_special_guards.xml.append:745
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"LIST_CREW_JERRY\"]/text"
msgstr "(Jerry) \"Hello!\""

#: src-en/data/events_special_guards.xml.append:751
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"REBEL_ID\"]/text"
msgstr "(Forged Identification) Try to pass your ship for a rebel one"

#: src-en/data/events_special_guards.xml.append:753
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"REBEL_ID\"]/event/text"
msgstr ""
"\"You... you really think I would fall for that? Wow...\" The MFK Ace guard "
"ends the call and moves in to attack."

#: src-en/data/events_special_guards.xml.append:756
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"REBEL_ID\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:762
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_nights\"]/text"
msgstr "(Nights) Nights has something to say."

#: src-en/data/events_special_guards.xml.append:764
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_nights\"]/event/text"
msgstr ""
"Nights chuckles, taking another swig of his beer. \"Tell me...How do you expect to beat ussss without your fancy artillery?\" He presses a big red button on a strange remote he carries behind his back.\n"
"\n"
"\t\t\t\t\t\"What? What are you talking about, you drunken slug?\" The guard asks confused before a giant explosion cuts the call, with Nights cackling drunkely as the enemy's artilery is disabled temporarily."

#: src-en/data/events_special_guards.xml.append:770
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_REBEL\"]/choice/event/choice[@req=\"unique_nights\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:791
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_SIGNAL\"]/text"
msgstr ""
"It appears the guard ship is sending out a distress signal to a nearby ASB "
"platform! Brace for impact!"

#: src-en/data/events_special_guards.xml.append:793
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/text"
msgstr "(Signal Diluter) Jam their signal."

#: src-en/data/events_special_guards.xml.append:795
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/event/text"
msgstr ""
"When no ASB activates, you assume that is a good sign that your augment has "
"functioned properly, and you continue to fight."

#: src-en/data/events_special_guards.xml.append:799
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_SIGNAL\"]/choice[2]/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:801
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_SIGNAL\"]/choice[2]/event/text"
msgstr ""
"Suddenly you detect a shift in the Coalition fleet in the distance, its guns"
" now pointing at the MFK Ace guard!"

#: src-en/data/events_special_guards.xml.append:809
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_DESTROY\"]/text"
msgstr ""
"You have defeated the MFK Ace guard. Whatever might have been in their cargo"
" has for certain been destroyed, but you can at least salvage some supplies "
"from the ship."

#: src-en/data/events_special_guards.xml.append:812
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_DESTROY\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:817
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_DEADCREW\"]/text"
msgstr ""
"You have defeated the MFK Ace guard. Without crew on board to stop you, you "
"can investigate their cargo. You find a Federation operative detained in "
"their cargo-bay who you rescue, and move on to scrap their hull."

#: src-en/data/events_special_guards.xml.append:821
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_DEADCREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:829
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_FOLLOWUP\"]/text"
msgstr ""
"By killing the Rebel guard, you have no doubt caused them to dispatch "
"reinforcements to track you down. Watch your step as you explore the sector."
" Though with how chaotic this sector is, there's a chance the forces here "
"will be too busy to deal with you."

#: src-en/data/events_special_guards.xml.append:838
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_FOLLOWUP\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:842
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_FOLLOWUP\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:850
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:851
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:852
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:854
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_REBEL\"]/text"
msgstr ""
"An Elite Rebel ship comes barreling towards you, its entire array of weapons ready to go. You assume this must be the ship sent by the guard to hunt you down and prepare to defend your ship.\n"
"\n"
"\tHowever, before the fight can truly start, you detect that the Federation fleet in the distance has also turned its guns on the rebel ship. It's an all-out brawl now!"

#: src-en/data/events_special_guards.xml.append:863
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_REBEL\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:872
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:873
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:874
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_REBEL\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:876
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_REBEL\"]/text"
msgstr ""
"An MFK Ace ship comes barreling towards you, its entire array of weapons ready to go. You assume this must be the ship sent by the guard to hunt you down and prepare to defend your ship.\n"
"\n"
"\tHowever, before the fight can truly start, you detect that the Federation fleet in the distance has also turned its guns on the rebel ship. It's an all-out brawl now!"

#: src-en/data/events_special_guards.xml.append:887
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_REBEL\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:899
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION\"]/text"
msgstr ""
"This sector would have once been a safe haven for you and your crew, but "
"ever since the Rebel attack and the sequential Coalition invasion, this "
"sector has become a no man's land. If that wasn't bad enough, pirates have "
"also been drawn into this place hoping to score easy scrap. Watch your step "
"and always be on guard."

#: src-en/data/events_special_guards.xml.append:907
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:911
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"3\"]/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:917
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/text"
msgstr ""
"By some miracle the Federation forces in this sector managed to weather the "
"attacks from the Rebels and the Coalition enough to still have a elite guard"
" present. Their weapons power on for a moment before they realize you aren't"
" a threat \"I'm sorry, renegade, we have all been on edge since the invasion"
" started. We are short on manpower and ships but we do have a surpluss of "
"weapons, if you are interested of course. Otherwise we can repair or refuel "
"your ship.\""

#: src-en/data/events_special_guards.xml.append:919
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[1]/text"
msgstr "Request support."

#: src-en/data/events_special_guards.xml.append:923
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[2]/text"
msgstr "Attack the guard."

#: src-en/data/events_special_guards.xml.append:925
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[2]/event/text"
msgstr ""
"The guard's captain is shocked that you've turned on them. \"I knew "
"something was fishy about you! We won't let you step any further, you maniac"
" renegade!\""

#: src-en/data/events_special_guards.xml.append:928
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[2]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:934
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[3]/text"
msgstr "Ignore the guard."

#: src-en/data/events_special_guards.xml.append:936
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[3]/event/text"
msgstr "You now have some time to do something on the ship."

#: src-en/data/events_special_guards.xml.append:938
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[3]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:942
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY\"]/choice[3]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:950
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/text"
msgstr ""
"The guard puts you on a secure line with one of the few surviving nearby "
"support ships, who awaits your command."

#: src-en/data/events_special_guards.xml.append:952
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_tully\"]/text"
msgstr "(Tully) Request support."

#: src-en/data/events_special_guards.xml.append:954
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_tully\"]/event/text"
msgstr ""
"The guard looks surprised. \"Admiral Tully? What are you doing here?! This "
"is an active warzone! Never mind, we'll give you everything we can possibly "
"spare!\""

#: src-en/data/events_special_guards.xml.append:964
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_turzil\"]/text"
msgstr "(Turzil) Request support."

#: src-en/data/events_special_guards.xml.append:966
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_turzil\"]/event/text"
msgstr ""
"The guard smiles at seeing the Engi Brigade Leader. \"Turzil, it's good to "
"see a friendly face in our time of need. We hope your strategic mind can "
"help us turn the tide of this battle just like it did back in first civil "
"war! We'll give what we can.\""

#: src-en/data/events_special_guards.xml.append:976
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_mafan\"]/text"
msgstr "(Mafan) Request support."

#: src-en/data/events_special_guards.xml.append:978
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_mafan\"]/event/text"
msgstr ""
"It takes the guard a moment to register who is in front of him. \"Doctor, "
"you have business in this sector? Please watch your step though, danger "
"lurks around every corner here.\""

#: src-en/data/events_special_guards.xml.append:988
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_tyerel\"]/text"
msgstr "(Ty E'rel) Request support."

#: src-en/data/events_special_guards.xml.append:990
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_tyerel\"]/event/text"
msgstr ""
"The guard nods. \"Of course, Ambassador. We'll send over whatever you need. "
"I do hope your ship is well equiped however, a silver tongue won't do much "
"good in this place...\""

#: src-en/data/events_special_guards.xml.append:1000
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_ruwen\"]/text"
msgstr "(Ruwen) Request support."

#: src-en/data/events_special_guards.xml.append:1002
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[@req=\"unique_ruwen\"]/event/text"
msgstr ""
"The guard nods. \"Of course, Ambassador. We'll send over whatever you need. "
"I do hope your ship is well equiped however, a silver tongue won't do much "
"good in this place...\""

#: src-en/data/events_special_guards.xml.append:1012
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[6]/text"
msgstr "Weapons."

#: src-en/data/events_special_guards.xml.append:1014
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[6]/event/text"
msgstr ""
"A resupply drone is dispatched to resupply your ship with a brand new "
"weapon."

#: src-en/data/events_special_guards.xml.append:1019
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[7]/text"
msgstr "Drone."

#: src-en/data/events_special_guards.xml.append:1021
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_FEDERATION_FRIENDLY_SUPPORT\"]/choice[7]/event/text"
msgstr ""
"A resupply drone is dispatched to resupply your ship with a brand new drone."

