#: src-en/data/events_special_guards.xml.append:1113
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_DEADCREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:1121
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_FOLLOWUP\"]/text"
msgstr ""
"By killing the Federation guard, you have no doubt caused them to dispatch "
"reinforcements to track you down. Watch your step as you explore the sector."
" Though with how chaotic this sector is, there's a chance the forces here "
"will be too busy to deal with you."

#: src-en/data/events_special_guards.xml.append:1130
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_FOLLOWUP\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:1134
