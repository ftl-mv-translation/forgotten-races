#: src-en/data/events_special_guards.xml.append:1093
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_SIGNAL\"]/choice[2]/event/text"
msgstr ""
"Suddenly you detect a shift in the Coalition and MFK fleets in the distance,"
" its guns now pointing at the Federation guard!"

#: src-en/data/events_special_guards.xml.append:1101
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_DESTROY\"]/text"
msgstr ""
"You have defeated the Federation guard. Whatever might have been in their "
"cargo has for certain been destroyed, but you can at least salvage some "
"supplies from the ship."

#: src-en/data/events_special_guards.xml.append:1104
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_DESTROY\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:1109
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_FEDERATION_DEADCREW\"]/text"
msgstr ""
"You have defeated the Federation guard. Without crew on board to stop you, "
