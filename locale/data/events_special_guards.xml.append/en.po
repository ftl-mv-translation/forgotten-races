#: src-en/data/events_special_guards.xml.append:1378
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_REINFORCEMENTS_WARZONE_PIRATE\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:1379
