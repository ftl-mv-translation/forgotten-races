"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[5]/event[1]/text"
msgstr "\"What? You think we are idiots? Your ID's fake!\""

#: src-en/data/events_special_fleet.xml.append:77
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
