#: src-en/data/events_special_fleet.xml.append:299
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FLEET_CHAOS\"]/mod-"
"append:choice[5]/event/text"
msgstr ""
"As you hand over your ID, the gnome screeches, transforming the data on your"
" card into a number of cognito-hazardous symbols. The Rebel slumps back, "
"their eyes completely black, leaking gallons of blood from their mouth as "
"the other horrified Rebels move into combat position!"

