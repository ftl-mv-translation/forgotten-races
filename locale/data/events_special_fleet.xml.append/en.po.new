#: src-en/data/events_special_fleet.xml.append:5
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halt, soldier! This is Vance Prime! Stand down, power off "
"your weapons!\""

#: src-en/data/events_special_fleet.xml.append:7
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[1]/text"
msgstr ""
"\"It's an honor to meet you, sir! Yes, we will stand down at your order!\""

#: src-en/data/events_special_fleet.xml.append:13
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[2]/text"
msgstr ""
"\"Vance Prime! Sir, it's an honor to meet you! We are short on supplies, but"
" we do have one too many bodies onboard!\" The Rebel offers to join your "
"crew."

#: src-en/data/events_special_fleet.xml.append:19
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[3]/text"
msgstr ""
"The Rebel captain can't believe their eyes when they see that your ship "
"carries the one and only Vance Prime! They quickly apologize and promise to "
"delay the fleet as much as they can before jumping away."

#: src-en/data/events_special_fleet.xml.append:26
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[4]/text"
msgstr "\"We know what you did, Prime! No mercy for traitors!\""

#: src-en/data/events_special_fleet.xml.append:29
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[4]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_fleet.xml.append:35
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[2]/text"
msgstr ""
"The fleet is now aware of Vance Prime's betrayal, and will not send any "
"soldiers to you who will listen."

#: src-en/data/events_special_fleet.xml.append:39
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[3]/text"
msgstr ""
"The fleet is now only made up of MFK sympathizers, refusing to even "
"entertain talking to Vance One."

