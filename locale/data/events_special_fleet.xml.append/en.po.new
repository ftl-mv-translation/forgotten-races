#: src-en/data/events_special_fleet.xml.append:269
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FLEET_CHAOS\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halt, soldier! This is Vance Prime! Stand down, power off "
"your weapons!\""

#: src-en/data/events_special_fleet.xml.append:271
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FLEET_CHAOS\"]/mod-"
"append:choice[1]/event/text"
msgstr ""
"As Vance attempts to hail the fleet, the gnome begins to screech, attempting"
" to drown out your comms. Without missing a beat, the Admiral punts the "
"gnome into the corner, causing it to shut up for now, and demands the fleet "
"let you pass."

#: src-en/data/events_special_fleet.xml.append:279
msgid ""
"data/events_special_fleet.xml.append$//mod:findName[@name=\"FLEET_CHAOS\"]/mod-"
"append:choice[2]/text"
msgstr ""
"The gnome appears to be jamming your comms. You can't contact the fleet."

