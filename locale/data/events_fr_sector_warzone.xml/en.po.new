msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_COALITION\"]/text"
msgstr ""
"A nearby Federation store is under fire by a R.U.E.S. vessel. Their defenses"
" are quickly crumbling; they won't last much longer without your help!"

#: src-en/data/events_fr_sector_warzone.xml:606
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_COALITION\"]/choice[1]/text"
msgstr "Rescue the store."

#: src-en/data/events_fr_sector_warzone.xml:608
