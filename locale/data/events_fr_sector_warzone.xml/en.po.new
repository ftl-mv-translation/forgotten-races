#: src-en/data/events_fr_sector_warzone.xml:715
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DESTROYED_FEDERATION_STATION_ELITE\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:717
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DESTROYED_FEDERATION_STATION_ELITE\"]/choice/event/text"
msgstr ""
"It seems that the cargo of the Elite Federation station survived the fight. "
"Inside is a functional weapon, which you bring back on board."

#: src-en/data/events_fr_sector_warzone.xml:728
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/text"
msgstr ""
"A nearby Elite Federation outpost is surprisingly still open for business, "
"despite the fact that it's in the middle of this warzone. The fleet is "
"problably giving them enough protection to not be on full lockdown."

#: src-en/data/events_fr_sector_warzone.xml:732
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/text"
msgstr "See what they're offering."

#: src-en/data/events_fr_sector_warzone.xml:734
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/text"
msgstr ""
"Before you shop, you still have some time to do something else aboard the "
"ship."

#: src-en/data/events_fr_sector_warzone.xml:737
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:741
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:747
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/text"
msgstr "See what they're offering."

#: src-en/data/events_fr_sector_warzone.xml:749
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/event/text"
msgstr ""
"As you attempt to dock onto the station, your sensors notice its weapons "
"have suddenly gone online! \"We've heard about all your misdeeds, Renegade! "
"We won't let you make our job harder than it already is!\""

#: src-en/data/events_fr_sector_warzone.xml:752
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:758
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"LIST_CREW_FEDERATION_ELITE_EASTER\"]/text"
msgstr "(Elite Federation Crew) Request military supplies."

#: src-en/data/events_fr_sector_warzone.xml:760
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"LIST_CREW_FEDERATION_ELITE_EASTER\"]/event/text"
msgstr ""
"\"A Federation soldier! You must be a very important vessel! Since we have a"
" surplus of weapons, we will gladly give you one as a token of graditude.\""

#: src-en/data/events_fr_sector_warzone.xml:765
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"LIST_CREW_FEDERATION_ELITE_EASTER\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:769
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"LIST_CREW_FEDERATION_ELITE_EASTER\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:775
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"unique_tully\"]/text"
msgstr "(Tully) Request military supplies."

#: src-en/data/events_fr_sector_warzone.xml:777
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"unique_tully\"]/event/text"
msgstr ""
"\"Admiral Tully? It's an honor to finally meet you! Please, have this weapon"
" as a gift and feel free to peruse our store!\""

#: src-en/data/events_fr_sector_warzone.xml:782
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"unique_tully\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:786
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[@req=\"unique_tully\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:792
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[5]/text"
msgstr "Attack the station!"

#: src-en/data/events_fr_sector_warzone.xml:794
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[5]/event/text"
msgstr ""
"Nothing will stop you from being a merciless ravager of all you come across."
" Hopefully you didn't pick a fight you can't win."

#: src-en/data/events_fr_sector_warzone.xml:797
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION\"]/choice[5]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:806
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/text"
msgstr ""
"\"Alright! We get it, you are very tough! We will let you trade just do it "
"quickly!\""

#: src-en/data/events_fr_sector_warzone.xml:808
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/text"
msgstr "Stop firing and trade."

#: src-en/data/events_fr_sector_warzone.xml:810
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/event/text"
msgstr ""
"The R.U.E.S. station powers its weapons off. You're worried this is some "
"kind of trap, but you are too far to back off now."

#: src-en/data/events_fr_sector_warzone.xml:815
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:817
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/event/choice/event/text"
msgstr ""
"Before you shop, you still have some time to do something else aboard the "
"ship."

#: src-en/data/events_fr_sector_warzone.xml:820
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/event/choice/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:824
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[1]/event/choice/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:832
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_COALITION\"]/surrender/choice[2]/text"
msgstr "Refuse and finish the station off."

#: src-en/data/events_fr_sector_warzone.xml:845
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/text"
msgstr ""
"Looks like the Coalition built an elite forward outpost in this beacon, "
"probably to support their offensive into this sector. Security is tight, "
"with R.U.E.S. fleets all around the station. Maybe you could pass the ship "
"off as a Coalition spy if you have the right crew?"

#: src-en/data/events_fr_sector_warzone.xml:849
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"FR_LIST_CREW_RUES\"]/text"
msgstr "(R.U.E.S. Elite Crew) Gain access."

#: src-en/data/events_fr_sector_warzone.xml:851
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"FR_LIST_CREW_RUES\"]/event/text"
msgstr ""
"Your crew has to work overtime to convince the guards, but eventually they "
"allow you in."

#: src-en/data/events_fr_sector_warzone.xml:854
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"FR_LIST_CREW_RUES\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:858
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"FR_LIST_CREW_RUES\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:864
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"fr_unique_mantis_queen\"]/text"
msgstr "(Leikonpliiinakra) Leikonpliiinakra demands access!"

#: src-en/data/events_fr_sector_warzone.xml:866
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"fr_unique_mantis_queen\"]/event/text"
msgstr ""
"\"Coalition outpost, I demand access to your store as well as a parting gift in the form of a weapon. This is an order.\"\n"
"\t\t\t\t\n"
"Whoever is in charge of the outpost scrambles to attention at the sight of the Queen. \"O-Of course, your highness! Right this way!\" The station leader allows you to shop in their outpost and then gifts you the weapon as ordered."

#: src-en/data/events_fr_sector_warzone.xml:873
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"fr_unique_mantis_queen\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:877
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"fr_unique_mantis_queen\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:883
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_nights\"]/text"
msgstr "(Nights) Nights demands access!"

#: src-en/data/events_fr_sector_warzone.xml:885
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_nights\"]/event/text"
msgstr ""
"\"Hey you sssslime bagssss! Let ussss sssshop in your sssstupid outposssst! And give ussss a new weapon too!\"\n"
"\n"
"The leader of the outpost freezes for a moment, \"Very well, Captain. You may dock your ship.\" The station leader allows you to shop in their outpost and then gifts you the weapon as ordered."

#: src-en/data/events_fr_sector_warzone.xml:892
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_nights\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:896
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_nights\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:902
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_tyrdeo\"]/text"
msgstr "(Tyrdeo) Ask for access."

#: src-en/data/events_fr_sector_warzone.xml:904
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_tyrdeo\"]/event/text"
msgstr ""
"\"Excuse me, but I'm Tyrdeo, the President of the Republic. As one of the leaders of the Coalition, I ask that you allow me and my crew to shop in this establishment. Also, as I'm sure you have heard, leaders of the Coalition are entitled to one free weapon in any Coalition outpost.\"\n"
"\n"
"The leader of the outpost tilts their head for a moment before shrugging. \"Very well, President. You may dock your ship.\" The station leader allows you to shop in their outpost and then gifts you the weapon as ordered."

#: src-en/data/events_fr_sector_warzone.xml:911
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_tyrdeo\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:915
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"unique_tyrdeo\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:921
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/text"
msgstr ""
"Fight the outpost; maybe they will respect your strength and let you trade?"

#: src-en/data/events_fr_sector_warzone.xml:923
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/event/text"
msgstr ""
"You prepare to fight the outpost. As expected, they send out a request for "
"ASB backup from the nearby fleet."

#: src-en/data/events_fr_sector_warzone.xml:928
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/event/choice[@req=\"PDS_DISABLE\"]/text"
msgstr "(Signal Diluter) Jam their signal."

#: src-en/data/events_fr_sector_warzone.xml:930
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/event/choice[@req=\"PDS_DISABLE\"]/event/text"
msgstr ""
"When no ASB activates, you assume that it's a good sign that your augment "
"has functioned properly, and you continue to fight."

#: src-en/data/events_fr_sector_warzone.xml:933
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/event/choice[@req=\"PDS_DISABLE\"]/event/choice/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:939
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[5]/event/choice[2]/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:945
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[6]/text"
msgstr "We can't do anything here."

#: src-en/data/events_fr_sector_warzone.xml:947
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[6]/event/text"
msgstr ""
"It's a total waste, but you don't have anything to sneak in, and attacking "
"the outpost would be too risky with the fleet surrounding it."

#: src-en/data/events_fr_sector_warzone.xml:949
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[6]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:953
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[6]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:963
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_REBEL\"]/destroyed/text"
msgstr ""
"The outpost has been destroyed. While there are plenty of supplies left "
"behind from the wreck itself, any extra supplies in its cargo have surely "
"been destroyed."

#: src-en/data/events_fr_sector_warzone.xml:967
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_REBEL\"]/deadCrew/text"
msgstr ""
"The crew of the outpost have been eliminated. You scrap the ship's exterior "
"before investigating inside."

#: src-en/data/events_fr_sector_warzone.xml:970
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_REBEL\"]/deadCrew/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:972
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_REBEL\"]/deadCrew/choice/event/text"
msgstr ""
"Fortunately, it appears the Rebels had a good supply of resources saved up, "
"all of which now belong to you."

#: src-en/data/events_fr_sector_warzone.xml:988
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/text"
msgstr ""
"It seems the Rebels are eager to make themselves at home in this sector. A "
"trading outpost has already been established at the beacon, probably to "
"serve as a checkpoint for passing Rebel ships as well as the fleet that "
"surrounds it. Realistically, only an elite rebel crew would get anywhere "
"with them."

#: src-en/data/events_fr_sector_warzone.xml:992
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_technician\"]/text"
msgstr "(Technician) Pretend to be a Rebel vessel."

#: src-en/data/events_fr_sector_warzone.xml:994
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_technician\"]/event/text"
msgstr ""
"Your Technician manages to fake it well enough for the outpost to believe "
"your lie. They let you trade as well as give you some supplies."

#: src-en/data/events_fr_sector_warzone.xml:998
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_technician\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1002
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_technician\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1008
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_mfk\"]/text"
msgstr "(MFK Ace Crew) Pretend to be a Rebel vessel."

#: src-en/data/events_fr_sector_warzone.xml:1010
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_mfk\"]/event/text"
msgstr ""
"Your MFK Ace manages to fake it well enough for the outpost to believe your "
"lie. They let you trade as well as give you some supplies."

#: src-en/data/events_fr_sector_warzone.xml:1014
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_mfk\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1018
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"human_mfk\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1024
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"unique_vance\"]/text"
msgstr ""
"(Vance Prime) \"Hail, loyal soldier! Allow us to dock and shop, this is an "
"order!\""

#: src-en/data/events_fr_sector_warzone.xml:1026
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"unique_vance\"]/event/text"
msgstr ""
"\"O-Oh shit! Of course sir! Right this way!\" The soldiers in the station "
"all scramble to get the outpost ready for their leader. One of the MFK Aces "
"even offers to join your ship."

#: src-en/data/events_fr_sector_warzone.xml:1030
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"unique_vance\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1034
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"unique_vance\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1040
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"fr_unique_vance_one\"]/text"
msgstr ""
"(Vance One) \"Hail, soldier! Allow us to dock and shop, this is an order!\""

#: src-en/data/events_fr_sector_warzone.xml:1042
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"fr_unique_vance_one\"]/event/text"
msgstr ""
"The MFK Ace soldier in charge of communications blnks before shouting, "
"\"ONE?! What the hell are you doing here?! Whatever your plan is, we won't "
"allow it to happen! Fellas, to your battle stations! We have a rat to "
"squish!\" The outpost goes hostile and refuse any more hails."

#: src-en/data/events_fr_sector_warzone.xml:1044
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[@req=\"fr_unique_vance_one\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1050
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[5]/text"
msgstr "Attack the station; maybe they have backup supplies!"

#: src-en/data/events_fr_sector_warzone.xml:1052
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[5]/event/text"
msgstr "You power up the weapons and engage the outpost."

#: src-en/data/events_fr_sector_warzone.xml:1055
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[5]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1061
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[6]/text"
msgstr "Ignore the outpost."

#: src-en/data/events_fr_sector_warzone.xml:1063
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[6]/event/text"
msgstr ""
"You fly past the outpost, deciding not to start more conflict in this "
"already hostile sector."

#: src-en/data/events_fr_sector_warzone.xml:1065
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[6]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1069
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_REBEL\"]/choice[6]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1079
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_PIRATE\"]/destroyed/text"
msgstr ""
"No matter how influential they were, at the end of the day they were still "
"pirates. As you watch their ill-gotten station crumble to dust, you breath a"
" sigh of relief that they won't make this sector even more of a hellish "
"place."

#: src-en/data/events_fr_sector_warzone.xml:1083
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_STATION_PIRATE\"]/deadCrew/text"
msgstr ""
"Not even the toughest pirates can stop you now. That's one less plague to "
"torment this sector."

#: src-en/data/events_fr_sector_warzone.xml:1096
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/text"
msgstr ""
"It seems even this battle-ravaged place isn't safe from piracy. A group of very influential and wealthy pirates decided to set up a black market store in this sector, potentially hoping to score some easy sales or salvage from damaged vessels. These pirates don't seem like the usual lot either, so be careful when dealing with them.\n"
"\n"
"As you approach the station you see what appears to be a pirate fleet. How those unaffiliated pirates even managed to steal multiple fleet ships is beyond you, but you doubt they are just for show."

#: src-en/data/events_fr_sector_warzone.xml:1102
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[1]/text"
msgstr "Go shop at the market."

#: src-en/data/events_fr_sector_warzone.xml:1104
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[1]/event/text"
msgstr ""
"Some elite smugglers welcome you inside and offer some less-than-legal "
"services and goods."

#: src-en/data/events_fr_sector_warzone.xml:1107
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[1]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1111
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[1]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1117
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"human_angel\"]/text"
msgstr "(Angel Crew) Demand tribute."

#: src-en/data/events_fr_sector_warzone.xml:1119
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"human_angel\"]/event/text"
msgstr ""
"The pirates immediately notice your Angel crew, with the leader of the store"
" hailing you, \"Well well well, what do we have here? One of Vael's top "
"brass? Now, we wouldn't want to pick a fight with him, so about we give you "
"a little something something and you keep anything that you see here to "
"yourself?\""

#: src-en/data/events_fr_sector_warzone.xml:1123
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"human_angel\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1127
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"human_angel\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1133
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"fr_unique_purple_beard\"]/text"
msgstr "(Purple Beard) Demand tribute."

#: src-en/data/events_fr_sector_warzone.xml:1135
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"fr_unique_purple_beard\"]/event/text"
msgstr ""
"The pirates immediately notice the pirate leader as soon as he enters the "
"view of the feed, with the leader of the store hailing you, \"Well turn me "
"sideways and call me porky! If it isn't the legendary Purple Beard himself! "
"Didn't know we were in the presence of legends! Let me be your own personal "
"tour guide of our little 'fixer-upper', and please, have this little gift, "
"as a little gift between fellow pirates.\""

#: src-en/data/events_fr_sector_warzone.xml:1139
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"fr_unique_purple_beard\"]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1143
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[@req=\"fr_unique_purple_beard\"]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1149
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[4]/text"
msgstr "Attack the pirates!"

#: src-en/data/events_fr_sector_warzone.xml:1151
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[4]/event/text"
msgstr ""
"These scum are still outlaws, regardless if they're running a market or not."
" Time to bring their villainy to an end."

#: src-en/data/events_fr_sector_warzone.xml:1154
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[4]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1160
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[5]/text"
msgstr "Ignore the market."

#: src-en/data/events_fr_sector_warzone.xml:1162
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[5]/event/text"
msgstr "You aren't looking to make any black market deals."

#: src-en/data/events_fr_sector_warzone.xml:1164
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[5]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1168
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_PIRATE\"]/choice[5]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1198
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/text"
msgstr ""
"An Elite Federation ship hails you. \"Renegade! This sector is crawling with"
" people who want us dead. In times like these, we must look out for each "
"other. We have an extra weapon that we picked up from an MFK Ace ship a few "
"jumps back; we have no use for it, so you might as well have it.\""

#: src-en/data/events_fr_sector_warzone.xml:1202
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/text"
msgstr "Accept."

#: src-en/data/events_fr_sector_warzone.xml:1204
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/text"
msgstr ""
"The Federation captain smiles and sends over the weapon alongside a small "
"package of resources."

#: src-en/data/events_fr_sector_warzone.xml:1210
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/text"
msgstr "Accept."

#: src-en/data/events_fr_sector_warzone.xml:1212
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/event/text"
msgstr ""
"The Federation captain is about to send over the weapon when they realize "
"who you are. \"Wait a moment! You are that blasted renegade that has been "
"causing us problems ever since you arrived here! Scum like you deserve only "
"death!\""

#: src-en/data/events_fr_sector_warzone.xml:1215
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"2\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1221
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[3]/text"
msgstr "Attack the Federation ship!"

#: src-en/data/events_fr_sector_warzone.xml:1223
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[3]/event/text"
msgstr ""
"The captain is shocked by your sudden betrayal. \"Turncoats! I should have "
"known your kind isn't to be trusted!\""

#: src-en/data/events_fr_sector_warzone.xml:1226
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[3]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1232
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[4]/text"
msgstr "Reject their offer."

#: src-en/data/events_fr_sector_warzone.xml:1234
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[4]/event/text"
msgstr ""
"You thank the captain and assure them that you are well-equipped enough for "
"the sector. The captain is confused but accepts your choice either way."

#: src-en/data/events_fr_sector_warzone.xml:1236
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[4]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1240
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[4]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1249
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/text"
msgstr ""
"This beacon appears to have been the place of a massive skirmish between all"
" three factions, with wrecks scattered all around it. A few of these wrecks "
"haven't been picked apart by pirates yet, though it's only a matter of time "
"before they come back for the rest. You have enough time to salvage one ship"
" before said pirates arrive."

#: src-en/data/events_fr_sector_warzone.xml:1252
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[1]/text"
msgstr "Salvage the Federation wreck."

#: src-en/data/events_fr_sector_warzone.xml:1254
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[1]/event/text"
msgstr ""
"You quickly salvage the Unity ship. It's a shame that something with so much"
" potential had to meet such a grim fate. To your surprise, inside the ship "
"you find a survivor! They offer to join your crew after you rescue them."

#: src-en/data/events_fr_sector_warzone.xml:1260
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[2]/text"
msgstr "Salvage the Rebel wreck."

#: src-en/data/events_fr_sector_warzone.xml:1262
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[2]/event/text"
msgstr ""
"You quickly salvage the MFK Ace ship. It seems like Vance's big scary fleet "
"isn't as powerful as you thought. Inside the ship you find a strange laser "
"weapon. You don't know where it came from or how the Rebels got it, but it "
"seems to be really powerful."

#: src-en/data/events_fr_sector_warzone.xml:1268
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[3]/text"
msgstr "Salvage the Coalition wreck."

#: src-en/data/events_fr_sector_warzone.xml:1270
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[3]/event/text"
msgstr ""
"You quickly salvage the R.U.E.S. ship. The Coalition is very protective of "
"their elite ships, only deploying them against very high value targets. "
"Inside the ship you find a modular version of one of their signature "
"augments which can be installed and uninstalled on the go."

#: src-en/data/events_fr_sector_warzone.xml:1276
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[4]/text"
msgstr "Don't salvage any."

#: src-en/data/events_fr_sector_warzone.xml:1278
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[4]/event/text"
msgstr ""
"The chances of something going wrong are too high to risk salvage random "
"wrecks."

#: src-en/data/events_fr_sector_warzone.xml:1280
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[4]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1284
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_DEBRIS\"]/choice[4]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1303
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/text"
msgstr ""
"A elite pirate seems to have set up shop on this beacon. They hail you and "
"offer you a random power-efficient weapon for a heavy discount. The catch is"
" that you won't know what it is until you buy it. In the background, you "
"also see what appears to be a pirate fleet, problably taking this "
"opportunity to get easy tribute."

#: src-en/data/events_fr_sector_warzone.xml:1307
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[1]/text"
msgstr "Buy the Weapon."

#: src-en/data/events_fr_sector_warzone.xml:1309
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[1]/event/text"
msgstr ""
"The pirate transfers a crate containing the weapon as soon as they validate "
"your purchase. You worry you might have been dupped but thankfully this "
"pirate was an honorable one all along."

#: src-en/data/events_fr_sector_warzone.xml:1317
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[2]/text"
msgstr "Attack the pirate!"

#: src-en/data/events_fr_sector_warzone.xml:1319
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[2]/event/text"
msgstr ""
"The pirate isn't surprised by your action, as it seems they already powered "
"their weapons before you even finished powering yours."

#: src-en/data/events_fr_sector_warzone.xml:1322
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[2]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1328
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[3]/text"
msgstr "Don't buy anything."

#: src-en/data/events_fr_sector_warzone.xml:1330
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[3]/event/text"
msgstr ""
"The pirate is slightly offended by your rejection of their deal, but they "
"aren't reckless enough to attack you for it."

#: src-en/data/events_fr_sector_warzone.xml:1332
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[3]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1336
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_PIRATE_TRADE\"]/choice[3]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1350
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/text"
msgstr ""
"A Federation Auto ship seems to have been deployed in this sector as a way "
"to help on the war effort, offering a combo of resources and repair for free"
" to Federation allies."

#: src-en/data/events_fr_sector_warzone.xml:1354
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[1]/text"
msgstr "Accept the Help."

#: src-en/data/events_fr_sector_warzone.xml:1356
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[1]/event/text"
msgstr ""
"The auto quickly transfers over a crate with the supplies before "
"effortlessly repairing your ship completely."

#: src-en/data/events_fr_sector_warzone.xml:1366
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[2]/text"
msgstr "Accept the Help."

#: src-en/data/events_fr_sector_warzone.xml:1368
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[2]/event/text"
msgstr ""
"The autoship scans your ship before quickly powering on its weapons. Seems "
"like your notoriety preceeds you."

#: src-en/data/events_fr_sector_warzone.xml:1371
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[2]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1377
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[3]/text"
msgstr "Attack the auto!"

#: src-en/data/events_fr_sector_warzone.xml:1379
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[3]/event/text"
msgstr ""
"The auto ship quickly reacts to your aggression and powers its weapons."

#: src-en/data/events_fr_sector_warzone.xml:1382
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[3]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1388
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[4]/text"
msgstr "Refuse the help."

#: src-en/data/events_fr_sector_warzone.xml:1390
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[4]/event/text"
msgstr ""
"The auto simply ends its transmission and moves on to find another ship to "
"help."

#: src-en/data/events_fr_sector_warzone.xml:1392
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[4]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1396
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_AUTO_REPAIR\"]/choice[4]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1404
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/text"
msgstr ""
"This beacon seems really uneventful until you detect a a hail from a nearby "
"Lanius shuttle. \"Seek metal. Ship too small to hold metal. Join crew?\"."

#: src-en/data/events_fr_sector_warzone.xml:1406
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[1]/text"
msgstr "Allow the Lanius to join your crew."

#: src-en/data/events_fr_sector_warzone.xml:1408
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[1]/event/text"
msgstr ""
"The Lanius is ejected from the shuttle and quickly arrives on your ship."

#: src-en/data/events_fr_sector_warzone.xml:1413
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[2]/text"
msgstr "Refuse."

#: src-en/data/events_fr_sector_warzone.xml:1415
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[2]/event/text"
msgstr ""
"The Lanius is very disappointed but they quickly jump away in search of a "
"better vessel."

#: src-en/data/events_fr_sector_warzone.xml:1417
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[2]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1421
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_LANIUS\"]/choice[2]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1429
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/text"
msgstr ""
"From the beacon, you can spot several large masses. Among them are two "
"gigantic fields of debris, filled with the wrecks of all sorts of factions. "
"You could salvage ships in this beacon but there's no telling what you will "
"find."

#: src-en/data/events_fr_sector_warzone.xml:1431
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/choice[1]/text"
msgstr "Explore the pile of metallic debris."

#: src-en/data/events_fr_sector_warzone.xml:1435
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/choice[2]/text"
msgstr "Leave these fields alone."

#: src-en/data/events_fr_sector_warzone.xml:1437
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/choice[2]/event/text"
msgstr "You decide not to spend any time examining these fields."

#: src-en/data/events_fr_sector_warzone.xml:1439
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/choice[2]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_fr_sector_warzone.xml:1443
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_GENERIC\"]/choice[2]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_fr_sector_warzone.xml:1452
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[1]/text"
msgstr ""
"You search the debris field, but it seems like there's nothing of value "
"here. Unfortunately, the debris is both loose and densely packed, so you'll "
"have to avoid damage as you charge your FTL drive!"

#: src-en/data/events_fr_sector_warzone.xml:1456
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[2]/text"
msgstr ""
"You search the debris field. Amidst the largely worthless junk, you manage "
"to track down a hidden supply of missiles in a large pile of debris."

#: src-en/data/events_fr_sector_warzone.xml:1460
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[3]/text"
msgstr ""
"You search the debris field. While much of it is worthless junk, you manage "
"to scrounge up a small amount of useful resources."

#: src-en/data/events_fr_sector_warzone.xml:1464
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[4]/text"
msgstr ""
"You search the debris field. The material itself is mostly worthless debris,"
" but amidst the junk is a single Federation shuttle. It desperately hails "
"you. \"Please renegade, let me join your crew! This shuttle is almost out of"
" fuel and oxygen!\"."

#: src-en/data/events_fr_sector_warzone.xml:1466
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[4]/choice[1]/text"
msgstr "Accept the Federation personnel onto your crew."

#: src-en/data/events_fr_sector_warzone.xml:1468
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[4]/choice[1]/event/text"
msgstr ""
"The crew breaths a sigh of relief as they enter your ship. \"Those damn "
"Rebels attacked us when we were vulnerable, I don't think anyone else "
"survived...\""

#: src-en/data/events_fr_sector_warzone.xml:1473
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[4]/choice[2]/text"
msgstr "Ignore the shuttle."

#: src-en/data/events_fr_sector_warzone.xml:1478
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[5]/text"
msgstr ""
"You search the debris field. The material itself is mostly worthless junk, "
"but floating adrift in the field is a badly damaged Coalition scout. It "
"desperately hails you. \"Federation Renegade! If you allow me to join your "
"vessel then I will do as you order!\""

#: src-en/data/events_fr_sector_warzone.xml:1480
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[5]/choice[1]/text"
msgstr "Accept the Coalition personnel onto your crew."

#: src-en/data/events_fr_sector_warzone.xml:1482
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[5]/choice[1]/event/text"
msgstr ""
"The crew seems relieved as you let them onto your ship. \"Finally. A "
"surprisingly powerful pirate ship cornered us after the battle. They seemed "
"to deploy some strange augment before battle that made our guns refuse to "
"fire.\""

#: src-en/data/events_fr_sector_warzone.xml:1487
msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[5]/choice[2]/text"
msgstr "Ignore the scout."

#: src-en/data/events_fr_sector_warzone.xml:1512
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_REBEL_SELITE_DOGFIGHT\"]/destroyed/text"
msgstr ""
"You've destroyed the Rebel Elite's ship: no easy task. It's not enough to "
"impact the fleet, but it's still a great victory."

#: src-en/data/events_fr_sector_warzone.xml:1515
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_REBEL_SELITE_DOGFIGHT\"]/destroyed/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1517
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_REBEL_SELITE_DOGFIGHT\"]/destroyed/choice/event/text"
msgstr ""
"It seems that the cargo of the Elite Rebel ship survived the fight. Inside "
"is a functional weapon, which you bring back on board."

#: src-en/data/events_fr_sector_warzone.xml:1520
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_REBEL_SELITE_DOGFIGHT\"]/destroyed/choice/event/choice/text"
msgstr "Continue..."

