#: src-en/data/events_fr_sector_warzone.xml:657
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/deadCrew/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:674
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_REBEL\"]/text"
msgstr ""
"A nearby Federation store is under fire by an MFK Ace ship. They are trying "
"to fight back but they are getting overwhelmed quickly."

#: src-en/data/events_fr_sector_warzone.xml:679
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_REBEL\"]/choice[1]/text"
