"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/deadCrew/text"
msgstr ""
"You've wiped out the crew of the Rebel Elite: no easy task. It's not enough "
"to impact the fleet though, but it's still a great victory."

#: src-en/data/events_fr_sector_warzone.xml:652
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/deadCrew/choice/text"
