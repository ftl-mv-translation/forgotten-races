#: src-en/data/events_fr_sector_warzone.xml:1535
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_REBEL_SELITE_DOGFIGHT\"]/deadCrew/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:1550
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_ELITE_COALITION_DOGFIGHT\"]/destroyed/text"
msgstr ""
"As you watch the Coalition vessel break apart, you reflect on what a stupid "
"acronym \"R.U.E.S.\" is. Like seriously, who even came up with that?"

#: src-en/data/events_fr_sector_warzone.xml:1553
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_ELITE_COALITION_DOGFIGHT\"]/destroyed/choice/text"
