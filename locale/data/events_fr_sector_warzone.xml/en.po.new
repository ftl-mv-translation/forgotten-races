#: src-en/data/events_fr_sector_warzone.xml:642
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/destroyed/choice/event/choice/text"
