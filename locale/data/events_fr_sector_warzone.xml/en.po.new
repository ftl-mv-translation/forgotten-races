#: src-en/data/events_fr_sector_warzone.xml:634
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/destroyed/text"
msgstr ""
"You've destroyed the Rebel Elite's ship: no easy task. It's not enough to "
"impact the fleet, but it's still a great victory."

#: src-en/data/events_fr_sector_warzone.xml:637
msgid ""
"data/events_fr_sector_warzone.xml$//ship[@name=\"FR_SHIP_WARZONE_STORE_REBEL\"]/destroyed/choice/text"
