"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_REBEL\"]/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_fr_sector_warzone.xml:690
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_REBEL\"]/choice[2]/text"
