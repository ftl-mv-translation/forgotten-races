#: src-en/data/events_fr_sector_warzone.xml:2160
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DISTRESS_WARZONE_UNION_COALITION\"]/text"
msgstr ""
"You jump into this beacon to find a small Union shuttle barely managing to "
"dodge the attacks from a R.U.E.S. ship. They desperately hail and bg you to "
"help them."

#: src-en/data/events_fr_sector_warzone.xml:2163
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DISTRESS_WARZONE_UNION_COALITION\"]/choice[1]/text"
msgstr "Defend the shuttle!"

#: src-en/data/events_fr_sector_warzone.xml:2165
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DISTRESS_WARZONE_UNION_COALITION\"]/choice[1]/event/text"
msgstr ""
"The Coalition ship manages to disable the shuttle's shields, and just as "
"they are about to destroy them you manage to catch their attention. Weapons "
"up!"

#: src-en/data/events_fr_sector_warzone.xml:2168
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_DISTRESS_WARZONE_UNION_COALITION\"]/choice[1]/event/choice/text"
