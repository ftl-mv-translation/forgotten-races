"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_COALITION\"]/choice[1]/event/text"
msgstr "You prepare for combat."

#: src-en/data/events_fr_sector_warzone.xml:611
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_FEDERATION_COALITION\"]/choice[1]/event/choice/text"
