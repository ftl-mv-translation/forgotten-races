msgid ""
"data/events_fr_sector_warzone.xml$//eventList[@name=\"FR_ITEM_WARZONE_GENERIC_EXPLORE\"]/event[5]/choice[1]/text"
msgstr "Принять персонал Коалиции в свой экипаж."

#: src-en/data/events_fr_sector_warzone.xml:1482
