#: src-en/data/events_fr_sector_warzone.xml:851
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_STORE_WARZONE_COALITION\"]/choice[@req=\"FR_LIST_CREW_RUES\"]/event/text"
msgstr ""
