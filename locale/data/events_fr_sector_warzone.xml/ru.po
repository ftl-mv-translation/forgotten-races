#: src-en/data/events_fr_sector_warzone.xml:1223
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_ITEM_WARZONE_FEDERATION_GIFT\"]/choice[3]/event/text"
msgstr ""
