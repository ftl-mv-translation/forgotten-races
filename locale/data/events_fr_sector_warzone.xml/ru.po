#: src-en/data/events_fr_sector_warzone.xml:1886
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_NEUTRAL_WARZONE_COALITION_NEUTRAL\"]/choice[1]/event/text"
msgstr "Слизень ворчит и тихо ругается под нос, а затем активирует свое оружие."

#: src-en/data/events_fr_sector_warzone.xml:1889
msgid ""
"data/events_fr_sector_warzone.xml$//event[@name=\"FR_NEUTRAL_WARZONE_COALITION_NEUTRAL\"]/choice[1]/event/choice/text"
