"data/events_special_socialize.xml.append$/dummyroot/FTL/event[@name=\"FR_SOCIALIZE_LEIKONPLIIINAKRA_FREDDY_1\"]/text"
msgstr ""

#: src-en/data/events_special_socialize.xml.append:148
