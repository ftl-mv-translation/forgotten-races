"data/events_special_fleet.xml.append$//mod:findName[@name=\"FINISH_BEACON_FLEET_ELITE_FEDERATION\"]/mod-"
"append:choice[1]/event[2]/text"
msgstr ""
"\" Vance Prime ! Monsieur, c'est un honneur de vous rencontrer ! Nous sommes"
" à court de fournitures, mais nous avons un corps de trop à bord ! \" Le "
"rebelle propose de rejoindre votre équipage."

#: src-en/data/events_special_fleet.xml.append:19
