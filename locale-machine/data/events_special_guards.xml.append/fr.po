#: src-en/data/events_special_guards.xml.append:1434
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_PIRATE\"]/beaconType/visitedTooltip"
msgstr "Emplacement déjà exploré. Il n'y reste rien d'intéressant."

