"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_PIRATE\"]/choice/event/choice/event/choice[@req=\"unique_tuco\"]/event/text"
msgstr ""
"\" Ha ! Tu crois qu'une recrue comme toi peut racketter quelqu'un comme moi, le terrible pirate Tuco ? \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\" Le terrible pirate Tuco ?? \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\" Écoute-moi bien. Non seulement je peux aller où je veux, mais j'exige une compensation pour une telle insulte ! \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\" O-oui, bien sûr, Tuco. \" La garde pirate vous verse un peu de ferraille.\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\" À la prochaine. \""

#: src-en/data/events_special_guards.xml.append:1307
msgid ""
