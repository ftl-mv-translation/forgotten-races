#: src-en/data/events_special_guards.xml.append:842
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_WARZONE_REBEL_DESTROY\"]/text"
msgstr ""
"Vous avez vaincu le Garde MFK Ace. Ce qui pouvait se trouver dans leur "
