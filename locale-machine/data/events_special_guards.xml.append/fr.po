"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_PIRATE\"]/choice/event/choice/event/choice[@req=\"unique_kaz\"]/event/text"
msgstr ""
"\" Vous êtes en présence du grand Kazaaakplethkilik Tiiikazpakaziiika ! Si vous ne baissez pas les armes, votre tête tombera au sol avant même que vous ne réalisiez que je la coupe ! \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\tLa garde halète. \" C'est... c'est un honneur. Bien sûr, vous pouvez passer comme bon vous semble. \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\" J'ai besoin d'un peu de ferraille supplémentaire pour votre temps. Vous donnez ? \"\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\tLa garde soupire et acquiesce timidement avant de donner au pirate légendaire ce qu'il veut."

#: src-en/data/events_special_guards.xml.append:1292
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_START_WARZONE_PIRATE\"]/choice/event/choice/event/choice[@req=\"unique_tuco\"]/text"
