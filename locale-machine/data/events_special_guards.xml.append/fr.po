#: src-en/data/events_special_guards.xml.append:65
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
"append:choice[1]/event/text"
msgstr ""
"\" Oh, merde ! Vance Prime ! Je suis terriblement désolé pour le malentendu,"
" nous vous avons pris pour un Fed ! Nous nous assurerons que la flotte ne "
"soit pas un problème pour vous ici. \" Alors que le garde envoie un signal "
"tout clair, quelques MFK Aces sont envoyés pour aider votre cause, "
"accompagnés de quelques caisses de fournitures."

#: src-en/data/events_special_guards.xml.append:72
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBELHOLD\"]/mod-"
