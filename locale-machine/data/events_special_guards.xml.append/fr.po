"data/events_special_guards.xml.append$//event[@name=\"FR_START_BEACON_COMMONWEALTH\"]/choice/event/choice[@req=\"fr_commonwealth\"]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/text"
