#: src-en/data/events_special_guards.xml.append:5
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halte, soldat ! Cessez le combat, et laissez-nous passer !\""

#: src-en/data/events_special_guards.xml.append:7
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[1]/text"
msgstr ""
"\"Oh merde ! Bien sûr, monsieur !\" Le garde rebelle se retire et laisse "
"passer votre vaisseau. L'un de leurs membres d'équipage propose de vous "
"rejoindre, et Vance ordonne au vaisseau de garde d'envoyer des provisions "
"ainsi que de fausses données à la flotte."

#: src-en/data/events_special_guards.xml.append:14
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[2]/text"
msgstr ""
"\"Jamais de la vie ! Vous ne méritez plus d'être appelé Vance, traître !\" "
"hurle le capitaine rebelle. Ils appellent des renforts et informent la "
"flotte de votre intrusion."

#: src-en/data/events_special_guards.xml.append:18
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[1]/event[2]/choice/text"
msgstr ""

#: src-en/data/events_special_guards.xml.append:24
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/text"
msgstr ""
"(Vance One) \"Halte, soldat ! Cessez le combat, et laissez-nous passer !\""

#: src-en/data/events_special_guards.xml.append:26
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
"append:choice[2]/event[1]/text"
msgstr ""
"\"Oh merde ! Bien sûr, monsieur !\" Le garde rebelle se retire et laisse "
"passer votre vaisseau. L'un de leurs membres d'équipage propose de sauter, "
"et Vance ordonne au vaisseau de garde d'envoyer des provisions ainsi que de "
"fausses données à la flotte."

#: src-en/data/events_special_guards.xml.append:33
msgid ""
"data/events_special_guards.xml.append$//mod:findName[@name=\"GUARD_REBEL\"]/mod-"
