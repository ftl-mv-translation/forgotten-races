msgid ""
"data/events_special_guards.xml.append$//event[@name=\"FR_GUARD_COMMONWEALTH_SURRENDER\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"FR_COMMONWEALTHS_BODY\"]/event/choice/event/choice/text"
