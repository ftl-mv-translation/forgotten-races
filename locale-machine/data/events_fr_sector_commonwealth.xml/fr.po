msgstr ""
"Vous tentez de contacter le vaisseau massif, et à votre grande surprise, "
"celui qui est en charge répond à vos appels. \" Étranger, si vous tenez à "
"votre vie, nous vous suggérons de reculer. Vous ne pouvez pas quitter le "
"secteur en aucune circonstance - personne ne le peut. \""

#: src-en/data/events_fr_sector_commonwealth.xml:379
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_RIFT\"]/choice/event/choice/text"
msgstr "Nous ne reculons pas ; combattez le Cuirassé lourd !"

