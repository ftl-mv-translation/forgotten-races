"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_RIFT\"]/choice/event/text"
msgstr ""
"Vous tentez de contacter le vaisseau massif et, à votre surprise, la "
"personne en charge répond à vos appels. \" Étranger, si vous tenez à votre "
"vie, nous vous suggérons de reculer. Vous ne pouvez en aucun cas quitter le "
"secteur – personne ne le peut. \""

#: src-en/data/events_fr_sector_commonwealth.xml:379
msgid ""
"data/events_fr_sector_commonwealth.xml$//event[@name=\"FR_COMMONWEALTH_RIFT\"]/choice/event/choice/text"
msgstr "Nous ne reculons pas ; combattez le Cuirassé Lourd !"

#: src-en/data/events_fr_sector_commonwealth.xml:381
