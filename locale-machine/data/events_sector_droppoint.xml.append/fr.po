"data/events_sector_droppoint.xml.append$//mod:findName[@name=\"FINISH_BEACON_DROPPOINT_ENCOUNTER_CASUAL\"]/mod-"
"append:choice[1]/event[1]/text"
msgstr ""
"\"C'est un honneur de vous rencontrer, monsieur ! Oui, nous allons nous "
"retirer sur votre ordre !\""

#: src-en/data/events_sector_droppoint.xml.append:12
