#: src-en/data/events_sector_droppoint.xml.append:5
msgid ""
"data/events_sector_droppoint.xml.append$//mod:findName[@name=\"FINISH_BEACON_DROPPOINT_ENCOUNTER_CASUAL\"]/mod-"
"append:choice[1]/text"
msgstr ""
"(Vance Prime) \"Halte, soldat ! Le mouvement rebelle est sous l'emprise d'un"
" rat perfide ! C'est votre ordre officiel de dissolution !\""

#: src-en/data/events_sector_droppoint.xml.append:7
