#: src-en/data/text_misc.xml.append:58
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_revenant\"]"
msgstr ""
"Astuce : Les armes de Revenant sont des morceaux de technologie mystérieux "
"forgés dans les profondeurs de Tartarus. Elles sont très fortes, mais "
"souvent hautement spécialisées."

#: src-en/data/text_misc.xml.append:59
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_wither_crew\"]"
msgstr ""
"Astuce : Les drones d'équipage d'Aenwithe n'ont pas la capacité de supporter"
" le changement de mode, et sont trop complexes pour être répliqués par des "
"Technopathes. Ils peuvent, cependant, être très puissants."

#: src-en/data/text_misc.xml.append:60
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_federation_loot_1\"]"
msgstr ""
"BUTIN UNION\n"
"Étourdit l'équipage touché pendant 10 secondes\n"
"+30 dégâts à l'équipage\n"
"+1 dégât au système\n"
"-3 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:65
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_federation_loot_2\"]"
msgstr ""
"BUTIN UNION\n"
"Étourdit l'équipage touché pendant 10 secondes\n"
"+30 dégâts à l'équipage\n"
"+1 dégât au système\n"
"+20% chance de feu et de brèche\n"
"-3 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:71
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_federation_loot_3\"]"
msgstr ""
"BUTIN UNION\n"
"Étourdit l'équipage touché pendant 2 secondes\n"
"+15 dégâts à l'équipage\n"
"+20% chance de feu et +10% chance de brèche\n"
"-3 secondes de pré-recharge de chaîne (le temps de recharge final est le même)"

#: src-en/data/text_misc.xml.append:76
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_coalition_loot_1\"]"
msgstr ""
"BUTIN E.E.U.R.\n"
"+20% chance de feu et de brèche\n"
"+20% de précision\n"
"-4 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:80
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_coalition_loot_2\"]"
msgstr ""
"BUTIN E.E.U.R.\n"
"+1 projectile tiré\n"
"+30% chance de brèche\n"
"-2 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:84
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_rebel_loot_1\"]"
msgstr ""
"BUTIN MFK\n"
"+10% de précision\n"
"+10% chance de feu et +20% chance de brèche\n"
"-1,5 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:88
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_rebel_loot_2\"]"
msgstr ""
"BUTIN MFK\n"
"+2 perforation de bouclier\n"
"+60% chance de feu\n"
"-1 seconde de temps de recharge"

#: src-en/data/text_misc.xml.append:92
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_auto_loot_1\"]"
msgstr ""
"BUTIN INNOVATION\n"
"+1 projectile tiré\n"
"+10 vitesse de projectile\n"
"-2 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:96
msgid "data/text_misc.xml.append$//text[@name=\"tip_fr_elite_rock_loot_1\"]"
msgstr ""
"BUTIN INQUISITION\n"
"-15px rayon, +10% chance de feu et de brèche\n"
"-2 secondes de temps de recharge"

#: src-en/data/text_misc.xml.append:99
