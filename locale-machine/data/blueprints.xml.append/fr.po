"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS\"]/desc"
msgstr ""
"Un vaisseau manié par Phys dans sa quête pour arrêter la souffrance "
"éternelle qui la traverse. Il est rempli de gaz ionisés qui représentent une"
" véritable menace pour les abordeurs."

#: src-en/data/blueprints.xml.append:29826
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_2\"]/class"
msgstr "Croiseur de Phys"

#: src-en/data/blueprints.xml.append:29827
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_2\"]/name"
msgstr "Le Coquille-Choqué"

