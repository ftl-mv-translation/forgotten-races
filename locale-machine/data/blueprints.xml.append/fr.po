#: src-en/data/blueprints.xml.append:19225
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_EXTERMINATORS_SHIELDS\"]/desc"
msgstr ""
"Le bouclier d'éther qui protège l'Exterminateur est alimenté par la plus grande batterie d'éther jamais conçue par les Obélisques.\n"
"\n"
"\tIl a une intégrité de 18 PV et augmente la vitesse de recharge des boucliers standards de 25 %."

#: src-en/data/blueprints.xml.append:19235
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FR_LICHS_SHIELDS\"]/title"
msgstr "Bouclier du Liche"

#: src-en/data/blueprints.xml.append:19236
