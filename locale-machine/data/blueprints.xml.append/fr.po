#: src-en/data/blueprints.xml.append:5234
msgid "data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_SALT_BEAM\"]/desc"
msgstr ""
"Une arme unique forgée par le légendaire Empire Salin déchu. Elle tire un "
"rayon de sel gazeux hautement compressé qui inflige des dégâts mineurs au "
"vaisseau et empoisonne l'équipage pendant 50 secondes, infligeant 5 PV/s. Le"
" rayon tue les Limaces instantanément."

#: src-en/data/blueprints.xml.append:5328
