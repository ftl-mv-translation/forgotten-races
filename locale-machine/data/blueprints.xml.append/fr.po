#: src-en/data/blueprints.xml.append:5681
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"FR_ALEENOR_BIO_PIERCE\"]/desc"
msgstr ""
"Une arme de perforation biologique précise conçue par Aleenor. Elle "
"infligera de lourds dégâts à tout membre d'équipage assez malchanceux pour "
