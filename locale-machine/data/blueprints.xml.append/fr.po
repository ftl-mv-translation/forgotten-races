"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_2\"]/desc"
msgstr ""
"La structure génétique unique de Phys la rend extrêmement puissante dans le "
"rôle de soutien pour les stratégies d'abordage. Pour soutenir ses pouvoirs, "
"son équipage a été équipé de combinaisons puissantes qui facilitent "
"l'étourdissement des ennemis et qui offrent une résistance à "
"l'étourdissement."

#: src-en/data/blueprints.xml.append:29904
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_3\"]/class"
msgstr "Croiseur de Phys"

#: src-en/data/blueprints.xml.append:29905
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_3\"]/name"
msgstr "La Tétrachromatie"

#: src-en/data/blueprints.xml.append:29906
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_PHYS_3\"]/unlock"
