msgstr "Croiseur d'Aleenor"

#: src-en/data/blueprints.xml.append:29981
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_ALEENOR\"]/name"
msgstr "Le Supra Mortem"

