msgstr ""
"Le vaisseau personnel d'Aleenor, forgé dans les profondeurs du Tartarus "
"après sa mort. Il est équipé d'un mélange de phéromones unique en son genre."

#: src-en/data/blueprints.xml.append:30056
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_FR_REVENANT_ALEENOR_2\"]/class"
msgstr "Croiseur d'Aleenor"

#: src-en/data/blueprints.xml.append:30057
