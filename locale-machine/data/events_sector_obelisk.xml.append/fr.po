"data/events_sector_obelisk.xml.append$//event[@name=\"FR_COMMONWEALTH_FORGE_CRUISER_TRANSLATED\"]/choice[1]/event/choice/text"
msgstr ""

#: src-en/data/events_sector_obelisk.xml.append:166
