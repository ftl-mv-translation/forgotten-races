msgstr "C'est trop risqué ; éloignez-vous du croiseur."

#: src-en/data/events_sector_obelisk.xml.append:188
msgid ""
"data/events_sector_obelisk.xml.append$//event[@name=\"FR_COMMONWEALTH_FORGE_CRUISER_TRANSLATED\"]/choice[4]/event/text"
msgstr ""
