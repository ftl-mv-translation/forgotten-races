"meilleure ligne de conduite. \" Et comment pouvez-vous le garantir ? Comment"
" puis-je savoir que ce n'est pas un piège ? \""

#: src-en/data/events_sector_laststand.xml.append:655
msgid ""
"data/events_sector_laststand.xml.append$//event[@name=\"FR_FLAGSHIP_VANCE\"]/choice/event/choice[@req=\"loc_fr_vance_peaceful\"]/text"
msgstr "\" L'Amiral Tully lui-même m'a confié cette tâche. \""

#: src-en/data/events_sector_laststand.xml.append:659
msgid ""
"data/events_sector_laststand.xml.append$//event[@name=\"FR_FLAGSHIP_VANCE\"]/choice/event/choice[2]/text"
