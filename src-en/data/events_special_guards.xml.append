	<choice hidden="true">
		<text>Continue...</text>
		<event load="FR_GUARD_WARZONE_PIRATE_FOLLOWUP"/>
	</choice>
</event>

<event name="FR_GUARD_WARZONE_PIRATE_FOLLOWUP">
	<noQuestText/>
	<removeHazards/>
	<text>By killing the Elite Pirate guard, you have no doubt caused them to dispatch reinforcements to track you down. Watch your step as you explore the sector. Though with how chaotic this sector is, there's a chance the forces here will be too busy to deal with you.</text>
	<quest event="FR_REINFORCEMENTS_WARZONE_PIRATE">
		<nebulaBeacon>true</nebulaBeacon>
		<nextSector>false</nextSector>
		<nebulaEvent>FR_NEBULA_LIGHT_REINFORCEMENTS_WARZONE_PIRATE</nebulaEvent>
		<createNebula>false</createNebula>
		<aggressive>2</aggressive>
	</quest>
	<choice>
		<text>Do something onboard the ship.</text>
