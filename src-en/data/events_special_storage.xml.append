					NEO PANDORA'S BOX
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="STORAGE_CHECK_FR_AUG_NEO_PANDORA_BOX">
	<text>Are you sure you want to do this?
	[50% chance for an amazing reward, 50% chance for a horrible outcome, has 3 uses per sector.]</text>
	<choice blue="false" hidden="true" lvl="0" max_lvl="0" max_group="0" req="loc_fr_neo_pandora_box_opened_times">
		<text>Open the box and await what's inside. [3 Uses Left]</text>
		<event>
			<text>You press a switch on the back of the box, and a hissing noise escapes as the walls of the box expand outwards...</text>
			<variable name="loc_fr_neo_pandora_box_opened_times" op="add" val="1" />
			<choice hidden="true">
				<text>Continue...</text>
                <event>
                    <loadEvent seeded="false">STORAGE_CHECK_FR_AUG_NEO_PANDORA_BOX_OPEN</loadEvent>
                </event>
			</choice>
		</event>
	</choice>
	<choice blue="false" hidden="true" lvl="1" max_lvl="1" max_group="0" req="loc_fr_neo_pandora_box_opened_times">
		<text>Open the box and await what's inside. [2 Uses Left]</text>
		<event>
			<text>You press a switch on the back of the box, and a hissing noise escapes as the walls of the box expand outwards...</text>
			<variable name="loc_fr_neo_pandora_box_opened_times" op="add" val="1" />
			<choice hidden="true">
				<text>Continue...</text>
                <event>
                    <loadEvent seeded="false">STORAGE_CHECK_FR_AUG_NEO_PANDORA_BOX_OPEN</loadEvent>
                </event>
			</choice>
		</event>
	</choice>
	<choice blue="false" hidden="true" lvl="2" max_group="0" req="loc_fr_neo_pandora_box_opened_times">
		<text>Open the box and await what's inside. [1 Use Left]</text>
		<event>
			<text>You press a switch on the back of the box, and a hissing noise escapes as the walls of the box expand outwards...</text>
			<variable name="loc_fr_neo_pandora_box_opened_times" op="add" val="1" />
			<choice hidden="true">
				<text>Continue...</text>
                <event>
                    <loadEvent seeded="false">STORAGE_CHECK_FR_AUG_NEO_PANDORA_BOX_OPEN</loadEvent>
                </event>
			</choice>
		</event>
	</choice>
	<choice blue="false" max_group="99" req="pilot">
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

