<event name="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR">
    <text>Are you sure you want to do this? 
[Spawns a quest marker for a guaranteed encounter]</text>
    <choice hidden="true" req="loc_laststand" lvl="0" max_group="0" blue="false">
        <text>Yes.</text>
		<event>
			<text>Which kind of probe do you want to hunt? This will dictate what its reward will be.</text>
			<choice>
				<text>Weapon focused.</text>
				<event load="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_LOCATED_WEAPONS"/>
			</choice>
			<choice>
				<text>Drone focused.</text>
				<event load="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_LOCATED_DRONES"/>
			</choice>
			<choice>
				<text>Nevermind, do something else.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
		</event>
    </choice>
    <choice hidden="true" req="loc_laststand" lvl="1" max_group="0" blue="false">
        <text id="storage_not_enough_time"/>
        <event load="OPTION_INVALID"/>
    </choice>
    <choice req="pilot" lvl="1" max_group="1" blue="false">
        <text>Nevermind, do something else.</text>
        <event load="STORAGE_CHECK"/>
    </choice>
</event>


<event name="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_LOCATED_WEAPONS">
	<text>Your gear does its job and finds a matching probe in the vicinity. You mark down the coordinates.</text>
	<quest event="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_PROBE_WEAPONS"/>
</event>

<event name="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_LOCATED_DRONES">
	<text>Your gear does its job and finds a matching probe in the vicinity. You mark down the coordinates.</text>
	<quest event="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_PROBE_DRONES"/>
</event>

<event name="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_PROBE_WEAPONS">
	<preventQuest/>
	<preventFleet/>
	<beaconType id="map_icon_fr_cel_probe" global="true">
		<color r="0" g="255" b="178" a="1"/>
		<unvisitedTooltip>Location of a Probe.</unvisitedTooltip>
		<visitedTooltip>Explored location. Nothing left of interest.</visitedTooltip>
	</beaconType>
	<text>You find a nearby continuity probe repairing itself. If you strike now, it won't have a chance to flee.</text>
	<ship load="FR_SHIP_COLLECTOR_CONTINUITY_PROBE_WEAPON" hostile="true"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR_PROBE_DRONES">
	<preventQuest/>
	<preventFleet/>
	<beaconType id="map_icon_fr_cel_probe" global="true">
		<color r="0" g="255" b="178" a="1"/>
		<unvisitedTooltip>Location of a Probe.</unvisitedTooltip>
		<visitedTooltip>Explored location. Nothing left of interest.</visitedTooltip>
	</beaconType>
	<text>You find a nearby continuity probe repairing itself. If you strike now, it won't have a chance to flee.</text>
	<ship load="FR_SHIP_COLLECTOR_CONTINUITY_PROBE_DRONE" hostile="true"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

