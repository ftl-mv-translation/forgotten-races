<mod:findName type="event" name="STORAGE_CHECK_FISH_GLOSSARY_5">
  <mod-append:choice blue="false" req="fish_obtained_FR_TARTARUS" lvl="1">
    <text>FOUND    </text>
    <event>
      <text>This strange fish can only be found in the one place where life and death merge. Legends say feeding yourself with this fish can make your skin much more corrosive, allowing you to easily break systems as well as phase through doors.</text>
      <loadEvent>STORAGE_CHECK_FISH_GLOSSARY_5</loadEvent>
      <weapon name="FISH_FOOD_FR_TARTARUS"/>
    </event>
  </mod-append:choice>
  <mod-append:choice blue="true" req="fish_obtained_FR_TARTARUS" lvl="0" max_lvl="0" hidden="true">
    <text>Unknown</text>
    <event load="OPTION_INVALID"/>
  </mod-append:choice>
</mod:findName>


<mod:findName type="event" name="STORAGE_CHECK_FISHING_FOOD">
  <mod-append:choice req="FISH_FOOD_FR_TARTARUS">
    <text>Cook the Undead Fish. (+50% sabotage damage and door phasing to allies)</text>
    <event>
      <remove name="FISH_FOOD_FR_TARTARUS"/>
      <hiddenAug>FISH_AUG_FR_TARTARUS</hiddenAug>
      <event load="STORAGE_CHECK_FISHING_LOAD" />
    </event>
  </mod-append:choice>
</mod:findName>

