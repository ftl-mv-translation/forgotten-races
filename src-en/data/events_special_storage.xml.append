            <weapon name="FISH_FOOD_FR_TARTARUS"/>
        </event>
    </mod-append:choice>
    <mod-append:choice blue="false" hidden="false" req="FISH_AUG_FR_TARTARUS" lvl="5">
        <text>5+ Consumed</text>
        <event>
            <text>+250%+ sabotage damage and door phasing to allies</text>
            <loadEvent>STORAGE_CHECK_FISHING_STATS_5</loadEvent>
            <weapon name="FISH_FOOD_FR_TARTARUS"/>
        </event>
    </mod-append:choice>
</mod:findName>

