<mod:findName type="event" name="STORAGE_CHECK_JOB_FLEET">
	<mod-append:choice req="FR_WITHER_PROTOTYPE_MINE" hidden="true">
	  <text>Use your 'Suppressor' Mine Launcher. [-1}, gives 1 delay, does not impact notoriety]</text>
        <event>
            <text>You rig the ammunition and set a trap for the Rebels. The selective trigger system the mines boast is covered by obscure legal loopholes, rendering the usage of the weapon legal in spite of any morality concerns.</text>
            <modifyPursuit amount="-1"/>
            <item_modify>
                <item type="missiles" min="-1" max="-1"/>
            </item_modify>
	  </event>
	</mod-append:choice>
	<mod-append:choice req="FR_COMMONWEALTH_MINELAUNCHER" hidden="true">
		<text>Use your Commonwealth 'Onslaught' Mine Launcher. [-10}, gives 3 delay]</text>
        <event>
            <text>You rig the ammunition and set a trap for the Rebels. It's definitely illegal to do, but you'll be gone before it matters.</text>
            <modifyPursuit amount="-3" />
            <item_modify>
                <item type="missiles" min="-10" max="-10" />
            </item_modify>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="0" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_1" />
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="1" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_2" />
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="2" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_3" />
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="3" blue="false">
				<text>Continue...</text>
				<event load="MORALITY_UPDATE_GENERAL" />
			</choice>
        </event>
	  </mod-append:choice>
	<mod-append:choice req="FR_GOLDEN_ANCIENT_MINELAUNCHER" hidden="true">
	  <text>Use your Golden 'Onslaught' Mine Launcher. [-30~, gives 2 delay, does not impact notoriety]</text>
        <event>
            <text>You load the scrap into the hollow mines and set a trap for the Rebels. It's definitely illegal to do, but anyone sent to verify your misdeeds might be enticed to keep the mines a secret given their high value.</text>
            <modifyPursuit amount="-2"/>
            <item_modify>
                <item type="scrap" min="-30" max="-30"/>
            </item_modify>
	  </event>
	</mod-append:choice>
	<mod-append:choice req="FR_LOOT_ELITE_AUTO_1" hidden="true">
        <text>Use your Estate Breach Mine Launcher. [-17}, gives 3 delay]</text>
        <event>
            <text>You rig the ammunition and set a trap for the Rebels. It's definitely illegal to do, but you'll be gone before it matters.</text>
            <modifyPursuit amount="-3"/>
            <item_modify>
                <item type="missiles" min="-17" max="-17"/>
            </item_modify>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="0" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_1"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="1" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_2"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="2" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_3"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="3" blue="false">
				<text>Continue...</text>
				<event load="MORALITY_UPDATE_GENERAL"/>
			</choice>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_LOOT_ELITE_ROCK_1" hidden="true">
        <text>Use your Inquisition Mk 3 Mine Launcher. [-7}, gives 2 delay]</text>
        <event>
            <text>You rig the ammunition and set a trap for the Rebels. It's definitely illegal to do, but you'll be gone before it matters.</text>
            <modifyPursuit amount="-2"/>
            <item_modify>
                <item type="missiles" min="-7" max="-7"/>
            </item_modify>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="0" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_1"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="1" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_2"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="2" blue="false">
				<text>Continue...</text>
				<event load="TRAP_WARNING_3"/>
			</choice>
			<choice hidden="true" req="loc_mine_counter" max_group="0" lvl="3" blue="false">
				<text>Continue...</text>
				<event load="MORALITY_UPDATE_GENERAL"/>
			</choice>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_LOOT_ELITE_ZOLTAN_1" hidden="true">
		 <text>Use your Peace-Keeping Energy Mine Launcher. [-15}, gives 2 delay, does not impact notoriety]</text> 
		 <event>
            <text>You rig the ammunition and set a trap for the Rebels. Fortunately, due to obscure legal loopholes, the use of this weapon isn't illegal, though it is very morally dubious.</text>
            <modifyPursuit amount="-2"/>
            <item_modify>
                <item max="-15" min="-15" type="missiles"/>
            </item_modify>
        </event>
	</mod-append:choice>
</mod:findName>

