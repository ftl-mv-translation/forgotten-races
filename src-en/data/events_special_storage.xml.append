			</choice>
		</event>
	</choice>
	<choice req="LAB_UPGRADE" lvl="0" max_group="0" blue="false" hidden="true">
		<text>You must have the lab upgrade for this modification.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="pilot" lvl="1" max_group="1" blue="false" hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_LAB_LOAD"/>
	</choice>
</event>
<event name="FR_INSTALL_LAB_REVENANT_TRUE_UNDEATH">
    <hiddenAug>FR_LAB_REVENANT_TRUE_UNDEATH</hiddenAug>
	<loadEvent>STORAGE_CHECK_LAB_FR_SPECTER</loadEvent>
</event>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					CRATES
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="event" name="STORAGE_CHECK_CRATE">
	<mod-append:choice req="FR_RANDOM_AUGMENT_CRATE">
		<text>Open the crate of augments.</text>
		<event>
        <loadEvent>FR_STORAGE_CHECK_CRATE_AUGMENTS</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_RANDOM_AUGMENT_CRATE_MULTIVERSE">
		<text>Open the crate of augments.</text>
		<event>
        <loadEvent>FR_STORAGE_CHECK_CRATE_MULTIVERSE_AUGMENTS</loadEvent>
        </event>
	</mod-append:choice>
</mod:findName>

<event name="FR_STORAGE_CHECK_CRATE_AUGMENTS">
	<text>Are you sure you want to do this?
	[Will give any augment and remove the crate.]</text>
	<choice hidden="true">
		<text>Open the crate.</text>
		<event>
			<text>You open the crate and look inside.</text>
			<remove name="FR_RANDOM_AUGMENT_CRATE"/>
		    <augment name="FR_RANDOM_AUGMENT_LIST"/>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK_BUTTON"/>
	</choice>
</event>

<event name="FR_STORAGE_CHECK_CRATE_MULTIVERSE_AUGMENTS">
	<text>Are you sure you want to do this?
	[Will give any Multiverse augment and remove the crate.]</text>
	<choice hidden="true">
		<text>Open the crate.</text>
		<event>
			<text>You open the crate and look inside.</text>
			<remove name="FR_RANDOM_AUGMENT_CRATE_MULTIVERSE"/>
		    <augment name="FR_RANDOM_MULTIVERSE_AUGMENT_LIST"/>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK_BUTTON"/>
	</choice>
</event>

