<event name="STORAGE_CHECK_FR_MODULAR_SHIELD_LOAD">
	<loadEvent>STORAGE_CHECK_FR_MODULAR_SHIELD</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_MODULAR_SHIELD">
	<text>How would you like to configure the Hektar Modular Shield? [CAUTION: disassembly with insufficient inventory space will destroy items!]</text>
	<checkCargo/>
	<choice req="FR_HEKTAR_SUPERSHIELD_BASE" blue="false" hidden="true">
		<text>Configure your Shield. [No Modules]</text>
		<event load="STORAGE_CHECK_FR_MODULAR_SHIELD_BASE"/>
	</choice>
	<choice req="FR_HEKTAR_SUPERSHIELD_BIO" blue="false" hidden="true">
		<text>Configure your Shield. [Anti-Bio Module]</text>
		<event load="STORAGE_CHECK_FR_MODULAR_SHIELD_BIO"/>
	</choice>
	<choice req="FR_HEKTAR_SUPERSHIELD_COOLDOWN" blue="false" hidden="true">
		<text>Configure your Shield. [Cooldown Module]</text>
		<event load="STORAGE_CHECK_FR_MODULAR_SHIELD_COOLDOWN"/>
