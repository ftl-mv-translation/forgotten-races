		<event name="FR_COMBAT_CHECK_JAM_OMNI_BATTERY"/>
	</mod-append:choice>
	<mod-append:choice req="FR_RADIOACTIVE_FURY_C" blue="true" hidden="true">
		<text>(Radioactive Fury - CREW) Swap your augment's mode!</text>
		<event name="FR_COMBAT_CHECK_RADIOACTIVE_FURY_C"/>
	</mod-append:choice>
	<mod-append:choice req="FR_RADIOACTIVE_FURY_S" blue="true" hidden="true">
		<text>(Radioactive Fury - SHIPBOARD) Swap your augment's mode!</text>
		<event name="FR_COMBAT_CHECK_RADIOACTIVE_FURY_S"/>
	</mod-append:choice>
	<mod-append:choice req="FR_THE_ORACLE" blue="true" hidden="true">
		<text>(The Oracle) Steal a weapon, crew or drone from the enemy!</text>
		<event name="FR_COMBAT_CHECK_THE_ORACLE"/>
	</mod-append:choice>
	<mod-append:choice req="FR_EDUTAINMENT_MODULE" blue="true" hidden="true">
		<text>(Edutainment Module) Activate this module for some fun mathematical questions!</text>
		<event name="FR_COMBAT_CHECK_EDUTAINMENT_MODULE"/>
	</mod-append:choice>
</mod:findName>

