<?xml version="1.0" encoding="UTF-8"?>

<FTL>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					AUGMENT CHECKS
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="event" name="STORAGE_CHECK_AUG">
	<mod-append:choice req="FR_AI_AVATAR_GENERATOR" hidden="true" blue="true">
        <text>(AI Avatar Generator) Make an AI Avatar. [15~]</text>
		<event>
			<text>You give the scrap to the generator and wait for it to form a new, fully functional, AI avatar. "Greetings, Captain! It's a pleasure to work with you!"</text>
			<item_modify>
				<item type="scrap" min="-15" max="-15"/>
			</item_modify>
			<crewMember amount="1" class="fr_CE_avatar"/>
				<choice>
                    <text>Continue...</text>
                        <event/>
                </choice>	
		</event>
	</mod-append:choice>
	<mod-append:choice req="FR_OBSERVER_PRESENCE" blue="true" hidden="true">
		<text>(Observer's Presence) Change your bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE"/>
	</mod-append:choice>
	<mod-append:choice req="FR_AUTO_HUNTER_GEAR" blue="true" hidden="true">
		<text>(Auto Hunter Gear) Scan the sector for a nearby probe.</text>
		<event load="STORAGE_CHECK_FR_AUTO_HUNTER_GEAR"/>
	</mod-append:choice>
	<mod-append:choice req="FR_ECHO_PLATING" blue="true" hidden="true">
		<text>(E.C.H.O. Plating) Breed your spiders.</text>
		<event load="STORAGE_CHECK_FR_ECHO_PLATING"/>
	</mod-append:choice>
	<mod-append:choice req="FR_FRIGID_AIR" hidden="true" blue="true">
        <text>(Frigid Air) Make a Snowman. [3{]</text>
		<event>
			<text>You gather up all the snow that formed inside the ship and use it to make a brand new Snowman!</text>
			<item_modify>
				<item type="fuel" min="-3" max="-3"/>
			</item_modify>
			<crewMember amount="1" class="fr_snowman_smart"/>
				<choice>
                    <text>Continue...</text>
                        <event/>
                </choice>	
		</event>
	</mod-append:choice>
	<mod-append:choice req="FR_SPHERAX_MAKER" hidden="true" blue="true">
        <text>(Spherax Maker) Make a Spherax. [40~, 5{]</text>
		<event>
			<text>While expensive, the process is quite fast. A new Spherax is forged in the blink of an eye!</text>
			<item_modify>
				<item type="fuel" min="-5" max="-5"/>
				<item type="scrap" min="-40" max="-40"/>
			</item_modify>
			<crewMember amount="1" class="fr_spherax"/>
				<choice>
                    <text>Continue...</text>
                        <event/>
                </choice>	
		</event>
	</mod-append:choice>
	<mod-append:choice req="FR_SMART_THERMOSTAT" hidden="true" blue="true">
        <text>(Smart Thermostat) Make a Snowman. [5{]</text>
		<event>
			<text>You gather up all the snow that formed inside the ship and use it to make a brand new Snowman!</text>
			<item_modify>
				<item type="fuel" min="-5" max="-5"/>
			</item_modify>
			<crewMember amount="1" class="fr_snowman_smart"/>
				<choice>
                    <text>Continue...</text>
                        <event/>
                </choice>	
		</event>
	</mod-append:choice>
	<mod-append:choice req="FR_FORGOTTEN_WALLACE" hidden="true" blue="true">
        <text>(Forgotten Anomalous Merchant Beacon) Summon the Forgotten store.</text>
        <event>
			<store>FR_FORGOTTEN_WALLACE_STORE</store>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_BEAM_STORE" hidden="true" blue="true">
        <text>(Universal Beam Store) Summon the Universal Beam Store.</text>
        <event>
			<store>STORE_FR_BEAM_SYLEAH</store>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_NEO_PANDORA_BOX_REQUIREMENT" max_group="100" hidden="true" blue="true">
        <text>(Neo Pandora's Box) Test your luck.</text>
        <event load="STORAGE_CHECK_FR_AUG_NEO_PANDORA_BOX"/>
	</mod-append:choice>
	<mod-append:choice req="FR_NEO_PANDORA_BOX_REQUIREMENT_NO" max_group="100" hidden="true" blue="true">
        <text>(Neo Pandora's Box) The box needs to recharge before being used again.</text>
		<event load="OPTION_INVALID"/>
	</mod-append:choice>
</mod:findName>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					OBSERVERS
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE">
	<text>Do you want to activate or deactivate a bonus? You can only have one active at any time. Item, crew, and resource rewards are limited to once per run.</text>
	<choice req="FR_LIST_OBSERVER_BONUSES" lvl="1" blue="false" hidden="true">
		<text>Disable a bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE"/>
	</choice>
	<choice req="FR_LIST_OBSERVER_BONUSES" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>Enable a bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_ACTIVATE"/>
	</choice>
	<choice max_group="99" hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_AUG_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE">
	<text>You already have an Observer bonus active. To swap to a new one, you must deactivate the current one.</text>
	<choice hidden="true" req="FR_OBSERVER_BOONS" blue="false">
		<text>Disable the Boon Bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_BOON"/>
	</choice>
	<choice hidden="true" req="FR_OBSERVER_GRANTS" blue="false">
		<text>Disable the Grant Bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_GRANT"/>
	</choice>
	<choice hidden="true" req="FR_OBSERVER_BLESSINGS" blue="false">
		<text>Disable the Blessing Bonus.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_BLESSING"/>
	</choice>
	<choice max_group="99">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_BOON">
	<removeItem>HIDDEN FR_OBSERVER_BOONS</removeItem>
	<loadEvent>STORAGE_CHECK_FR_OBSERVER_PRESENCE</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_GRANT">
	<removeItem>HIDDEN FR_OBSERVER_GRANTS</removeItem>
	<loadEvent>STORAGE_CHECK_FR_OBSERVER_PRESENCE</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_DEACTIVATE_BLESSING">
	<removeItem>HIDDEN FR_OBSERVER_BLESSINGS</removeItem>
	<loadEvent>STORAGE_CHECK_FR_OBSERVER_PRESENCE</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_ACTIVATE">
	<text>Which bonus do you want active?</text>
	<choice req="loc_fr_free_boon_gift_got" lvl="1" max_group="0" hidden="true">
		<text>Toggle Boon bonuses. (One-Time Gift Claimed)</text>
		<event>
			<text>You tune your presence to apply the boon of your choice.</text>
			<hiddenAug>FR_OBSERVER_BOONS</hiddenAug>
			<choice hidden="true">
				<text>It's done...</text>
					<event/>
			</choice>
		</event>
	</choice> 
	<choice req="loc_fr_free_boon_gift_got" lvl="0" max_lvl="0" max_group="0" hidden="true">
		<text>Toggle Boon bonuses. [Gift available.]</text>
		<event>
			<text>You tune your presence to apply the boon of your choice. You also receive a complementary gift!</text>
			<crewMember amount="1" class="pony_tamed">Gift Horse</crewMember>
			<variable name="loc_fr_free_boon_gift_got" op="set" val="1" />
			<hiddenAug>FR_OBSERVER_BOONS</hiddenAug>
			<choice hidden="true">
				<text>It's done...</text>
					<event/>
			</choice>
		</event>
	</choice> 
	<choice req="loc_fr_free_grant_gift_got" lvl="1" max_group="1" hidden="true">
		<text>Toggle Grant bonuses. [Gift claimed.]</text>
		<event>
			<text>You tune your presence to apply the grant of your choice.</text>
			<hiddenAug>FR_OBSERVER_GRANTS</hiddenAug>
			<choice hidden="true">
				<text>It is done.</text>
					<event/>
			</choice>
		</event>
	</choice> 
	<choice req="loc_fr_free_grant_gift_got" lvl="0" max_lvl="0" max_group="1" hidden="true">
		<text>Toggle Grant bonuses. [Gift available.]</text>
		<event>
			<text>You tune your presence to apply the grant of your choice. You also receive a complementary gift!</text>
			<upgrade amount="1" system="reactor" />
			<variable name="loc_fr_free_grant_gift_got" op="set" val="1" />
			<hiddenAug>FR_OBSERVER_GRANTS</hiddenAug>
			<choice hidden="true" req="sensors" lvl="0" max_lvl="0" blue="false">
				<text>Continue...</text>
				<event>
					<text>You don't have sensors, so they must first be installed.</text>
					<system name="sensors" />
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<text>Your sensor systems have been upgraded.</text>
							<upgrade amount="1" system="sensors" />
							<choice hidden="true">
								<text>It is done.</text>
									<event/>
							</choice>
						</event>
					</choice>
				</event>
			</choice>
			<choice hidden="true" req="sensors" lvl="1" blue="false">
				<text>Continue...</text>
				<event>
					<text>Your sensor systems have been upgraded.</text>
					<upgrade amount="2" system="sensors" />
					<choice hidden="true">
						<text>It is done.</text>
							<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice> 
	<choice req="loc_fr_free_blessing_gift_got" lvl="1" max_group="2" hidden="true">
		<text>Toggle Blessing bonuses. [Gift claimed.]</text>
		<event>
			<text>You tune your presence to apply the blessing of your choice.</text>
			<hiddenAug>FR_OBSERVER_BLESSINGS</hiddenAug>
			<choice hidden="true">
				<text>It's done.</text>
					<event/>
			</choice>
		</event>
	</choice> 
	<choice req="loc_fr_free_blessing_gift_got" lvl="0" max_lvl="0" max_group="2" hidden="true">
		<text>Toggle Blessing bonuses. [Gift available.]</text>
		<event>
			<text>You tune your presence to apply the blessing of your choice. You also receive a complementary gift!</text>
			<item_modify>
				<item type="scrap" min="15" max="15" />
				<item type="fuel" min="3" max="3" />
				<item type="missiles" min="9" max="9" />
				<item type="drones" min="3" max="3" />
			</item_modify>
			<modifyPursuit amount="-2" />
			<eventAlias name="SYLVAN_TRADES_DROPPOINT">SYLVAN_TRADES_CHOICE</eventAlias>
			<eventAlias name="SYLVAN_TRADES_LASTSTAND">SYLVAN_TRADES_CHOICE</eventAlias>
			<eventAlias name="SYLVAN_TRADES">SYLVAN_TRADES_CHOICE</eventAlias>
			<variable name="merchant_boon_active" op="set" val="1" />
			<variable name="loc_fr_free_blessing_gift_got" op="set" val="1" />
			<variable name="rep_general" op="add" val="-3" />
			<hiddenAug>FR_OBSERVER_BLESSINGS</hiddenAug>
			<choice hidden="true">
				<text>It is done...</text>
					<event/>
			</choice>
		</event>
	</choice> 
	<choice max_group="99">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_OBSERVER_PRESENCE_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_OBSERVER_PRESENCE_LOAD">
	<loadEvent>STORAGE_CHECK_FR_OBSERVER_PRESENCE</loadEvent>
</event>

<event name="STORAGE_CHECK_AUG_LOAD">
	<loadEvent>STORAGE_CHECK_AUG</loadEvent>
</event>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					TALKING TO CREW
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="event" name="STORAGE_CHECK_MORPH_TRANSFORM" limit="1">
	<mod:findWithChildLike type="choice" child-type="text">
		<mod:selector>Reset a Morph.</mod:selector>
        <mod:findLike type="event">
			<mod-append:choice req="fr_technocwmender" blue="false" hidden="true">
				<text>Reset your Commonwealth Mender Technopath. [-3{]</text>
				<event>
					<item_modify>
						<item type="fuel" min="-3" max="-3"/>
					</item_modify>
					<text>Your Morph transforms back to its original shape.</text>
					<transformRace class="fr_technocwmender">techno</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="fr_technocwdirector" blue="false" hidden="true">
				<text>Reset your Commonwealth Director Technopath. [-3{]</text>
				<event>
					<item_modify>
						<item type="fuel" min="-3" max="-3"/>
					</item_modify>
					<text>Your Morph transforms back to its original shape.</text>
					<transformRace class="fr_technocwdirector">techno</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="fr_technocwatom" blue="false" hidden="true">
				<text>Reset your Commonwealth Atomizer Technopath. [-3{]</text>
				<event>
					<item_modify>
						<item type="fuel" min="-3" max="-3"/>
					</item_modify>
					<text>Your Morph transforms back to its original shape.</text>
					<transformRace class="fr_technocwatom">techno</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="fr_technolegion_battle" blue="false" hidden="true">
				<text>Reset your Legionnaire Pyrotechnic Technopath. [-2{]</text>
				<event>
					<item_modify>
						<item type="fuel" min="-2" max="-2"/>
					</item_modify>
					<text>Your Morph transforms back to its original shape.</text>
					<transformRace class="fr_technolegion_battle">techno</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
        </mod:findLike>
    </mod:findWithChildLike>
	<mod:findWithChildLike type="choice" child-type="text">
		<mod:selector>Transform a Technopath.</mod:selector>
        <mod:findLike type="event">
			<mod-append:choice req="FR_BLUELIST_COMMONWEALTH_CREW_COMBAT_DRONES" blue="false" hidden="true">
				<text>(Proto-Atomizer Drone) Take the form of the Proto-Atomizer.</text>
				<event>
					<text>Your Morph transforms into a new shape.</text>
					<transformRace class="techno">fr_technocwatom</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="FR_MENDERC" blue="false" hidden="true">
				<text>(Proto-Mender Drone) Take the form of the Proto-Mender.</text>
				<event>
					<text>Your Morph transforms into a new shape.</text>
					<transformRace class="techno">fr_technocwmender</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="FR_DIRECTORC" blue="false" hidden="true">
				<text>(Proto-Director Drone) Take the form of the Proto-Director.</text>
				<event>
					<text>Your Morph transforms into a new shape.</text>
					<transformRace class="techno">fr_technocwdirector</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
			<mod-append:choice req="FR_LIST_LEGION_BATTLE_DRONES" blue="false" hidden="true">
				<text>(Legionnaire Pyrotechnic Battledrone) Take the form of the Legionnaire Pyrotechnic Battledrone.</text>
				<event>
					<text>Your Morph transforms into a new shape.</text>
					<transformRace class="techno">fr_technolegion_battle</transformRace>
					<choice hidden="true">
						<text>Continue...</text>
						<event>
							<loadEvent>STORAGE_CHECK_MORPH_TRANSFORM</loadEvent>
						</event>
					</choice>
				</event>
			</mod-append:choice>
        </mod:findLike>
    </mod:findWithChildLike>
</mod:findName>


<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					STORAGE CHECK 
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="event" name="STORAGE_CHECK_BUTTON">
	<mod-append:choice req="FR_SUPREME_HATRED" blue="true" hidden="true">
		<text>(Supreme Hatred) Claim the buffs.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_SUPREME_HATRED</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_TIIIKAKA_MEMBERSHIP" blue="true" hidden="true">
		<text>(Tiiikaka Membership) Register your name on their database.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_TIIIKAKA_MEMBERSHIP</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_ENHANCED_AUGMENTER" blue="true" hidden="true">
		<text>(Enhanced Augmenter) Use the Augmenter.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_ENHANCED_AUGMENTER</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_AETHER_FORGE" blue="true" hidden="true">
		<text>(Aether Forge) Use the Forge.</text>
		<event>
        <loadEvent>FR_AETHER_FORGE_CRAFT</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_WITHER_ENGINEERING" blue="true" hidden="true">
		<text>(Aenwithe Engineering) Use the Proto-Forge.</text>
		<event>
        <loadEvent>FR_WITHER_ENGINEERING_CRAFT</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_LIVING_SHIP" blue="true" hidden="true">
		<text>(Living Ship) Feed one of your crew members to the ship.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_LIVING_SHIP</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_SOUL_STEALER" blue="true" hidden="true">
		<text>(Soul Stealer) Feed one of your unique crew member's soul to the ship.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_SOUL_STEALER</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_MFK_TRAINING_WITH_HUMANS" blue="true" hidden="true">
		<text>(MFK Training) Train a human.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_MFK_TRAINING</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_NEXUS_TECH_SCHEMATICS" blue="true" hidden="true">
		<text>(Nexus-Tech Schematics) Install an advanced upgrade.</text>
		<event>
        <loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_HEKTAR_MODULAR_SHIELDS" hidden="true" blue="true">
		<text>(Hektar Modular Shield) Modify the shield.</text>
		<event>
			<loadEvent>STORAGE_CHECK_FR_MODULAR_SHIELD</loadEvent>
		</event>
	</mod-append:choice>
	<mod-append:choice req="FR_FORGOTTEN_AENWITHER_CREWSER" hidden="true" blue="true">
		<text>(Aenwithe Crewser) Summon Forgotten Races uniques.</text>
		<event>
			<loadEvent>STORAGE_CHECK_FR_WITHER_CREWSER_CREW</loadEvent>
		</event>
	</mod-append:choice>
</mod:findName>

<mod:findName type="event" name="STORAGE_CHECK_WEAPON">
	<mod-append:choice req="FR_LIST_FROST_EQUIPMENT" blue="true" hidden="true">
		<text>(Frost Weapon) Dismantle your frost weapon and make a Smart Snowman out of it.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_FROST_DISMANTLE</loadEvent>
        </event>
	</mod-append:choice>
	<mod-append:choice req="FR_LIST_PURE_FIRE_EQUIPMENT" blue="true" hidden="true">
		<text>(Pure Fire Weapon) Dismantle your fire or particle weapon and make a Lavaman out of it.</text>
		<event>
        <loadEvent>STORAGE_CHECK_AUG_FR_FIRE_DISMANTLE</loadEvent>
        </event>
	</mod-append:choice>
</mod:findName>

<!--MFK TRAINING-->

<event name="STORAGE_CHECK_AUG_FR_MFK_TRAINING">
	<text>Which human do you want to train?</text>
        <choice req="human" hidden="false">
			<text>Train a Human into a Soldier. [1 fleet boost]</text>
				<event>
					<text>You crew undertakes an accelerated training regimen and receives new equipment to match.</text>
					<modifyPursuit amount="1"/>
					<item_modify>
						<item type="scrap" min="-15" max="-15"/>
						<item type="missiles" min="-5" max="-5"/>
					</item_modify>
					<transformRace class="human">human_soldier</transformRace>
						<choice>
							<text>Continue...</text>
								<event/>
						</choice>	
				</event>
	    </choice>
        <choice req="FR_HUMAN_ENGINEERS" hidden="false">
			<text>Train a Human Engineer into a Soldier. [1 fleet boost]</text>
				<event>
					<text>You crew undertakes an accelerated training regimen and receives new equipment to match.</text>
					<modifyPursuit amount="1"/>
					<item_modify>
						<item type="scrap" min="-15" max="-15"/>
						<item type="missiles" min="-5" max="-5"/>
					</item_modify>
					<transformRace class="FR_HUMAN_ENGINEERS">human_soldier</transformRace>
						<choice>
							<text>Continue...</text>
								<event/>
						</choice>	
				</event>
	    </choice>
        <choice req="FR_HUMAN_MEDICS" hidden="false">
			<text>Train a Human Medic into a Soldier [1 fleet boost]</text>
				<event>
					<text>You crew undertakes an accelerated training regimen and receives new equipment to match.</text>
					<modifyPursuit amount="1"/>
					<item_modify>
						<item type="scrap" min="-15" max="-15"/>
						<item type="missiles" min="-5" max="-5"/>
					</item_modify>
					<transformRace class="FR_HUMAN_MEDICS">human_soldier</transformRace>
						<choice>
							<text>Continue...</text>
								<event/>
						</choice>	
				</event>
	    </choice>
        <choice req="FR_HUMAN_SOLDIERS" hidden="false">
			<text>Train a Human Soldier into an MFK Ace. [2 fleet boost]</text>
				<event>
					<text>You crew undertakes an accelerated training regimen and receives new equipment to match.</text>
					<modifyPursuit amount="2"/>
					<item_modify>
						<item type="scrap" min="-30" max="-30"/>
						<item type="missiles" min="-10" max="-10"/>
					</item_modify>
					<transformRace class="FR_HUMAN_SOLDIERS">human_mfk</transformRace>
						<choice>
							<text>Continue...</text>
								<event/>
						</choice>	
				</event>
	    </choice>
        <choice req="human_technician" hidden="false">
			<text>Train a Human Technician into an MFK Ace. [2 fleet boost]</text>
				<event>
					<text>You crew undertakes an accelerated training regimen and receives new equipment to match.</text>
					<modifyPursuit amount="2"/>
					<item_modify>
						<item type="scrap" min="-30" max="-30"/>
						<item type="missiles" min="-10" max="-10"/>
					</item_modify>
					<transformRace class="human_technician">human_mfk</transformRace>
						<choice>
							<text>Continue...</text>
								<event/>
						</choice>	
				</event>
	    </choice>
		<choice req="pilot" lvl="1" max_group="99" blue="false">
			<text>Nevermind, do something else.</text>
			<event load="STORAGE_CHECK"/>
		 </choice>
</event>

