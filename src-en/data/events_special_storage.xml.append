<!--ENHANCED AUGMENTER  [huge thanks to Julk for the help with the code]-->
<event name="STORAGE_CHECK_AUG_FR_ENHANCED_AUGMENTER">
	<text>Which system should be upgraded?</text>
	<choice req="hull" lvl="11" max_group="1" blue="false" hidden="true">
		<text>Scrap part of the plating to upgrade your Reactor. [10 hull damage, +2 to the Reactor level] </text>
		<event>
			<text>You tear off a sizable chunk of the hull and use it to upgrade your reactor.</text>
			<damage amount="10"/>
            <upgrade amount="2" system="reactor"/>
		</event>
	</choice>
	<choice req="hull" max_lvl="10" max_group="1" blue="false" hidden="true">
		<text>Not enough hull. [10 hull damage, +2 Reactor level]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_REQUIREMENT_SHIELD_HULL" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Scrap part of the plating to upgrade your Shield system.[35 hull damage, +2 Shield system level] </text>
		<event>
			<text>You tear off a sizable chunk of the hull and use it to upgrade your system.</text>
			<damage amount="35"/>
            <upgrade amount="2" system="shields"/>	
		</event>
	</choice>
	<choice req="FR_REQUIREMENT_SHIELD_HULL_FALSE" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Not enough hull. [35 hull damage, +2 Shield system level]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_REQUIREMENT_SHIELD_CAPPED" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Shield system is already at max level!</text>
		<event load="OPTION_INVALID"/>
	</choice>
