\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="STORAGE_CHECK_FR_ECHO_PLATING">
	<text>What do you want to do?</text>
	<choice hidden="true" lvl="2" req="FR_LIST_CREW_SPIDER_MATURE">
		<text>Breed two Giant Alien spiders.</text>
		<event>
			<text>A new hatchling is born.</text>
			<crewMember amount="1" class="spider_hatch"/>
		</event>
	</choice>
	<choice hidden="true" req="FR_ADULT_QUEEN_SPIDER">
		<text>Breed a mature and a queen Giant Alien spider.</text>
		<event load="STORAGE_CHECK_FR_ECHO_PLATING_QUEEN_RANDOM"/>
	</choice>
	<choice hidden="true" lvl="2" req="LIST_CREW_QUEEN">
		<text>Breed two Giant Alien spider queens.</text>
		<event>
			<text>A new queen is born.</text>
			<crewMember amount="1" class="unique_queen"/>
		</event>
	</choice>
