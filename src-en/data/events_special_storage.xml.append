\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					COMBAT CHECK - RADIOACTIVE FURY
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="FR_COMBAT_CHECK_RADIOACTIVE_FURY_C">
	<text>Are you sure you want to swap modes? 
	
	[CURRENTLY MODE: CREW

	While in Crew mode: Your crew heal 200% and clone 100% faster and are immune to hazards.

	While in Shipboard mode: Your weapons pierce 2 extra layers of shields and your shields recharge 50% faster.]</text>
	<choice hidden="true">
		<text>Yes.</text>
		<event>
			<text>You start swapping the augment's mode...</text>
			<removeItem>FR_RADIOACTIVE_FURY_C</removeItem>
			<choice>
				<text>Continue...</text>
				<event>
					<text>You finish the process and your augment is now ready to be used again!</text>
					<augment name="FR_RADIOACTIVE_FURY_S"/>
					<choice>
						<text>Continue to the fight!</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice>
		<text>Do something else instead.</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

<event name="FR_COMBAT_CHECK_RADIOACTIVE_FURY_S">
	<text>Are you sure you want to swap modes? 
	
	[CURRENTLY MODE: SHIPBOARD

	While in Crew mode: Your crew heal 200% and clone 100% faster and are immune to hazards.

	While in Shipboard mode: Your weapons pierce 2 extra layers of shields and your shields recharge 50% faster.]</text>
	<choice hidden="true">
		<text>Yes.</text>
		<event>
			<text>You start swapping the augment's mode...</text>
			<removeItem>FR_RADIOACTIVE_FURY_S</removeItem>
			<choice>
				<text>Continue...</text>
				<event>
					<text>You finish the process and your augment is now ready to be used again!</text>
					<augment name="FR_RADIOACTIVE_FURY_C"/>
					<choice>
						<text>Continue to the fight!</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice>
		<text>Do something else instead.</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

