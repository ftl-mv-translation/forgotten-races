<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					TIIIKAKA MEMBERSHIP
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="STORAGE_CHECK_AUG_FR_TIIIKAKA_MEMBERSHIP">
	<text>Are you sure you want to do this?
[Will consume the membership but give you +10 slaver reputation and allow you to find a slaver ship in the next sector at jumpspeed.]</text>
	<choice hidden="true">
		<text>Register the membership card.</text>
		<event>
			<text>You enter the very shady but surprisingly safe Tiiikaka website and register your name on their database. A popup welcomes you to their clan's premium list of customers. You aren't sure if you should feel proud about this.</text>
			<remove name="FR_TIIIKAKA_MEMBERSHIP"/>
			<hiddenAug>FR_TIIIKAKA_CARD_USED</hiddenAug>
			<variable name="fr_loc_tiiikaka_card_used" op="set" val="1"/>
			<choice hidden="true">
                <text>Continue...</text>
                <event load="FR_REPUTATION_UPDATE_SLAVER_MEMBERSHIP"/>
            </choice>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

<event name="FR_ENCOUNTER_MEMBERSHIP_SLAVER">
	<preventQuest/>
	<beaconType id="map_fr_icon_slaver" global="true">
		<color r="247" g="73" b="73" a="1"/>
		<unvisitedTooltip>The location of a Tiikaka Slaver.</unvisitedTooltip>
		<visitedTooltip>Explored location. Nothing left of interest.</visitedTooltip>
	</beaconType>
	<loadEvent>SLAVER_FRIENDLY</loadEvent>
</event>

