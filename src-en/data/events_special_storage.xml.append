<mod:findName type="event" name="COMBAT_CHECK_FAIL_REAL">
	<mod-append:choice req="FR_NECRO_SHIELD_AND_ENEMY_BYPASS" blue="true" hidden="true">
		<text>(Necromancer Shield) Counter the enemy's bypass attempt!</text>
		<event name="COMBAT_CHECK_REMOVEBYPASS"/>
	</mod-append:choice>
	<mod-append:choice req="FR_NECRO_SHIELD_AND_ENEMY_BYPASS_FAIL" blue="false" hidden="true">
		<text>(Necromancer Shield) Enemy has no bypass capability.</text>
		<event load="OPTION_INVALID"/>
	</mod-append:choice>
	<mod-append:choice req="FR_DISCHARGE_SURGE" blue="true" hidden="true">
		<text>(Discharge Surge) Downgrade the enemy's systems!</text>
		<event name="FR_DISCHARGE"/>
	</mod-append:choice>
	<mod-append:choice req="FR_NEXUS_ARM_ELECTROMAGNETIC" blue="true" hidden="true">
		<text>(Electromagnetic Arm) Activate the arm!</text>
		<event name="FR_COMBAT_CHECK_ELECTROMAGNETIC_ARM"/>
	</mod-append:choice>
	<mod-append:choice req="FR_NEXUS_ARM_WEAPON" blue="true" hidden="true">
		<text>(Weapon Dismemberment Arm) Activate the arm!</text>
		<event name="FR_COMBAT_CHECK_WEAPON_ARM"/>
	</mod-append:choice>
	<mod-append:choice req="FR_NEXUS_PILOT_RAM" blue="true" hidden="true">
		<text>(Incisive Ramming Upgrade) Ram the bastards!</text>
		<event name="FR_COMBAT_CHECK_PILOT_RAM"/>
	</mod-append:choice>
	<mod-append:choice req="FR_COMBAT_OMNI_JAMMER" blue="true" hidden="true">
		<text>(Omni-System Jammer) Jam an enemy system!</text>
		<event name="FR_COMBAT_CHECK_JAM_OMNI"/>
	</mod-append:choice>
	<mod-append:choice req="FR_REQUIREMENT_OMNI_HAMMER_AND_ENERGY_GENERATOR" blue="true" hidden="true">
