<event name="FR_COMBAT_CHECK_POK_MORPH">
	<text>What mode do you want to set the drone to?
	Current stats; [Shoots: Morphs, speed 15]</text>
	<choice hidden="true">
		<text>Set the drone to shoot Technomorphs. [Shoots: Technomorphs, speed 12]</text>
		<event>
			<text>You start calibrating the drone...</text>
			<remove name="FR_POK_MORPH_DRONE"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the drone successfully.</text>
					<drone name="FR_POK_TECHNO_DRONE"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Set the drone to shoot Malformeds. [Shoots: Malformeds, speed 8]</text>
		<event>
			<text>You start calibrating the drone...</text>
			<remove name="FR_POK_MORPH_DRONE"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the drone successfully.</text>
					<drone name="FR_POK_MALFORMED_DRONE"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice hidden="true" req="FR_MORPH_REVENANT_FORMS">
		<text>Set the drone to shoot Poks. [Shoots: Poks, speed 5]

WARNING: WILL CONSUME YOUR POK! THIS ISN'T REVERSIBLE!</text>
		<event>
			<text>You start calibrating the drone...</text>
			<remove name="FR_POK_MORPH_DRONE"/>
			<removeCrew class="FR_MORPH_REVENANT_FORMS">
				<clone>false</clone>
				<text>Your crew cannot be cloned on your ship as they are inside the drone.</text>
			</removeCrew>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the drone successfully.</text>
					<drone name="FR_POK_POK_DRONE"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>
</event>

