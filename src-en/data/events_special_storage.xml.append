<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					TOGGLE: CLICKER
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="event" name="COMBAT_CHECK_TOGGLE">
    <mod-append:choice req="FR_CLICKER_PAUSE_OFF" blue="false">
        <text>Enable clicker system function with pause.</text>
        <event>
            <metaVariable name="fr_clicker_pause_enabled" op="set" value="1"/>
        </event>
    </mod-append:choice>
    <mod-append:choice req="FR_CLICKER_PAUSE_ON" blue="false">
        <text>Disable clicker system function with pause.</text>
        <event>
            <metaVariable name="fr_clicker_pause_enabled" op="set" value="0"/>
        </event>
    </mod-append:choice>
</mod:findName>

