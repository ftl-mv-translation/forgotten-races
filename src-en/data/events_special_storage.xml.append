		</event>
	</choice>
</event>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					OCCULT PORTAL
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<mod:findName type="eventList" name="STORAGE_CHECK_AUG_GHOST_SPAWNER_SUMMON">
	<mod-append:event>
		<text>To your shock, out of the portal comes Goziodeon himself! Amazingly, he doesn't immediately attempt to strike at you, and instead offers to... join your crew?</text>
		<crewMember amount="1" all_skills="2" class="fr_gozer">Goziodeon</crewMember>
	</mod-append:event>
</mod:findName>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					STABLE
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	


<mod:findName type="event" name="STORAGE_CHECK_EQUINOID_DUPLICATOR">
	<mod-append:choice req="fr_bonus_prince" lvl="2" hidden="true">
		<text>Breed two Princes of Darkness.</text>
		<event>
			<text>A new demon is born.</text>
			<crewMember amount="1" class="fr_bonus_prince" />
		</event>
	</mod-append:choice>
</mod:findName>

<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					NEXUS-TECH SCHEMATICS
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->	

<event name="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD">
	<loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS">
	<text>What system do you want to upgrade?
	[Viewing an upgrade will tell you its details before you buy it.]</text>
	<checkCargo/>
	<choice req="FR_LIST_NEXUS_ARMS" lvl="1" blue="false" hidden="true">
		<text>Uninstall an arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL"/>
	</choice>
	<choice req="FR_LIST_NEXUS_ARMS" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>Install an arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_INSTALL"/>
	</choice>
	<choice req="pilot" hidden="true" blue="false">
		<text>The Piloting.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_PILOT"/>
	</choice>
	<choice req="engines" hidden="true" blue="false">
		<text>The Engines.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ENGINES"/>
	</choice>
	<choice req="shields" hidden="true" blue="false">
		<text>The Shields.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_SHIELDS"/>
	</choice>
	<choice req="weapons" hidden="true" blue="false">
		<text>The Weapons.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_WEAPONS"/>
	</choice>
	<choice req="oxygen" hidden="true" blue="false">
		<text>The Life Support.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_OXYGEN"/>
	</choice>
	<choice req="drones" hidden="true" blue="false">
		<text>The Drone Control.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_DRONES"/>
	</choice>
	<choice req="cloaking" hidden="true" blue="false">
		<text>The Cloaking.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_CLOAK"/>
	</choice>
	<choice req="teleporter" hidden="true" blue="false">
		<text>The Teleporter.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TELEPORTER"/>
	</choice>
	<choice req="clonebay" hidden="true" blue="false">
		<text>The Clone Bay.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_CLONEBAY"/>
	</choice>
	<choice req="medbay" hidden="true" blue="false">
		<text>The Medbay.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_MEDBAY"/>
	</choice>
	<choice req="mind" hidden="true" blue="false">
		<text>Mind Control.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_MIND"/>
	</choice>
	<choice req="hacking" hidden="true" blue="false">
		<text>The Hacking Bay.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_HACKING"/>
	</choice>
	<choice req="temporal" hidden="true" blue="false">
		<text>The Temporal Manipulator.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TEMPORAL"/>
	</choice>
	<choice req="battery" hidden="true" blue="false">
		<text>The Battery.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_BATTERY"/>
	</choice>
	<choice req="doors" hidden="true" blue="false">
		<text>The Door Control.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_DOORS"/>
	</choice>
	<choice req="sensors" hidden="true" blue="false">
		<text>The Sensors.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_SENSORS"/>
	</choice>
	<choice hidden="true" blue="false">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

<!-- INSTALL ARM NEXUS-->

<event name="STORAGE_CHECK_FR_NEXUS_ARM_INSTALL">
	<text>You have one nexus arm slot you can fill. You can also disassemble an arm, but you won't get any resources back for it. You can have 1 normal and 1 nexus arm at the same time.</text>
	<choice hidden="true">
		<text>Electromagnetic Arm. [Cost: 70~]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_ELECTROMAGNETIC"/>
	</choice>
	<choice hidden="true">
		<text>Weapon Dismemberment Arm. [Cost: 70~, 5}]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_WEAPON"/>
	</choice>
	<choice hidden="true">
		<text>Missile Recovery Arm. [Cost: 5}]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_MISSILE"/>
	</choice>
	<choice hidden="true">
		<text>Ship-Part Recovery Arm. [Cost: 50~, 2|]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_SHIP"/>
	</choice>
	<choice>
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_ELECTROMAGNETIC">
	<text>You are about to install the Electromagnetic Arm.
[Effects: Before combat, you can activate this arm to lower the enemy's accuracy by 10% at the cost of losing your sensors.]</text>
	<choice hidden="true">
		<text>Perform the upgrade. [Cost: 70~]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="scrap" min="-70" max="-70"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="FR_NEXUS_ARM_INSTALL_ELECTROMAGNETIC"/>
			</choice>
		</event>
	</choice> 
	<choice hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>
<event name="FR_NEXUS_ARM_INSTALL_ELECTROMAGNETIC">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>FR_NEXUS_ARM_ELECTROMAGNETIC</hiddenAug>
	<loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
</event>

<event name="FR_COMBAT_CHECK_ELECTROMAGNETIC_ARM">
	<text>What would you like to do?</text>
	<choice>
		<text>Lower enemy accuracy by 10% in exchange for disabling your Sensors and Hacking systems.</text>
		<event>
			<text>You activate the combat augment.</text>
			<status type="limit" target="player" system="sensors" amount="0"/>
			<hiddenAug>FR_NEXUS_ARM_ELECTROMAGNETIC_DEBUFF</hiddenAug>
			<triggeredEvent name="FR_TIMER_ELECTROMAGNETIC_ARM" event="FR_ELECTROMAGNETIC_ARM_DISABLE" jumps="1"/>
			<choice>
				<text>Continue to the fight!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DEBUG_GENERATOR">
		<text>[Emergency Generator] Lower enemy accuracy by 10%.</text>
		<event>
			<text>You activate the combat augment.</text>
			<hiddenAug>FR_NEXUS_ARM_ELECTROMAGNETIC_DEBUFF</hiddenAug>
			<triggeredEvent name="FR_TIMER_ELECTROMAGNETIC_ARM" event="FR_ELECTROMAGNETIC_ARM_DISABLE" jumps="1"/>
			<choice>
				<text>Continue to the fight!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice>
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<event name="FR_ELECTROMAGNETIC_ARM_DISABLE">
	<remove name="HIDDEN FR_NEXUS_ARM_ELECTROMAGNETIC_DEBUFF"/>
	<removeItem>HIDDEN FR_NEXUS_ARM_ELECTROMAGNETIC_DEBUFF</removeItem>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_WEAPON">
	<text>You are about to install the Weapon Dismemberment Arm.
[Effects: Before combat, you can activate this arm to remove one of the enemy's weapons at the cost of 8 reactor power. Also has a 10% chance to grant 10 scrap for each power bar the disabled weapon requires.]</text>
	<choice hidden="true">
		<text>Perform the upgrade. [Cost: 70~, 5}]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="scrap" min="-70" max="-70"/>
				<item type="missiles" min="-5" max="-5"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="FR_NEXUS_ARM_INSTALL_WEAPON"/>
			</choice>
		</event>
	</choice> 
	<choice hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>
<event name="FR_NEXUS_ARM_INSTALL_WEAPON">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>FR_NEXUS_ARM_WEAPON</hiddenAug>
	<loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
</event>

<event name="FR_COMBAT_CHECK_WEAPON_ARM">
	<text>What would you like to do?</text>
	<choice req="reactor" lvl="8" max_group="0" hidden="true" blue="false">
		<text>[-8 Reactor] Remove a random weapon from the enemy. Also has a 10% chance to grant 10 scrap for each power bar the disabled weapon requires.</text>
		<event>
			<text>You activate the combat augment.</text>
			<status type="loss" target="player" system="reactor" amount="8"/>
			<choice>
				<text>Continue to the fight!</text>
				<event name="COMBAT_CHECK_FR_REMOVE_WEAPON"/>
			</choice>
		</event>
	</choice>
	<choice req="reactor" max_lvl="7" max_group="0" blue="false" hidden="true">
		<text>Not enough reactor power!</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_REQUIREMENT_NEXUS_ARM_POWER_BACKUP_OK" max_group="1">
		<text>[-5 Reactor, Emergency Generator] Remove a random weapon from the enemy. Also has a 10% chance to grant 10 scrap for each power bar the disabled weapon requires.</text>
		<event>
			<text>You activate the combat augment.</text>
			<status type="loss" target="player" system="reactor" amount="5"/>
			<choice>
				<text>Continue to the fight!</text>
				<event name="COMBAT_CHECK_FR_REMOVE_WEAPON"/>
			</choice>
		</event>
	</choice>
	<choice req="FR_REQUIREMENT_NEXUS_ARM_POWER_BACKUP_FAILED" max_group="1">
		<text>Not enough reactor power!</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice>
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_MISSILE">
	<text>You are about to install the Missile Recovery Arm.
[Effects: Missed shots from weapons that consume ammunition will refund 1 missile.]</text>
	<choice hidden="true">
		<text>Perform the upgrade. [Cost: 5}]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="missiles" min="-5" max="-5"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="FR_NEXUS_ARM_INSTALL_MISSILE"/>
			</choice>
		</event>
	</choice> 
	<choice hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>
<event name="FR_NEXUS_ARM_INSTALL_MISSILE">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>FR_NEXUS_ARM_MISSILE</hiddenAug>
	<loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_SHIP">
	<text>You are about to install the Ship-Part Recovery Arm.
[Effects: Taking hull damage gives you 0-2 scrap.]</text>
	<choice hidden="true">
		<text>Perform the upgrade. [Cost: 50~, 2|]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="scrap" min="-50" max="-50"/>
				<item type="drones" min="-2" max="-2"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="FR_NEXUS_ARM_INSTALL_SHIP"/>
			</choice>
		</event>
	</choice> 
	<choice hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>
<event name="FR_NEXUS_ARM_INSTALL_SHIP">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>FR_NEXUS_ARM_SHIP</hiddenAug>
	<loadEvent>STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS</loadEvent>
</event>

<!-- UNINSTALL ARM NEXUS-->

<event name="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL">
	<text>You have already installed a Nexus arm. To install a new one, you must dismantle the current one.</text>
	<choice hidden="true" req="FR_NEXUS_ARM_ELECTROMAGNETIC" blue="false">
		<text>Dismantle Electromagnetic Arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_ELECTROMAGNETIC"/>
	</choice>
	<choice hidden="true" req="FR_NEXUS_ARM_WEAPON" blue="false">
		<text>Dismantle Weapon Dismemberment Arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_WEAPON"/>
	</choice>
	<choice hidden="true" req="FR_NEXUS_ARM_MISSILE" blue="false">
		<text>Dismantle Missile Recovery Arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_MISSILE"/>
	</choice>
	<choice hidden="true" req="FR_NEXUS_ARM_SHIP" blue="false">
		<text>Dismantle Ship-Part Recovery Arm.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_SHIP"/>
	</choice>
	<choice>
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_ELECTROMAGNETIC">
	<text>You are about to dismantle the Electromagnetic Arm.
	[You will lose these effects: Before combat, you can activate this arm to lower the enemy's accuracy by 10% at the cost of losing your sensors.]</text>
	<choice hidden="true">
