<mod:findName type="event" name="COMBAT_CHECK_EXPLOSIVE">
	<mod-append:choice blue="false" hidden="true" req="fr_clicker_enemy">
		<text>Her Will</text>
		<event>
			<text>You activate the payload and launch it from the vessel.</text>
			<enemyDamage amount="4" effect="fire" system="fr_clicker"/>
			<remove name="COMBAT_EXPLOSIVE"/>
			<choice>
				<text>Continue to the fight!</text>
				<event/>
			</choice>
		</event>
	</mod-append:choice>
</mod:findName>

<!--
