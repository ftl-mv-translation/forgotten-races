<event name="STORAGE_CHECK_LAB_FR_SALT">
	<text>You are viewing the lab menu for: [SALT]</text>
	<choice req="FR_LAB_SALT_PRO_SLUG_SALT" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Pro-Slug Salt.
		[Salt passive damage now heals Slugs but deals double damage to every other race. Obyn's ability acquires similar properties, but also deals double damage to allies.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_OATH_OF_PEACE" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Oath of Peace.
		[Salts lose the ability to fight and halve their movement speed in exchange for doubled sabotage damage.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_HEALING_CRYTALS" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Healing Crystals.
		[Salts heal from their passive damage equal to the amount of damage done to enemies. Obyn's ability heals himself and nearby allies for 6 hp/s instead of damaging allies and enemies. Both take double damage from all sources.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="pilot" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: None</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="1" max_group="1" blue="false" hidden="true">
		<text>Pri: Pro-Slug Salt. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="0" max_group="1" blue="false" hidden="true">
		<text>Pri: Pro-Slug Salt. [Cost: 50~]</text>
		<event load="STORAGE_CHECK_LAB_FR_SALT_PRO_SLUG_SALT"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Pri: Oath of Peace. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="0" max_group="2" blue="false" hidden="true">
		<text>Pri: Oath of Peace. [Cost: 10~, 12|]</text>
		<event load="STORAGE_CHECK_LAB_FR_SALT_OATH_OF_PEACE"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="1" max_group="3" blue="false" hidden="true">
		<text>Pri: Healing Crystals. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="0" max_group="3" blue="false" hidden="true">
		<text>Pri: Healing Crystals. [Cost: 10{]</text>
		<event load="STORAGE_CHECK_LAB_FR_SALT_HEALING_CRYSTALS"/>
	</choice>
	<choice req="pilot" lvl="1" max_group="4" blue="false" hidden="true">
		<text>Go back.</text>
		<event load="STORAGE_CHECK_LAB_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_LAB_FR_SALT_PRO_SLUG_SALT">
	<text>You are about to install the Pro-Slug Salt modification.
	[Salt passive damage now heals Slugs but deals double damage to every other race. Obyn's ability acquires similar properties, but also deals double damage to allies.]
	
	[Warning: After installing this, you will not be able to install any more primary upgrades for Salt crew. You will not be able to deactivate this mod either.]</text>
	<choice hidden="true">
		<text>Install the modification. [Cost: 50~]</text>
		<event>
			<text>You install the modification.</text>
			<item_modify>
				<item type="scrap" min="-50" max="-50"/>
			</item_modify>
