<event name="STORAGE_CHECK_LAB_FR_SPECTER">
	<text>You are viewing the lab menu for: [SPECTER]</text>
	<choice req="FR_LAB_SPECTER_FLAWLESS_ASCENSION" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Flawless Ascension.
		[Your Specters take twice as long to charge their abilities but their abilities become boosted in unique ways.
		Slimer: 
		- DEVOUR: Removes the system damage and allows it to be used in the enemy ship.
		- EAT: Now deals 75 damage to enemy crew and heals Slimer for 35 for each enemy crew in the room.
		Phys: Ion damage is raised to 8 and the stun now only affects enemies.
		Aleenor: Raises crew damage to 100 damage and system damage to 4 damage.
		Vin:
		- BOOST: Removes the self damage.
		- FUSION: Vin's fire healing will be doubled for 10 seconds after activating the ability.
		Cleo: The drones also gain double damage for the duration.
		Zulu: Removes the movement speed, sabotage and damage penalties during the effect.
		G: Also spawns 3 undead specters for the duration.
		Frostwall: Removes the self damage and causes frozen crew to take full damage for the duration.
		Deathbloom: Doubles the duration of the spores and lowers speed of enemies while affected by the spores by 10%.
		Pok: Their morph ability's cooldown is cut to 10 seconds in all forms.
		Charror: Their ability now affects all crew types and only applies to enemies.
		Leo: The increased damage taken now applies to enemies in the room instead.
		Searak: Removes the post-explosion stun.
		Augustus: Now only costs 1 scrap to fully heal him.
		Sally: The hatchling and adult abilities now only have a 1 second cooldown, while the weaver form ability's affects all ships.
		Prince: Breaches and starts a fire in the room as well.
		Tririac: Tririac becomes immune to stun during the effect.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SPECTER_TAILORED_SPECIALIZATION" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Tailored Specialization.
		[Your Specters' strengths and weaknesses are greatly increased.
		Slimer: Reduces his active ability cooldowns by 50% - Halves his crew damage.
		Phys: Provides double her base power - Can't sabotage.
		Aleenor: Doubles her damage - Can't repair.
		Vin: Doubles his health - Halves his speed.
		Cleo: Gains a 1.3x bonus to health, speed, repair, and damage - Cannot fight enemy drones directly. 
		Zulu: Doubles his sabotage damage - Halves his crew damage.
		G: Doubles the healing gained from hazards - Raises her active ability cooldowns by 50%.
		Frostwall: Doubles his ranged damage - Halves his hp.
		Deathbloom: Sets her o2 production to 2.0 (from 0.1) - Halves her heal speed. 
		Pok: They move 50% faster and reduces their active ability cooldowns by 50% - They use 2 crew slots.
		Charror: Doubles their repair speed - Halves their crew damage.
		Leo: Doubles their power drain - Doubles their stun time.
		Searak: Halves his damage taken - Halves his sabotage damage.
		Augustus: Adds a 1.2x multipler to his sabotage, damage, and health - Halves his movement speed.
		Sally: Constantly heals for 15 hp/s - Halves health.
		Prince: Doubles movement speed - Halves repair speed.
		Tririac: Doubles the damage mind controled crew do in the same room as them - They are stunned 10 times longer.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SPECTER_SPECTRAL_EXISTENCE" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: Spectral Existence.
		[Specters don't use up any crew slots. Generic Specters will be prioritized first in crew loss events above *any* other crew.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="pilot" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Currently Installed: None</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SPECTER_INSTALLED" lvl="1" max_group="1" blue="false" hidden="true">
		<text>Pri: Flawless Ascension. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SPECTER_INSTALLED" lvl="0" max_group="1" blue="false" hidden="true">
		<text>Pri: Flawless Ascension. [Cost: 100~]</text>
		<event load="STORAGE_CHECK_LAB_FR_SPECTER_FLAWLESS_ASCENSION"/>
	</choice>
	<choice req="FR_LAB_SPECTER_INSTALLED" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Pri: Tailored Specialization. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SPECTER_INSTALLED" lvl="0" max_group="2" blue="false" hidden="true">
		<text>Pri: Tailored Specialization. [Cost: 25{]</text>
		<event load="STORAGE_CHECK_LAB_FR_SPECTER_TAILORED_SPECIALIZATION"/>
	</choice>
	<choice req="FR_LAB_SPECTER_INSTALLED" lvl="1" max_group="3" blue="false" hidden="true">
		<text>Pri: Spectral Existence. [An upgrade is already installed.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_SALT_INSTALLED" lvl="0" max_group="3" blue="false" hidden="true">
		<text>Pri: Spectral Existence. [Cost: 15| 30}]</text>
		<event load="STORAGE_CHECK_LAB_FR_SPECTER_SPECTRAL_EXISTENCE"/>
	</choice>
	<choice req="FR_LAB_REVENANT_TRUE_UNDEATH" lvl="1" max_group="4" blue="false" hidden="true">
		<text>Sec [Revenant]: True Undeath. [An upgrade is already installed]
		[Revenants can't be cloned or heal through normal means but will instead be revived on jump.]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_LAB_REVENANT_TRUE_UNDEATH" lvl="0" max_group="4" blue="false" hidden="true">
		<text>Sec [Revenant]: True Undeath. [Cost: 45~]</text>
		<event load="STORAGE_CHECK_LAB_FR_REVENANT_TRUE_UNDEATH"/>
	</choice>
	<choice req="pilot" lvl="1" max_group="5" blue="false" hidden="true">
		<text>Go back.</text>
		<event load="STORAGE_CHECK_LAB_LOAD"/>
	</choice>
</event>

