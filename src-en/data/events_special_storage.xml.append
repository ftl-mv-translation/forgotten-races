			<text>You finish dismantling the arm.</text>
			<remove name="HIDDEN FR_NEXUS_ARM_ELECTROMAGNETIC"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
			</choice>
		</event>
	</choice> 
	<choice hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
	</choice>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_ARM_UNINSTALL_WEAPON">
	<text>You are about to dismantle the Weapon Dismemberment Arm.
	[You will lose these effects: Before combat, you can activate this arm to remove one of the enemy's weapons at the cost of 8 reactor power. Also has a 10% chance to grant 10 scrap for each power bar the disabled weapon requires.]</text>
	<choice hidden="true">
		<text>Dismantle it.</text>
		<event>
			<text>You finish dismantling the arm.</text>
