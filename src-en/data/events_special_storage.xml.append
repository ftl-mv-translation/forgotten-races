<event name="STORAGE_CHECK_FR_NEXUS_PILOT_AUTOMAN_1">
    <text>You are about to install the Enhanced Auto-Piloting Lvl 1 upgrade.
[Effects: All of your systems will be automatically manned at least at level 1 skill.]</text>
    <choice hidden="true">
        <text>Perform the upgrade. [Cost: 50~]</text>
        <event>
            <text>You install the upgrade.</text>
            <item_modify>
                <item type="scrap" min="-50" max="-50"/>
            </item_modify>
            <choice hidden="true">
                <text>Continue...</text>
                <event load="FR_NEXUS_PILOT_INSTALL_AUTOMAN_1"/>
            </choice>
        </event>
    </choice> 
    <choice req="pilot" lvl="1" max_group="2" blue="false" hidden="true">
        <text>Nevermind.</text>
        <event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
    </choice>
</event>
<event name="FR_NEXUS_PILOT_INSTALL_AUTOMAN_1">
    <variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>FR_NEXUS_PILOT_AUTOMAN_1</hiddenAug>
