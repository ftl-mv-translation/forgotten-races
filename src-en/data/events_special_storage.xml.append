				</event>
			</choice>
		</event>
	</choice>
	<choice req="LOOT_CULTIST_1">
		<text>Dismantle a Loot Piercing 'Torch'.</text>
		<event>
			<text>You dismantle the weapon.</text>
			<remove name="LOOT_CULTIST_1"/>
			<choice>
				<text>Continue...</text>
				<event>
					<text>The heating elements of the weapon allow you to build a man of lava!</text>
					<crewMember amount="1" class="fr_lavaman"/>
				</event>
			</choice>
		</event>
	</choice>
	<choice req="FR_VIN_MISSILE">
		<text>Dismantle a 'Prometheus' Burst Missile Launcher.</text>
		<event>
			<text>You dismantle the weapon.</text>
			<remove name="FR_VIN_MISSILE"/>
			<choice>
				<text>Continue...</text>
				<event>
					<text>The heating elements of the weapon allow you to build a man of lava!</text>
					<crewMember amount="1" class="fr_lavaman"/>
				</event>
			</choice>
		</event>
	</choice>
	<choice req="pilot" lvl="1" max_group="99" blue="false">
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

