<mod:findName type="event" name="STORAGE_CHECK_CREW_REAL">
	<mod-append:choice req="unique_vance" blue="false" hidden="true">
		<text>Look for Vance Prime.</text>
		<event load="FR_SOCIALIZE_VANCE_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="unique_cyra" blue="false" hidden="true">
		<text>Look for Cyra.</text>
		<event load="FR_SOCIALIZE_CYRA_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="fr_unique_mantis_queen" blue="false" hidden="true">
		<text>Look for Queen Leikonpliiinakra.</text>
		<event load="FR_SOCIALIZE_LEIKONPLIIINAKRA_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="FR_LIST_CREW_SAMMY" blue="false" hidden="true">
		<text>Look for Michael.</text>
		<event load="FR_SOCIALIZE_SAMMY_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="FR_LIST_CREW_LEAH" blue="false" hidden="true">
		<text>Look for Leah.</text>
		<event load="FR_SOCIALIZE_LEAH_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="fr_unique_purple_beard" blue="false" hidden="true">
		<text>Look for Purple Beard.</text>
		<event load="FR_SOCIALIZE_PURPLE_BEARD_LIST"/>
	</mod-append:choice>
	<mod-append:choice req="FR_JERRY_AND_PRINCE" hidden="true">
		<text>Mount Jerry on your Shadow Equinoid.</text>
        <event>
            <text>Jerry climbs onto the horse...</text>
            <removeCrew class="fr_bonus_prince">
                <clone>false</clone>
                <text></text>
            </removeCrew>
            <achievement>ACH_JERRY_STEED</achievement>
            <choice hidden="true">
                <text>Continue...</text>
                <event>
                    <text>...</text>
                    <transformRace class="unique_jerry_gun">fr_bonus_prince_jerry</transformRace>
                    <achievement>ACH_FR_EVENT_JERRY_SHADOW_PONY</achievement>
                </event>
            </choice>
        </event>
	</mod-append:choice>
	<mod-append:choice req="fr_bonus_prince_jerry" hidden="true">
        <text>Dismount Jerry.</text>
        <event>
            <text>Jerry gets off of his horse...</text>
            <transformRace class="fr_bonus_prince_jerry">unique_jerry_gun</transformRace>
            <choice hidden="true">
                <text>Continue...</text>
                <event>
                    <text>...</text>
                    <crewMember amount="1" class="fr_bonus_prince">Prince Of Darkness</crewMember>
                </event>
            </choice>
        </event>
	</mod-append:choice>
</mod:findName>

