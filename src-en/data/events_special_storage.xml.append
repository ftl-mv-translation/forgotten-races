<!-- PILOT NEXUS-->

<event name="STORAGE_CHECK_FR_NEXUS_PILOT">
    <text>What upgrade do you want to install?</text>
    <choice req="FR_NEXUS_PILOT_RAM" lvl="1" max_group="0" blue="false" hidden="true">
        <text>Incisive Ramming. [ALREADY INSTALLED]</text>
        <event load="OPTION_INVALID"/>
    </choice>
    <choice req="FR_NEXUS_PILOT_RAM" lvl="0" max_group="0" blue="false" hidden="true">
        <text>Incisive Ramming. [Cost: 30~, 3{]</text>
        <event load="STORAGE_CHECK_FR_NEXUS_PILOT_RAM"/>
    </choice>
	<choice req="FR_REQUIREMENT_AUTOMAN_UPGRADE_2" max_group="1" blue="false" hidden="true">
		<text>Enhanced Auto-Piloting. [UNAVAILABLE: You already have the max of this upgrade]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_REQUIREMENT_AUTOMAN_UPGRADE_ALL" max_group="1" blue="false" hidden="true">
		<text>Enhanced Auto-Piloting. [UNAVAILABLE: You already have the max of this upgrade]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="FR_REQUIREMENT_AUTOMAN_UPGRADE_1" max_group="1" blue="false" hidden="true">
		<text>Enhanced Auto-Piloting Lvl 2. [Cost: 50~]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_PILOT_AUTOMAN_2"/>
	</choice>
	<choice req="FR_REQUIREMENT_NO_AUTOMAN_UPGRADE" max_group="1" blue="false" hidden="true">
		<text>Enhanced Auto-Piloting Lvl 1. [Cost: 50~]</text>
		<event load="STORAGE_CHECK_FR_NEXUS_PILOT_AUTOMAN_1"/>
	</choice>
    <choice req="FR_NEXUS_PILOT_IMMUNITY" lvl="1" max_group="2" blue="false" hidden="true">
        <text>Isolated Piloting. [ALREADY INSTALLED]</text>
        <event load="OPTION_INVALID"/>
    </choice>
    <choice req="FR_NEXUS_PILOT_IMMUNITY" lvl="0" max_group="2" blue="false" hidden="true">
        <text>Isolated Piloting. [Cost: 5|, 3}]</text>
        <event load="STORAGE_CHECK_FR_NEXUS_PILOT_IMMUNITY"/>
    </choice>
    <choice>
        <text>Nevermind.</text>
        <event load="STORAGE_CHECK_FR_NEXUS_TECH_SCHEMATICS_LOAD"/>
    </choice>
</event>

<event name="STORAGE_CHECK_FR_NEXUS_PILOT_RAM">
    <text>You are about to install the Incisive Ramming upgrade.
[Effects: Before combat, you can choose a system to ram. You will deal 2 damage to the enemy hull and the chosen system, breaching it. The impact will also deal 1 damage to your own hull and to your corresponding system. Bypasses resistances.]</text>
    <choice hidden="true">
        <text>Perform the upgrade. [Cost: 30~, 3{]</text>
        <event>
            <text>You install the upgrade.</text>
            <item_modify>
                <item type="fuel" min="-3" max="-3"/>
                <item type="scrap" min="-30" max="-30"/>
            </item_modify>
            <choice hidden="true">
                <text>Continue...</text>
                <event load="FR_NEXUS_PILOT_INSTALL_RAM"/>
            </choice>
        </event>
    </choice> 
    <choice req="pilot" lvl="1" max_group="2" blue="false" hidden="true">
        <text>Nevermind.</text>
