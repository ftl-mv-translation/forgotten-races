		</event>
	</choice>
</event>

<event name="FR_DESTROYED_TRAPPER_WARZONE_PIRATE">
	<text>While scrapping the wreckage of the Elite Trapper ship, you find a functional Mine Launcher weapon drifting in the midst of the wreckage.</text>
	<autoReward level="MED">standard</autoReward>
