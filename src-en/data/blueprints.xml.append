<augBlueprint name="JUDGE_BOON_FR_CLICKER">
    <title>Grant of Touch</title>
    <desc>Your ship becomes immune to ion damage. Enemy crew take 10hp/s while inside Her Will's system.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_SPHERAX">
    <title>Boon of The Precursors</title>
    <desc>Your Spherax crew can't be stunned.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_WITHER_GUN">
    <title>Blessing of Withering</title>
    <desc>All beam weapons pierce 1 additional shield layer.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_REVENANT_CREW">
    <title>Boon of Revenants</title>
    <desc>All crew can phase through doors and are immune to suffocation damage.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_SNOWMAN">
    <title>Boon of Snow</title>
    <desc>Your Snow crew will slow down all enemies in the same room as them.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_LAVAMAN">
    <title>Boon of Lava</title>
    <desc>Your Lava crew will slowly damage enemies in the same room as them.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_AI_CREW">
    <title>Boon of Artificiality</title>
    <desc>Your AI Avatar crew will now only use 0.1x the space of a normal crew.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

<augBlueprint name="JUDGE_BOON_FR_EX_COMMONWEALTH_CREW">
    <title>[B] Blessing of The Extinct</title>
    <desc>Your Commonwealth crew can teleport anywhere.

	[B] - As an external boon, this augment will provide its normal effect but also stack with any other boon effect if applicable.</desc>
    <cost>0</cost>
    <rarity>0</rarity>
    <stackable>true</stackable>
</augBlueprint>

