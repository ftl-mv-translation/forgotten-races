			</statBoost>
			<statBoost name="noClone">
				<boostType>SET</boostType>
				<value>true</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALL</crewTarget>
				<priority>999999</priority>
			</statBoost>
			<statBoost name="controllable">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALL</crewTarget>
				<priority>999999</priority>
			</statBoost>
			<statBoost name="canRepair">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALL</crewTarget>
				<priority>999999</priority>
			</statBoost>
			<statBoost name="canMan">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALL</crewTarget>
				<priority>999999</priority>
			</statBoost>
