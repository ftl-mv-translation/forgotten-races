<augBlueprint name="FR_INFESTATION">
	<title>Spider Infestation</title>
	<desc>Every 15 seconds, a friendly but uncontrollable spider will violently burst out of enemy crew, dealing 5 damage to them. These spiders will die after 7 seconds. This effect applies on both ships.</desc>
	<cost>150</cost>
	<rarity>0</rarity>
