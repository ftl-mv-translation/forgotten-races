<augBlueprint name="FR_SILVER_SYSTEMS">
	<title>Silver Circuitry</title>
	<desc>Your ship is protected by the presence of scrap. The more scrap you have aboard at any given moment, the higher your defenses will be.
	- For every 20 scrap in your cargo, you have +1% chance to negate incoming hull damage.
	- For every 30 scrap in your cargo, you have +1% chance to negate incoming system damage.</desc>
	<cost>250</cost>
	<rarity>0</rarity>
	<bp>0</bp>
	<value>1</value>
	<stackable>true</stackable>
