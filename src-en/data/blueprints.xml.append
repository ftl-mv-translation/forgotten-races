	<spawnCrew>
		<number>1</number>
		<race>fr_wither_hologram</race>
		<noSlot>true</noSlot>
		<statBoosts>
			<statBoost name="noWarning">
				<boostType>SET</boostType>
				<value>true</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALL</crewTarget>
