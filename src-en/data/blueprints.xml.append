<augBlueprint name="FR_SLOWFUL_MASTERY">
	<title>Slowful Mastery</title>
	<desc>This ship has mastered one aspect of the Temporal Manipulator system, its slowness side. While your Temporal Manipulator system is powered to at least lvl 3, your enemy's weapons recharge 15% slower and their shields recharge 30% slower.</desc>
	<cost>150</cost>
	<rarity>0</rarity>
