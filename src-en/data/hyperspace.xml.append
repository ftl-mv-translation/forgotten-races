<mod:findLike type="achievements" limit="1">
	<mod-append:page>
		<section text="Forgotten Boons" hidden="false">
			<achievement name="ACH_FR_BOON_COMMONWEALTH">
				<secretName>Boon of ???</secretName>
				<secretDescription>Receive the Boon of ??? from Thest.</secretDescription>
				<name>Boon of The Extinct</name>
				<description>Show a Commonwealth crew to Thest. 
				While in effect, your Commonwealth crew can move anywhere by teleporting.</description>
				<header>Boon Received</header>
				<icon>fr_ach_boon_commonwealth</icon>
				<lockImage>ach_locked</lockImage>
				<multiDifficulty>false</multiDifficulty>
			</achievement>
			<achievement name="ACH_FR_BOON_SALT">
				<secretName>Boon of ???</secretName>
				<secretDescription>Receive the Boon of ??? from Thest.</secretDescription>
				<name>Boon of The Forgotten</name>
				<description>Show a Salt crew to Thest. 
				While in effect, your Salt crew become immune to suffocation and stun.</description>
				<header>Boon Received</header>
				<icon>fr_ach_boon_salt</icon>
				<lockImage>ach_locked</lockImage>
				<multiDifficulty>false</multiDifficulty>
			</achievement>
