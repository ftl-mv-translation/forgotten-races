<mod:findLike type="crew" limit="1">

<mod-append:race name="fr_unique_eggman">
	<essential>1</essential>
	<repairSpeed>2</repairSpeed>
	<sabotageSpeedMultiplier>2</sabotageSpeedMultiplier>
	<suffocationModifier>0.83</suffocationModifier>
	<fireDamageMultiplier>0.60</fireDamageMultiplier>
	<damageTakenMultiplier>1.5</damageTakenMultiplier>
	<animBase>human</animBase>
	<defaultSkillLevel>2</defaultSkillLevel>
	<passiveStatBoosts>  
		<statBoost name="statBoost">
			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<amount>2</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>SELF</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<affectsSelf>true</affectsSelf>
			</statBoost>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<droneTarget>DRONES</droneTarget>
			<extraConditions type="and">
				<repairingSystem>true</repairingSystem>
			</extraConditions>
		</statBoost>
		<statBoost name="statBoost">
			<statBoost name="moveSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>2</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>SELF</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<affectsSelf>true</affectsSelf>
			</statBoost>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<droneTarget>DRONES</droneTarget>
			<extraConditions type="and">
				<repairingSystem>true</repairingSystem>
			</extraConditions>
		</statBoost>
		<statBoost name="statBoost">
			<statBoost name="damageMultiplier">
				<boostType>MULT</boostType>
				<amount>2</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>SELF</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<affectsSelf>true</affectsSelf>
			</statBoost>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<droneTarget>DRONES</droneTarget>
			<extraConditions type="and">
				<repairingSystem>true</repairingSystem>
			</extraConditions>
		</statBoost>
		<statBoost name="statBoost">
			<statBoost name="trueHealAmount">
				<boostType>FLAT</boostType>
				<amount>-10</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>SELF</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<affectsSelf>true</affectsSelf>
			</statBoost>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ENEMIES</crewTarget>
			<droneTarget>DRONES</droneTarget>
			<extraConditions type="and">
				<sabotaging>true</sabotaging>
			</extraConditions>
		</statBoost>
	</passiveStatBoosts>
	<deathSounds>
		<deathSound>death1</deathSound>
		<deathSound>death2</deathSound>
	</deathSounds>
	<skills>
		<piloting req="1"/>
		<engines req="1"/>
		<shields req="1"/>
		<weapons req="1"/>
		<repair req="1"/>
		<combat req="1"/>
	</skills>
</mod-append:race>

<mod-append:race name="fr_unique_prophet">
	<essential>1</essential>
	<lowHealthThreshold>2500.0</lowHealthThreshold>
	<lowHealthThresholdPercentage>0.25</lowHealthThresholdPercentage>
	<maxHealth>175</maxHealth>
	<canBurn>false</canBurn>
	<fireRepairMultiplier>1.67</fireRepairMultiplier>
	<moveSpeedMultiplier>0.5</moveSpeedMultiplier>
	<stunMultiplier>0.5</stunMultiplier>
	<animBase>rock</animBase>
	<passiveStatBoosts>  
		<statBoost name="bonusPower">
			<boostType>FLAT</boostType>
			<amount>1</amount>
			<shipTarget>CURRENT_ROOM</shipTarget>
			<crewTarget>SELF</crewTarget>
			<affectsSelf>true</affectsSelf>
			<maxStacks>1</maxStacks>
			<systemRoomTarget>ALL</systemRoomTarget>
			<systemList>
				<drones/>
			</systemList>
		</statBoost>
		<statBoost name="damageMultiplier">
			<boostType>MULT</boostType>
			<amount>1.05</amount>
			<shipTarget>CURRENT_ROOM</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<affectsSelf>false</affectsSelf>
			<droneTarget>CREW</droneTarget>
		</statBoost>
		<statBoost name="maxHealth">
			<boostType>MULT</boostType>
			<amount>1.05</amount>
			<shipTarget>CURRENT_ROOM</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<affectsSelf>false</affectsSelf>
			<droneTarget>CREW</droneTarget>
		</statBoost>
	</passiveStatBoosts>
	<deathSounds>
		<deathSound>rockDeath</deathSound>
	</deathSounds>
	<shootingSounds>
