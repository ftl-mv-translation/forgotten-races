<mod-append:aug name="FR_LOCAL_MAINTENANCE">
	<statBoosts>
		<statBoost name="powerEffect">
			<boostType>SET</boostType>
			<powerEffect>
				<cooldown>25</cooldown>
				<jumpCooldown>full</jumpCooldown>
				<powerSounds>
					<powerSound>droneLaunch</powerSound>
				</powerSounds>
				<req type="enemy">
					<enemyInRoom/>
				</req>
				<buttonText>DRONE</buttonText>
				<tooltip>[COOLDOWN:25s]
					Spawns a temporary drone assistant which can fight and sabotage but not repair or man systems. Will die in 30 seconds while in the enemy ship.</tooltip>
				<cooldownColor r="185" g="185" b="185"/>
				<activateWhenReady enemiesOnly="true">true</activateWhenReady>
				<powerCharges>3</powerCharges>
				<initialCharges>3</initialCharges>
				<chargesPerJump>1</chargesPerJump>
				<spawnCrew>
					<number>1</number>
					<race>human_technician_drone</race>
					<statBoosts>
						<statBoost name="noClone">
							<boostType>SET</boostType>
							<value>true</value>
							<shipTarget>ALL</shipTarget>
							<crewTarget>ALL</crewTarget>
							<priority>999999</priority>
						</statBoost>
					</statBoosts>
				</spawnCrew>
			</powerEffect>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<whiteList>
				<human_technician/>
			</whiteList>
		</statBoost>
		<statBoost name="powerEffect">
			<boostType>SET</boostType>
			<powerEffect>
				<chargeReq>
					<enemyShip/>
				</chargeReq>
				<cooldown>30</cooldown>
				<jumpCooldown>continue</jumpCooldown>
				<buttonText>EXPIRATION</buttonText>
				<tooltip>This drone will die in 30 seconds while in the enemy ship</tooltip>
