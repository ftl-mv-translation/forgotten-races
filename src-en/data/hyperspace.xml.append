<!--
	 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
	 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
			                    NEW SYSTEMS
	 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
	 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->

<mod:findLike type="customSystems">
	<mod-append:customSystem id="fr_clicker" mannable="false"/>
	<mod-append:exclusivityGroup>
		<fr_clicker/>
	</mod-append:exclusivityGroup>
	<mod:findLike type="systemPositions">
		<mod-append:fr_clicker position="900"/>
	</mod:findLike>
	<mod-append:systemPositions subSystemOffset="1015"> 
        <shields position="0"/>
        <engines position="1"/>
        <medbay position="2"/>
        <clonebay position="3"/>
        <oxygen position="4"/>
        <teleporter position="5"/>
        <cloaking position="6"/>
        <artillery position="7"/>
        <mind position="8"/>
        <hacking position="9"/>
        <temporal position="10"/>
		<fr_clicker position="900"/>
        <weapons position="2147483646"/>
        <drones position="2147483647"/>


        <pilot staticOffset="0"/>
        <sensors staticOffset="36"/>
        <doors staticOffset="72"/>
        <battery staticOffset="123"/>
    </mod-append:systemPositions>
	<mod:findLike type="systemPositions" reverse="false" start="1">
		<mod:removeTag />
	</mod:findLike>
</mod:findLike>


<mod:findLike type="ships" limit="1">
	<mod:findLike type="customShip">
		<mod:findLike type="exclusivityOverride">
			<mod-append:exclusivityGroup>
				<fr_clicker/>
			</mod-append:exclusivityGroup>
			<mod:findWithChildLike type="exclusivityGroup" reverse="false" child-type="fr_clicker" start="1">
				<mod:removeTag />
			</mod:findWithChildLike>
		</mod:findLike>
	</mod:findLike>
</mod:findLike>

</FTL>