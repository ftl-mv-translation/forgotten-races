<mod:findLike type="augments" limit="1">

<mod-append:aug name="FR_PERFECTED_SHIELD">
	<function name="ENERGY_SHIELD" value="0" useForReqs="true" warning="false"/>
	<function name="ION_ARMOR" value="0.50" useForReqs="true"/>
	<superShield>
		<value>20</value>
		<color r="255" g="255" b="255" a="1.0"/>
		<shieldImage>ship/fr_shield_base_bubble_white.png</shieldImage>
	</superShield>
	<locked/>
</mod-append:aug>

