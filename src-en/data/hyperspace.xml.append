<mod-append:aug name="FR_SHRAPNEL_AMMO">
	<statBoosts>
		<statBoost name="powerEffect">
			<boostType>ADD</boostType>
				<powerEffect name="fr_shrapnel_ammo">
					<cooldown>1</cooldown>
					<activateWhenReady>true</activateWhenReady>
					<friendlyFire>false</friendlyFire>
					<shipFriendlyFire>true</shipFriendlyFire>
					<jumpCooldown>reset</jumpCooldown>
					<buttonText>SHRAPNEL</buttonText>
					<hideCooldown>true</hideCooldown>
					<hideCharges>true</hideCharges>
					<req>
						<inCombat/>
						<enemyInRoom/>
						<extraConditions type="and">
							<shooting>true</shooting>
						</extraConditions>
					</req>
					<chargeReq>
						<inCombat/>
						<enemyInRoom/>
						<extraConditions type="and">
							<shooting>true</shooting>
						</extraConditions>
					</chargeReq>
					<tooltip>[COOLDOWN:1s]
						Causes the enemy the crew is targeting to take 2 hp/s. Stacks 5 times and lasts for 5 seconds.</tooltip>
					<cooldownColor r="255" g="0" b="0" />
					<statBoosts>
						<statBoost name="trueHealAmount">
							<boostType>FLAT</boostType>
							<amount>-2</amount>
							<shipTarget>CREW_TARGET</shipTarget>
							<crewTarget>ENEMIES</crewTarget>
							<droneTarget>CREW</droneTarget>
							<affectsSelf>false</affectsSelf>
							<duration>5</duration>
							<boostAnim>blood_effect</boostAnim>
							<maxStacks id="fr_shrapnel_ammo_stacks">5</maxStacks>
							<blackList load="LIST_CREW_METAL"/>
						</statBoost>
					</statBoosts>
				</powerEffect>
			<shipTarget>ALL</shipTarget>
			<crewTarget>ALLIES</crewTarget>
			<droneTarget>CREW</droneTarget>
			<maxStacks id="fr_shrapnel_ammo_power">1</maxStacks>
		</statBoost>
	</statBoosts>
	<locked/>
</mod-append:aug>

